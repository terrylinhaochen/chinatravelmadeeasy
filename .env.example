# Google Analytics / Search Console
# Use a single GA4 ID in PUBLIC_GA_MEASUREMENT_ID or comma-separated IDs in PUBLIC_GA_MEASUREMENT_IDS.
PUBLIC_GA_MEASUREMENT_ID=G-X2F8XWJWY6
PUBLIC_GA_MEASUREMENT_IDS=
PUBLIC_GOOGLE_SITE_VERIFICATION=ou8Q0OHDojgqqfKyVjNE7WcdOqP8sWfdEMA-ycfTG5o

# Nano Banana / Gemini image generation
# Required for npm run images:generate. Without this, npm run images:fallback creates local watercolor placeholders.
GEMINI_API_KEY=
NANO_BANANA_MODEL=gemini-3.1-flash-image
