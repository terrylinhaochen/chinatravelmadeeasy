# Google Analytics / Search Console
# Use a single GA4 ID in PUBLIC_GA_MEASUREMENT_ID or comma-separated IDs in PUBLIC_GA_MEASUREMENT_IDS.
PUBLIC_GA_MEASUREMENT_ID=G-X2F8XWJWY6
PUBLIC_GA_MEASUREMENT_IDS=
PUBLIC_GOOGLE_SITE_VERIFICATION=ou8Q0OHDojgqqfKyVjNE7WcdOqP8sWfdEMA-ycfTG5o

# Supabase Auth
# Configure Supabase URL settings to allow:
# - http://127.0.0.1:4323/auth/confirm/
# - https://chinatravelmadeeasy.com/auth/confirm/
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=
PUBLIC_TURNSTILE_SITE_KEY=
# Legacy projects can use PUBLIC_SUPABASE_ANON_KEY instead of the publishable key.
PUBLIC_SUPABASE_ANON_KEY=

# Nano Banana / Gemini image generation
# Required for npm run images:generate. Use npm run images:fallback only for explicit local watercolor placeholders.
GEMINI_API_KEY=
NANO_BANANA_MODEL=gemini-3.1-flash-image
GEMINI_IMAGE_MIME=image/jpeg

# Edge Function secrets (never expose these as PUBLIC_* values):
# TURNSTILE_SECRET_KEY=
# RATE_LIMIT_HMAC_SECRET=
# AMAP_WEB_SERVICE_KEY=
# APPLE_MAPS_SERVER_API_TOKEN=
# OPENAI_API_KEY=
