{
  "name": "China Travel Made Easy",
  "short_name": "China Travel",
  "description": "Save China trip places from social posts and reviews.",
  "start_url": "/map-import/",
  "scope": "/",
  "display": "standalone",
  "background_color": "#faf8f4",
