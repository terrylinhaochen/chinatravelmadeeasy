{
  "name": "chinatravelmadeeasy",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "astro dev",
    "prebuild": "npm run videos:materialize && npm run images:verify",
    "build": "astro build",
    "preview": "astro preview",
    "test:places": "node --test tests/placeExtraction.test.mjs",
    "test:state": "node --test tests/localPrototypeState.test.mjs",
    "test:community-map": "node --test tests/communityMapState.test.mjs",
    "test:shared-task": "node --test tests/sharedLocationTask.test.mjs",
    "test:videos": "node --test tests/videoIngestion.test.mjs",
    "test:library-search": "node --test tests/librarySearch.test.mjs",
    "test:destinations": "node --test tests/destinationQuality.test.mjs",
    "test:local-lens": "node --test tests/localLensStudy.test.mjs tests/localLanguageResearch.test.mjs",
    "test:local-knowledge": "node --test tests/localKnowledgeSubmission.test.mjs",
    "test:supabase-functions": "deno test --allow-env --allow-net supabase/functions/_shared/ctme_test.ts supabase/functions/_shared/videoMetadata_test.ts supabase/functions/_shared/localResearch_test.ts && for dir in supabase/functions/submit-video supabase/functions/video-status supabase/functions/process-video-jobs supabase/functions/submit-local-research supabase/functions/local-research-status supabase/functions/save-map-items supabase/functions/place-experience supabase/functions/place-correction supabase/functions/report-content; do deno check --config \"$dir/deno.json\" \"$dir/index.ts\" || exit 1; done",
    "test:supabase-contract": "node --test tests/supabaseBackendContract.test.mjs",
    "videos:materialize": "node pipeline/materialize_video_snapshots.mjs",
    "test": "npm run test:places && npm run test:state && npm run test:community-map && npm run test:shared-task && npm run test:videos && npm run test:library-search && npm run test:destinations && npm run test:local-lens && npm run test:local-knowledge && npm run test:supabase-contract",
    "images:generate": "node pipeline/prepare_curated_images.mjs",
    "atlas:generate": "node pipeline/generate_world_pixel_atlas.mjs",
    "lists:ingest:google": "node pipeline/ingest_google_maps_list.mjs",
    "images:check": "node pipeline/prepare_curated_images.mjs --dry-run",
    "images:verify": "node pipeline/verify_generated_images.mjs",
    "audit:seo-ai": "python3 pipeline/seo_ai_audit.py",
    "seed:content": "python3 pipeline/content_seeds_from_crowdlisten.py",
    "capture:agent-reach": "python3 pipeline/capture_agent_reach_exports.py",
    "import:agent-reach": "python3 pipeline/agent_reach_to_crowdlisten.py",
    "test:agent-reach-import": "python3 pipeline/agent_reach_to_crowdlisten.py pipeline/agent-reach-sample.jsonl --out /tmp/china-agent-reach-normalized.json",
    "sample:agent-reach": "python3 pipeline/agent_reach_to_crowdlisten.py pipeline/agent-reach-sample.jsonl --out pipeline/agent-reach-normalized-seeds.json",
    "report:agent-reach-gap": "python3 pipeline/agent_reach_gap_report.py",
    "study:local-lens:analyze": "node pipeline/analyze_local_lens_results.mjs",
    "study:local-lens:analyze:seoul": "node pipeline/analyze_local_lens_results.mjs --study seoul",
    "review:local-knowledge": "node pipeline/review_local_knowledge_submissions.mjs",
    "import:handoff": "python3 pipeline/import_handoff_from_crowdlisten.py",
    "draft:handoff": "python3 pipeline/materialize_handoff_drafts.py"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.3.0",
    "@supabase/supabase-js": "^2.110.0",
    "@tailwindcss/vite": "^4.1.0",
    "astro": "^5.8.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.0"
  }
}
