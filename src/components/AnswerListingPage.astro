---
import Icon from './Icon.astro';
import Pagination from './Pagination.astro';
import { getGeneratedImage } from '../data/generatedImages';
import { questionAlternates } from '../data/localizedQuestions';

interface QuestionItem {
  q: string;
  answer: string;
  href: string;
  guide: string;
}

interface PageData {
  lang: string;
  path: string;
  eyebrow: string;
  heading: string;
  intro: string;
  readAnswer: string;
}

interface Props {
  page: PageData;
  items: QuestionItem[];
  currentPage: number;
  totalPages: number;
}

const { page, items, currentPage, totalPages } = Astro.props;

function imageForHref(href: string) {
  const slug = href.match(/^\/guides\/([^/]+)\/?$/)?.[1];
  return slug ? getGeneratedImage(`guide:${slug}`) : undefined;
}
---

<section class="ds-section">
  <div class="flex flex-wrap gap-2">
    {questionAlternates.filter((alternate) => alternate.hreflang !== 'x-default').map((alternate) => (
      <a
        href={alternate.href}
        class:list={[
          'ds-chip',
          alternate.href === page.path ? '!border-accent !bg-accent !text-white' : 'hover:border-accent/50 hover:text-accent',
        ]}
      >
        {alternate.hreflang === 'en' ? 'English' : alternate.hreflang === 'ko' ? '한국어' : '日本語'}
      </a>
    ))}
  </div>

  <p class="ds-eyebrow mt-8">{page.eyebrow}</p>
  <div class="ds-section-head mt-3">
    <div>
      <h1 class="ds-section-title">{page.heading}</h1>
    </div>
    <p class="text-lg leading-relaxed text-soft">{page.intro}</p>
  </div>

  <div class="ds-listing-grid mt-8">
    {items.map((item) => {
      const image = imageForHref(item.href);
      return (
        <a href={item.href} class="ds-listing-card group">
          {image && (
            <div class="ds-listing-thumb">
              <img
                src={image.src}
                alt={image.alt}
                loading="lazy"
              />
            </div>
          )}
          <div class="ds-listing-body">
            <p class="ds-tag text-accent">{item.guide}</p>
            <h2 class="ds-listing-title">{item.q}</h2>
            <p class="ds-listing-copy">{item.answer}</p>
            <p class="mt-auto inline-flex min-h-8 items-center gap-2 pt-4 text-sm font-medium text-accent">
              {page.readAnswer}
              <Icon name="arrow" class="h-3.5 w-3.5" />
            </p>
          </div>
        </a>
      );
    })}
  </div>

  <section class="ds-panel mt-10 p-5 sm:p-6" aria-labelledby="answers-use-heading">
    <div class="grid gap-5 lg:grid-cols-[0.72fr_1.28fr] lg:items-start">
      <div>
        <p class="ds-eyebrow">Answer format</p>
        <h2 id="answers-use-heading" class="mt-2 text-3xl leading-tight">How should I use these answers?</h2>
      </div>
      <div class="grid gap-4 text-sm leading-relaxed text-soft sm:grid-cols-3">
        <p>
          Start with the question closest to your real blocker. Each card gives the short answer first,
          then links to the guide with dates, caveats, and setup steps.
        </p>
        <p>
          The index is written for search and AI retrieval: one traveler problem, one direct answer,
          and one canonical guide path instead of scattered notes.
        </p>
        <p>
          If a question involves maps, food, hotels, transport, or payments, save the relevant place
          first and use the linked guide to check whether the plan will work in China.
        </p>
        <p>
          Use pagination as a filtered reading path rather than a deep archive. Later pages still keep
          the same answer structure so a saved search result can explain the problem, the fix, and the
          next place to open.
        </p>
        <p>
          When a result is not enough, move from the answer card to the full guide. The longer guide
          carries examples, tradeoffs, and warnings that would make the index harder to scan.
        </p>
        <p>
          For trip planning, the best rhythm is simple: answer the blocker, save the place or route,
          then keep the practical guide open while booking transport, hotels, or food stops.
        </p>
      </div>
    </div>
  </section>

  <Pagination basePath="/answers/" currentPage={currentPage} totalPages={totalPages} />
</section>
