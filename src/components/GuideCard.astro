---
import Icon from './Icon.astro';
import type { CollectionEntry } from 'astro:content';
import { getGuideImage } from '../data/guideImages';

interface Props {
  guide: CollectionEntry<'guides'>;
  searchId?: string;
  searchText?: string;
}

const { guide, searchId, searchText } = Astro.props;
const { title, description, category, icon, updated } = guide.data;
const image = getGuideImage(guide.id);
const fmt = updated.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  timeZone: 'UTC',
});
---

<a
  href={`/guides/${guide.id}/`}
  class="ds-listing-card group"
  data-library-item={searchId}
  data-library-search={searchText}
>
  <div class="ds-listing-thumb">
    <img src={image.src} alt={image.alt} loading="lazy" />
  </div>
  <div class="ds-listing-body">
    <div class="flex items-center gap-2">
      <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-accent-soft text-accent">
        <Icon name={icon} class="h-4 w-4" />
      </span>
      <p class="ds-tag">{category}</p>
    </div>
    <h3 class="ds-listing-title">
      {title}
    </h3>
    <p class="ds-listing-copy">{description}</p>
    <p class="mt-auto pt-4 text-xs text-faint">Updated {fmt}</p>
  </div>
</a>
