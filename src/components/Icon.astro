---
// Minimal inline stroke icons (24x24 viewBox), no external assets.
interface Props {
  name: string;
  class?: string;
}
const { name, class: className = 'w-5 h-5' } = Astro.props;

const paths: Record<string, string> = {
  // wallet / payments
  wallet:
    'M3 7a2 2 0 0 1 2-2h13a1 1 0 0 1 1 1v2M3 7v10a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7a2 2 0 0 0-2-2H3Zm13 6h2',
  // wifi / internet
  wifi: 'M2.5 9.5a14 14 0 0 1 19 0M5.5 13a9.5 9.5 0 0 1 13 0M8.7 16.3a5 5 0 0 1 6.6 0M12 19.5h.01',
  // passport / visa
  passport:
    'M6 2.5h12a1.5 1.5 0 0 1 1.5 1.5v16a1.5 1.5 0 0 1-1.5 1.5H6A1.5 1.5 0 0 1 4.5 20V4A1.5 1.5 0 0 1 6 2.5Zm6 11a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7ZM8.5 17.5h7',
  // train
  train:
    'M7 3.5h10a2 2 0 0 1 2 2V15a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V5.5a2 2 0 0 1 2-2Zm-2 7h14M9 20.5l-1.5-3.5m9 3.5 1.5-3.5M9 13.5h.01m5.99 0h.01',
  // bus / city transit
  bus: 'M5 4h14a1.5 1.5 0 0 1 1.5 1.5V17a1.5 1.5 0 0 1-1.5 1.5H5A1.5 1.5 0 0 1 3.5 17V5.5A1.5 1.5 0 0 1 5 4Zm-1.5 7h17M7.5 15h.01m8.99 0h.01M7 21l.5-2.5m10 2.5-.5-2.5',
  // chat / translate
  chat: 'M4 5h9v8H8l-3 3v-3H4V5Zm9 5h7v7h-1v3l-3-3h-3v-2M7 8.5h3M8.5 7v1.5',
  // bed / hotel
  bed: 'M3 18v-7m0 3h18v4m0-4v-2a2 2 0 0 0-2-2h-8v4M6.5 12.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3ZM3 6v5',
  // bowl / food
  bowl: 'M4 11h16a8 8 0 0 1-5 7.4V20H9v-1.6A8 8 0 0 1 4 11Zm9.5-7.5-3 5m6.5-4-2.5 4',
  // map / itinerary
  map: 'M9 4 4 6v14l5-2 6 2 5-2V4l-5 2-6-2Zm0 0v14m6-12v14',
  // checklist
  checklist:
    'M8 3.5h8a1 1 0 0 1 1 1V5h2a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1h2v-.5a1 1 0 0 1 1-1ZM8 5h8v2H8V5Zm0 7 1.5 1.5L12.5 10M8 17h8',
  // compass (default)
  compass:
    'M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Zm3.5-12.5-2 5-5 2 2-5 5-2Z',
  // arrow
  arrow: 'M5 12h14m-6-6 6 6-6 6',
};

const d = paths[name] ?? paths.compass;
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.7"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  <path d={d}></path>
</svg>
