---
import { destinations } from '../data/destinations';
import { destinationCoordinates } from '../data/destinationCoordinates';
import { isWorldPixelLand, projectLonLatToWorldCell, worldPixelAtlas, worldPixelKey } from '../data/worldPixelAtlas';

interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  class?: string;
}

const {
  eyebrow = 'Explored map',
  title = 'See where traveler pins cluster.',
  description = 'A shareable block atlas for saved-place signal. Darker pixels mean more pins, guides, and repeat traveler interest.',
} = Astro.props;
const className = Astro.props.class ?? '';
const mapColumns = worldPixelAtlas.columns;
const mapRows = worldPixelAtlas.rows;

const regionCount = destinations.length;
const cityAreaCount = new Set(destinations.flatMap((destination) => destination.places.map((place) => place.area))).size;

function densityFor(destination: (typeof destinations)[number]) {
  const base = destination.places.length * 2 + destination.guideIds.length;
  const bonus = destination.featured ? 4 : destination.type === 'Municipality' ? 2 : 0;
  return Math.min(5, Math.max(1, Math.round((base + bonus) / 3)));
}

const mapRegions = destinations.map((destination) => {
  const density = densityFor(destination);
  const coordinate = destinationCoordinates[destination.slug];
  const projected = coordinate
    ? projectLonLatToWorldCell(coordinate.lon, coordinate.lat)
    : {
        column: Math.min(mapColumns, Math.max(1, Math.round((destination.mapPin.x / 100) * mapColumns))),
        row: Math.min(mapRows, Math.max(1, Math.round((destination.mapPin.y / 100) * mapRows))),
      };
  return {
    name: destination.name,
    slug: destination.slug,
    density,
    placeCount: destination.places.length,
    regionHref: `/regions/${destination.slug}/`,
    column: projected.column,
    row: projected.row,
    coordinate,
  };
});

const totalPins = mapRegions.reduce((sum, region) => sum + region.placeCount, 0);
const mostActive = [...mapRegions].sort((a, b) => b.density - a.density || b.placeCount - a.placeCount).slice(0, 4);
const regionCells = new Map<string, (typeof mapRegions)[number] & { regionCount: number }>();

for (const region of mapRegions) {
  const key = worldPixelKey(region.column, region.row);
  const existing = regionCells.get(key);
  if (!existing || region.density > existing.density || region.placeCount > existing.placeCount) {
    regionCells.set(key, { ...region, regionCount: (existing?.regionCount ?? 0) + 1 });
  } else {
    existing.regionCount += 1;
  }
}

const mapCells = Array.from({ length: mapColumns * mapRows }).map((_, index) => {
  const column = (index % mapColumns) + 1;
  const row = Math.floor(index / mapColumns) + 1;
  const active = regionCells.get(worldPixelKey(column, row));
  return { column, row, isLand: isWorldPixelLand(column, row), active };
});
---

<section class={`pin-density-panel ds-panel overflow-hidden p-5 sm:p-6 lg:p-8 ${className}`}>
  <div class="grid gap-8 lg:grid-cols-[0.6fr_1.4fr] lg:items-start">
    <div class="min-w-0">
      <p class="ds-eyebrow">{eyebrow}</p>
      <h2 class="mt-3 max-w-xl text-4xl leading-tight sm:text-5xl">{title}</h2>
      <p class="mt-4 max-w-xl leading-relaxed text-soft">{description}</p>

      <div class="pin-density-stats mt-6">
        <div class="rounded-md border border-line bg-white/75 p-4">
          <p class="ds-tag">Regions</p>
          <p class="mt-2 text-3xl leading-none">{regionCount}</p>
        </div>
        <div class="rounded-md border border-line bg-white/75 p-4">
          <p class="ds-tag">Cities</p>
          <p class="mt-2 text-3xl leading-none">{cityAreaCount}</p>
        </div>
        <div class="rounded-md border border-line bg-white/75 p-4">
          <p class="ds-tag">Pins</p>
          <p class="mt-2 text-3xl leading-none">{totalPins}</p>
        </div>
      </div>
    </div>

    <div class="min-w-0">
      <div class="pin-density-activity" aria-label="Equal Earth saved place pixel atlas">
        <div class="pin-density-world-grid" style={`--atlas-columns: ${mapColumns};`} data-projection={worldPixelAtlas.projection}>
          {mapCells.map((cell) => (
            cell.active ? (
              <a
                href={cell.active.regionHref}
                class="pin-density-world-cell"
                data-land="true"
                data-active="true"
                data-density={cell.active.density}
                data-cell={`${cell.column}:${cell.row}`}
                aria-label={`${cell.active.name}: ${cell.active.placeCount} saved-place signals on the atlas`}
                title={`${cell.active.name}: ${cell.active.placeCount} saved-place signals`}
              ></a>
            ) : (
              <span
                class="pin-density-world-cell"
                data-land={cell.isLand ? 'true' : 'false'}
                data-cell={`${cell.column}:${cell.row}`}
                aria-hidden="true"
              ></span>
            )
          ))}
        </div>
      </div>

      <div class="mt-4 flex flex-wrap items-center justify-between gap-3">
        <div class="pin-density-legend" aria-hidden="true">
          <span>Less</span>
          <i data-level="1"></i>
          <i data-level="2"></i>
          <i data-level="3"></i>
          <i data-level="4"></i>
          <i data-level="5"></i>
          <span>More</span>
        </div>
        <div class="flex flex-wrap gap-2">
          {mostActive.map((region) => (
            <a href={region.regionHref} class="ds-chip hover:border-accent/50 hover:text-accent">{region.name}</a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .pin-density-activity {
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: 18px;
    background:
      radial-gradient(circle at 76% 28%, rgb(140 47 34 / 0.07), transparent 18%),
      radial-gradient(circle at 55% 66%, rgb(140 47 34 / 0.07), transparent 20%),
      linear-gradient(145deg, #ffffff, #f3f1ee);
    padding: clamp(0.55rem, 1.7vw, 1rem);
  }

  .pin-density-world-grid {
    display: grid;
    grid-template-columns: repeat(var(--atlas-columns), minmax(0, 1fr));
    gap: clamp(0.04rem, 0.16vw, 0.12rem);
  }

  .pin-density-world-cell {
    aspect-ratio: 1;
    border-radius: clamp(1px, 0.32vw, 4px);
    background: transparent;
  }

  .pin-density-world-cell[data-land="true"] {
    background: rgb(214 211 209 / 0.5);
    box-shadow: inset 0 0 0 1px rgb(255 255 255 / 0.38);
  }

  .pin-density-world-cell[data-active="true"] {
    border: 1px solid rgb(255 255 255 / 0.78);
    background: rgb(140 47 34 / 0.38);
    box-shadow: 0 6px 14px rgb(12 10 9 / 0.12);
    transition:
      background-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .pin-density-world-cell[data-density="2"] {
    background: rgb(140 47 34 / 0.5);
  }

  .pin-density-world-cell[data-density="3"] {
    background: rgb(140 47 34 / 0.64);
  }

  .pin-density-world-cell[data-density="4"] {
    background: rgb(140 47 34 / 0.78);
  }

  .pin-density-world-cell[data-density="5"] {
    background: rgb(140 47 34 / 0.94);
  }

  .pin-density-world-cell[data-active="true"]:hover,
  .pin-density-world-cell[data-active="true"]:focus-visible {
    outline: 2px solid white;
    outline-offset: 2px;
    transform: scale(1.28);
    box-shadow: 0 12px 26px rgb(12 10 9 / 0.24);
  }

  .pin-density-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .pin-density-legend {
    display: flex;
    align-items: center;
    gap: 0.42rem;
    color: var(--color-faint);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .pin-density-legend i {
    display: block;
    width: 0.92rem;
    height: 0.92rem;
    border-radius: 4px;
    background: rgb(140 47 34 / 0.32);
  }

  .pin-density-legend i[data-level="2"] {
    background: rgb(140 47 34 / 0.46);
  }

  .pin-density-legend i[data-level="3"] {
    background: rgb(140 47 34 / 0.62);
  }

  .pin-density-legend i[data-level="4"] {
    background: rgb(140 47 34 / 0.78);
  }

  .pin-density-legend i[data-level="5"] {
    background: rgb(140 47 34 / 0.94);
  }

  @media (max-width: 640px) {
    .pin-density-panel {
      padding: 1rem;
    }

    .pin-density-stats {
      grid-template-columns: 1fr;
    }
  }
</style>
