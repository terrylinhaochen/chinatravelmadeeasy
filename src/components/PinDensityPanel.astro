---
import { destinations } from '../data/destinations';

interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  class?: string;
}

const {
  eyebrow = 'Map profile',
  title = 'Track where useful pins keep showing up.',
  description = 'A province-level activity map for the places travelers keep saving.',
} = Astro.props;
const className = Astro.props.class ?? '';
const activityColumns = 18;
const activityRows = 12;

function isMapLandCell(column: number, row: number) {
  const bands: Record<number, Array<[number, number]>> = {
    1: [[7, 12]],
    2: [[5, 14]],
    3: [[4, 16]],
    4: [[3, 16]],
    5: [[4, 17]],
    6: [[4, 16]],
    7: [[5, 15]],
    8: [[5, 14]],
    9: [[6, 13]],
    10: [[7, 12]],
    11: [[8, 10], [13, 13]],
    12: [[9, 10]],
  };
  return (bands[row] ?? []).some(([start, end]) => column >= start && column <= end);
}

function densityFor(destination: (typeof destinations)[number]) {
  const base = destination.places.length * 2 + destination.guideIds.length;
  const bonus = destination.featured ? 4 : destination.type === 'Municipality' ? 2 : 0;
  return Math.min(5, Math.max(1, Math.round((base + bonus) / 3)));
}

const mapRegions = destinations.map((destination) => {
  const density = densityFor(destination);
  return {
    name: destination.name,
    slug: destination.slug,
    density,
    placeCount: destination.places.length,
    regionHref: `/regions/${destination.slug}/`,
    gridX: Math.min(activityColumns, Math.max(1, Math.round((destination.mapPin.x / 100) * (activityColumns - 1)) + 1)),
    gridY: Math.min(activityRows, Math.max(1, Math.round((destination.mapPin.y / 100) * (activityRows - 1)) + 1)),
  };
});

const totalPins = mapRegions.reduce((sum, region) => sum + region.placeCount, 0);
const mostActive = [...mapRegions].sort((a, b) => b.density - a.density || b.placeCount - a.placeCount).slice(0, 4);
const backgroundCells = Array.from({ length: activityColumns * activityRows }).map((_, index) => {
  const column = (index % activityColumns) + 1;
  const row = Math.floor(index / activityColumns) + 1;
  return { column, row, isLand: isMapLandCell(column, row) };
});
---

<section class={`pin-density-panel ds-panel overflow-hidden p-5 sm:p-6 lg:p-8 ${className}`}>
  <div class="grid gap-8 lg:grid-cols-[0.62fr_1.38fr] lg:items-start">
    <div class="min-w-0">
      <p class="ds-eyebrow">{eyebrow}</p>
      <h2 class="mt-3 max-w-xl text-4xl leading-tight sm:text-5xl">{title}</h2>
      <p class="mt-4 max-w-xl leading-relaxed text-soft">{description}</p>

      <div class="mt-6 grid grid-cols-3 gap-3">
        <div class="rounded-md border border-line bg-white/75 p-4">
          <p class="ds-tag">Regions</p>
          <p class="mt-2 text-3xl leading-none">{mapRegions.length}</p>
        </div>
        <div class="rounded-md border border-line bg-white/75 p-4">
          <p class="ds-tag">Pins</p>
          <p class="mt-2 text-3xl leading-none">{totalPins}</p>
        </div>
        <div class="rounded-md border border-line bg-white/75 p-4">
          <p class="ds-tag">Hotspots</p>
          <p class="mt-2 text-3xl leading-none">{mostActive.length}</p>
        </div>
      </div>
    </div>

    <div class="min-w-0">
      <div class="pin-density-activity" aria-label="Province-level pin activity map">
        <div class="pin-density-activity-grid" aria-hidden="true">
          {backgroundCells.map((cell) => <span data-land={cell.isLand ? 'true' : 'false'}></span>)}
        </div>
        {mapRegions.map((region) => (
          <a
            href={region.regionHref}
            class="pin-density-cell"
            style={`--grid-x: ${region.gridX}; --grid-y: ${region.gridY};`}
            data-density={region.density}
            aria-label={`${region.name}: ${region.placeCount} saved-place signals`}
            title={`${region.name}: ${region.placeCount} saved-place signals`}
          />
        ))}
      </div>

      <div class="mt-4 flex flex-wrap items-center justify-between gap-3">
        <div class="pin-density-legend" aria-hidden="true">
          <span>Less</span>
          <i data-level="1"></i>
          <i data-level="2"></i>
          <i data-level="3"></i>
          <i data-level="4"></i>
          <i data-level="5"></i>
          <span>More</span>
        </div>
        <div class="flex flex-wrap gap-2">
          {mostActive.map((region) => (
            <a href={region.regionHref} class="ds-chip hover:border-accent/50 hover:text-accent">{region.name}</a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .pin-density-activity {
    position: relative;
    min-height: 36rem;
    border: 1px solid var(--color-line);
    border-radius: 18px;
    background:
      radial-gradient(circle at 76% 28%, rgb(140 47 34 / 0.08), transparent 18%),
      radial-gradient(circle at 55% 66%, rgb(140 47 34 / 0.08), transparent 20%),
      linear-gradient(145deg, #ffffff, #f3f1ee);
  }

  .pin-density-activity-grid {
    position: absolute;
    inset: 1.25rem;
    display: grid;
    grid-template-columns: repeat(18, minmax(0, 1fr));
    grid-template-rows: repeat(12, minmax(0, 1fr));
    gap: 0.32rem;
  }

  .pin-density-activity-grid span {
    border-radius: 5px;
    background: transparent;
  }

  .pin-density-activity-grid span[data-land="true"] {
    background: rgb(214 211 209 / 0.62);
    box-shadow: inset 0 0 0 1px rgb(255 255 255 / 0.36);
  }

  .pin-density-cell {
    position: absolute;
    left: calc(1.25rem + (100% - 2.5rem) / 18 * (var(--grid-x) - 0.5));
    top: calc(1.25rem + (100% - 2.5rem) / 12 * (var(--grid-y) - 0.5));
    z-index: 2;
    width: clamp(1.2rem, 4.3vw, 2.1rem);
    height: clamp(1.2rem, 4.3vw, 2.1rem);
    border: 1px solid rgb(255 255 255 / 0.78);
    border-radius: 6px;
    background: rgb(140 47 34 / 0.38);
    box-shadow: 0 8px 18px rgb(12 10 9 / 0.14);
    transform: translate(-50%, -50%);
    transition:
      background-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .pin-density-cell[data-density="2"] {
    background: rgb(140 47 34 / 0.5);
  }

  .pin-density-cell[data-density="3"] {
    background: rgb(140 47 34 / 0.64);
  }

  .pin-density-cell[data-density="4"] {
    background: rgb(140 47 34 / 0.78);
  }

  .pin-density-cell[data-density="5"] {
    background: rgb(140 47 34 / 0.94);
  }

  .pin-density-cell:hover,
  .pin-density-cell:focus-visible,
  .pin-density-cell.is-active {
    outline: 2px solid white;
    outline-offset: 2px;
    transform: translate(-50%, -50%) scale(1.18);
    box-shadow: 0 12px 26px rgb(12 10 9 / 0.24);
  }

  .pin-density-legend {
    display: flex;
    align-items: center;
    gap: 0.42rem;
    color: var(--color-faint);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .pin-density-legend i {
    display: block;
    width: 0.92rem;
    height: 0.92rem;
    border-radius: 4px;
    background: rgb(140 47 34 / 0.32);
  }

  .pin-density-legend i[data-level="2"] {
    background: rgb(140 47 34 / 0.46);
  }

  .pin-density-legend i[data-level="3"] {
    background: rgb(140 47 34 / 0.62);
  }

  .pin-density-legend i[data-level="4"] {
    background: rgb(140 47 34 / 0.78);
  }

  .pin-density-legend i[data-level="5"] {
    background: rgb(140 47 34 / 0.94);
  }

  @media (max-width: 640px) {
    .pin-density-activity {
      min-height: 26rem;
    }

    .pin-density-activity-grid {
      gap: 0.28rem;
    }
  }
</style>
