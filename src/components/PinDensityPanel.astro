---
import { destinations } from '../data/destinations';

interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  class?: string;
}

const {
  eyebrow = 'Explored map',
  title = 'See where traveler pins cluster.',
  description = 'A shareable world atlas for saved-place signal. Darker pixels mean more pins, guides, and repeat traveler interest.',
} = Astro.props;
const className = Astro.props.class ?? '';

const countryRegionCount = 4;
const cityAreaCount = new Set(destinations.flatMap((destination) => destination.places.map((place) => place.area))).size;

const continentPaths = [
  'M83 155C126 102 191 73 254 90C301 103 320 124 354 126C389 128 399 157 368 186C337 215 309 213 288 239C260 273 223 277 184 252C145 226 102 217 79 187C66 171 69 166 83 155Z',
  'M309 272C350 291 367 329 352 369C339 404 322 431 330 463C337 489 314 503 292 479C270 456 254 423 252 384C250 346 269 317 286 286C292 276 300 270 309 272Z',
  'M462 124C487 103 527 100 555 119C586 139 577 167 536 166C499 165 475 152 452 155C427 157 434 140 462 124Z',
  'M474 191C516 173 559 189 579 230C599 269 584 320 555 353C528 384 487 379 473 334C458 287 438 247 456 213C460 203 466 196 474 191Z',
  'M592 137C641 105 708 105 764 128C823 153 877 143 913 178C948 212 911 249 854 236C807 225 774 253 733 243C690 232 656 215 620 218C586 221 562 192 574 164C577 153 583 144 592 137Z',
  'M747 288C786 269 842 281 873 313C899 339 880 372 835 368C789 364 743 348 719 329C699 313 713 297 747 288Z',
];

function densityFor(destination: (typeof destinations)[number]) {
  const base = destination.places.length * 2 + destination.guideIds.length;
  const bonus = destination.featured ? 4 : destination.type === 'Municipality' ? 2 : 0;
  return Math.min(5, Math.max(1, Math.round((base + bonus) / 3)));
}

const mapRegions = destinations.map((destination) => {
  const density = densityFor(destination);
  return {
    name: destination.name,
    slug: destination.slug,
    density,
    placeCount: destination.places.length,
    regionHref: `/regions/${destination.slug}/`,
    worldX: Math.min(842, Math.max(690, Math.round(690 + (destination.mapPin.x / 100) * 152))),
    worldY: Math.min(350, Math.max(126, Math.round(126 + (destination.mapPin.y / 100) * 224))),
  };
});

const totalPins = mapRegions.reduce((sum, region) => sum + region.placeCount, 0);
const mostActive = [...mapRegions].sort((a, b) => b.density - a.density || b.placeCount - a.placeCount).slice(0, 4);
---

<section class={`pin-density-panel ds-panel overflow-hidden p-5 sm:p-6 lg:p-8 ${className}`}>
  <div class="grid gap-8 lg:grid-cols-[0.6fr_1.4fr] lg:items-start">
    <div class="min-w-0">
      <p class="ds-eyebrow">{eyebrow}</p>
      <h2 class="mt-3 max-w-xl text-4xl leading-tight sm:text-5xl">{title}</h2>
      <p class="mt-4 max-w-xl leading-relaxed text-soft">{description}</p>

      <div class="pin-density-stats mt-6">
        <div class="rounded-md border border-line bg-white/75 p-4">
          <p class="ds-tag">Countries/regions</p>
          <p class="mt-2 text-3xl leading-none">{countryRegionCount}</p>
        </div>
        <div class="rounded-md border border-line bg-white/75 p-4">
          <p class="ds-tag">Cities/areas</p>
          <p class="mt-2 text-3xl leading-none">{cityAreaCount}</p>
        </div>
        <div class="rounded-md border border-line bg-white/75 p-4">
          <p class="ds-tag">Pins</p>
          <p class="mt-2 text-3xl leading-none">{totalPins}</p>
        </div>
      </div>
    </div>

    <div class="min-w-0">
      <div class="pin-density-activity" aria-label="World-style saved place activity map">
        <svg class="pin-density-world-map" viewBox="0 0 1000 520" role="img" aria-labelledby="pin-density-title pin-density-desc">
          <title id="pin-density-title">World map of saved travel pins</title>
          <desc id="pin-density-desc">A global map with darker square pixels clustered over China and nearby planning regions.</desc>
          <rect class="pin-density-ocean" x="0" y="0" width="1000" height="520" rx="34"></rect>
          <g class="pin-density-graticule" aria-hidden="true">
            <path d="M80 130H920M80 260H920M80 390H920"></path>
            <path d="M200 74V446M400 74V446M600 74V446M800 74V446"></path>
          </g>
          <g class="pin-density-land" aria-hidden="true">
            {continentPaths.map((path) => <path d={path}></path>)}
          </g>
          <g class="pin-density-heat" aria-label="Saved-place density by region">
            {mapRegions.map((region) => (
              <a
                href={region.regionHref}
                aria-label={`${region.name}: ${region.placeCount} saved-place signals`}
                title={`${region.name}: ${region.placeCount} saved-place signals`}
              >
                <rect
                  class="pin-density-map-pixel"
                  x={region.worldX}
                  y={region.worldY}
                  width="16"
                  height="16"
                  rx="3"
                  data-density={region.density}
                ></rect>
              </a>
            ))}
          </g>
        </svg>
      </div>

      <div class="mt-4 flex flex-wrap items-center justify-between gap-3">
        <div class="pin-density-legend" aria-hidden="true">
          <span>Less</span>
          <i data-level="1"></i>
          <i data-level="2"></i>
          <i data-level="3"></i>
          <i data-level="4"></i>
          <i data-level="5"></i>
          <span>More</span>
        </div>
        <div class="flex flex-wrap gap-2">
          {mostActive.map((region) => (
            <a href={region.regionHref} class="ds-chip hover:border-accent/50 hover:text-accent">{region.name}</a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .pin-density-activity {
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: 18px;
    background:
      radial-gradient(circle at 76% 28%, rgb(140 47 34 / 0.07), transparent 18%),
      radial-gradient(circle at 55% 66%, rgb(140 47 34 / 0.07), transparent 20%),
      linear-gradient(145deg, #ffffff, #f3f1ee);
    padding: clamp(0.45rem, 1.7vw, 1rem);
  }

  .pin-density-world-map {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1.92;
  }

  .pin-density-ocean {
    fill: rgb(250 249 247 / 0.94);
  }

  .pin-density-graticule path {
    fill: none;
    stroke: rgb(120 113 108 / 0.09);
    stroke-width: 1.2;
    vector-effect: non-scaling-stroke;
  }

  .pin-density-land path {
    fill: rgb(214 211 209 / 0.64);
    stroke: rgb(255 255 255 / 0.55);
    stroke-width: 7;
    stroke-linejoin: round;
  }

  .pin-density-map-pixel {
    fill: rgb(140 47 34 / 0.38);
    stroke: rgb(255 255 255 / 0.72);
    stroke-width: 2;
    transform-box: fill-box;
    transform-origin: center;
    transition:
      fill 160ms ease,
      filter 160ms ease,
      transform 160ms ease;
  }

  .pin-density-map-pixel[data-density="2"] {
    fill: rgb(140 47 34 / 0.5);
  }

  .pin-density-map-pixel[data-density="3"] {
    fill: rgb(140 47 34 / 0.64);
  }

  .pin-density-map-pixel[data-density="4"] {
    fill: rgb(140 47 34 / 0.78);
  }

  .pin-density-map-pixel[data-density="5"] {
    fill: rgb(140 47 34 / 0.94);
  }

  .pin-density-heat a:hover .pin-density-map-pixel,
  .pin-density-heat a:focus-visible .pin-density-map-pixel {
    filter: drop-shadow(0 10px 16px rgb(12 10 9 / 0.22));
    transform: scale(1.24);
  }

  .pin-density-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .pin-density-legend {
    display: flex;
    align-items: center;
    gap: 0.42rem;
    color: var(--color-faint);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .pin-density-legend i {
    display: block;
    width: 0.92rem;
    height: 0.92rem;
    border-radius: 4px;
    background: rgb(140 47 34 / 0.32);
  }

  .pin-density-legend i[data-level="2"] {
    background: rgb(140 47 34 / 0.46);
  }

  .pin-density-legend i[data-level="3"] {
    background: rgb(140 47 34 / 0.62);
  }

  .pin-density-legend i[data-level="4"] {
    background: rgb(140 47 34 / 0.78);
  }

  .pin-density-legend i[data-level="5"] {
    background: rgb(140 47 34 / 0.94);
  }

  @media (max-width: 640px) {
    .pin-density-panel {
      padding: 1rem;
    }

    .pin-density-stats {
      grid-template-columns: 1fr;
    }

    .pin-density-land path {
      stroke-width: 10;
    }

    .pin-density-map-pixel {
      width: 18px;
      height: 18px;
    }
  }
</style>
