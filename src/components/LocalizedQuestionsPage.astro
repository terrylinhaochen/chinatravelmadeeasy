---
import Icon from './Icon.astro';
import { questionAlternates } from '../data/localizedQuestions';

interface QuestionItem {
  q: string;
  answer: string;
  href: string;
  guide: string;
  related?: { label: string; href: string }[];
}

interface QuestionGroup {
  title: string;
  questions: QuestionItem[];
}

interface PageData {
  lang: string;
  path: string;
  label: string;
  eyebrow: string;
  heading: string;
  intro: string;
  whyTitle: string;
  whyCopy: string;
  steps: readonly (readonly [string, string])[];
  readAnswer: string;
  submitTitle: string;
  submitCopy: string;
  submitButton: string;
  questionPlaceholder: string;
  emailLabel: string;
  groups: readonly QuestionGroup[];
}

const { page } = Astro.props as { page: PageData };
---

<section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16">
  <div class="flex flex-wrap gap-2">
    {questionAlternates.filter((alternate) => alternate.hreflang !== 'x-default').map((alternate) => (
      <a
        href={alternate.href}
        class:list={[
          'rounded-md border px-3 py-1.5 text-sm font-semibold',
          alternate.href === page.path ? 'border-accent bg-accent text-white' : 'border-line text-soft hover:border-accent/50 hover:text-accent',
        ]}
      >
        {alternate.hreflang === 'en' ? 'English' : alternate.hreflang === 'ko' ? '한국어' : '日本語'}
      </a>
    ))}
  </div>

  <p class="mt-8 text-[12px] font-semibold uppercase tracking-[0.15em] text-accent">
    {page.eyebrow}
  </p>
  <div class="mt-3 grid gap-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
    <div>
      <h1 class="font-display font-bold text-4xl sm:text-5xl leading-tight">
        {page.heading}
      </h1>
    </div>
    <p class="text-soft text-lg leading-relaxed">
      {page.intro}
    </p>
  </div>
</section>

<section class="mx-auto max-w-6xl px-4 sm:px-6">
  <div class="rounded-lg border border-line bg-[#f4f0e8] p-4 sm:p-6">
    <div class="grid gap-6 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
      <div>
        <h2 class="font-display text-3xl font-bold">{page.whyTitle}</h2>
        <p class="mt-3 text-soft leading-relaxed">{page.whyCopy}</p>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        {page.steps.map(([title, copy]) => (
          <div class="rounded-lg border border-line bg-white p-5">
            <p class="text-[11px] font-semibold uppercase tracking-wider text-faint">{title}</p>
            <p class="text-soft text-sm mt-2 leading-relaxed">{copy}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16">
  <div class="space-y-10">
    {page.groups.map((group) => (
      <section aria-labelledby={group.title.toLowerCase().replaceAll(' ', '-')}>
        <h2 id={group.title.toLowerCase().replaceAll(' ', '-')} class="font-display text-2xl font-bold">{group.title}</h2>
        <div class="mt-4 grid gap-4 lg:grid-cols-3">
          {group.questions.map((item) => (
            <a href={item.href} class="group rounded-lg border border-line bg-card p-5 transition-colors hover:border-accent/50">
              <p class="text-[11px] font-semibold uppercase tracking-wider text-accent">{item.guide}</p>
              <h3 class="mt-2 font-display text-xl font-bold leading-snug group-hover:text-accent">{item.q}</h3>
              <p class="mt-2 text-sm leading-relaxed text-soft">{item.answer}</p>
              {item.related && item.related.length > 0 && (
                <div class="mt-4 border-t border-line pt-3">
                  <p class="text-[11px] font-semibold uppercase tracking-wider text-faint">Also answered by</p>
                  <div class="mt-2 flex flex-wrap gap-2">
                    {item.related.map((related) => (
                      <span class="rounded-md bg-paper px-2.5 py-1 text-xs font-semibold text-soft">
                        {related.label}
                      </span>
                    ))}
                  </div>
                </div>
              )}
              <p class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-accent">
                {page.readAnswer}
                <Icon name="arrow" class="h-3.5 w-3.5" />
              </p>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</section>

<section class="mx-auto max-w-6xl px-4 sm:px-6">
  <div class="rounded-lg border border-line bg-card p-6 sm:p-8">
    <div class="grid gap-6 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
      <div>
        <p class="text-[12px] font-semibold uppercase tracking-[0.15em] text-accent">{page.eyebrow}</p>
        <h2 class="mt-2 font-display text-3xl font-bold">{page.submitTitle}</h2>
        <p class="mt-3 text-soft leading-relaxed">{page.submitCopy}</p>
      </div>
      <form action="mailto:hello@chinatravelmadeeasy.com" method="post" enctype="text/plain" class="grid gap-3">
        <label class="grid gap-1 text-sm font-semibold text-soft">
          {page.submitTitle}
          <textarea name="question" rows="5" class="w-full rounded-md border border-line bg-paper p-3 font-body text-ink outline-none focus:border-accent" placeholder={page.questionPlaceholder}></textarea>
        </label>
        <label class="grid gap-1 text-sm font-semibold text-soft">
          {page.emailLabel}
          <input name="email" type="email" class="w-full rounded-md border border-line bg-paper p-3 font-body text-ink outline-none focus:border-accent" placeholder="you@example.com" />
        </label>
        <button type="submit" class="justify-self-start rounded-md bg-accent px-5 py-2.5 text-sm font-semibold text-white hover:bg-accent-dark">
          {page.submitButton}
        </button>
      </form>
    </div>
  </div>
</section>
