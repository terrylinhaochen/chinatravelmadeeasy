---
import type { CuratedCollection } from '../data/curatedCollections';
import { isWorldPixelLand, projectLonLatToWorldCell, worldPixelAtlas, worldPixelKey } from '../data/worldPixelAtlas';

interface Props {
  collection: CuratedCollection;
  compact?: boolean;
  places?: CuratedCollection['places'];
}

const { collection, compact = false, places = collection.places } = Astro.props;
const mapColumns = worldPixelAtlas.columns;
const mapRows = worldPixelAtlas.rows;
const cellCounts = new Map<string, { count: number; names: string[]; column: number; row: number }>();

for (const place of places) {
  const projected = projectLonLatToWorldCell(place.longitude, place.latitude);
  const key = worldPixelKey(projected.column, projected.row);
  const existing = cellCounts.get(key);
  if (existing) {
    existing.count += 1;
    if (existing.names.length < 4) existing.names.push(place.name);
  } else {
    cellCounts.set(key, { count: 1, names: [place.name], column: projected.column, row: projected.row });
  }
}

const maxCellCount = Math.max(1, ...Array.from(cellCounts.values()).map((cell) => cell.count));
const mapCells = Array.from({ length: mapColumns * mapRows }).map((_, index) => {
  const column = (index % mapColumns) + 1;
  const row = Math.floor(index / mapColumns) + 1;
  const active = cellCounts.get(worldPixelKey(column, row));
  const density = active ? Math.max(1, Math.min(5, Math.ceil((active.count / maxCellCount) * 5))) : 0;
  return { column, row, isLand: isWorldPixelLand(column, row), active, density };
});
---

<div class:list={['curated-map', compact && 'curated-map-compact']} aria-label={`${collection.title} pixel map`}>
  <div class="curated-map-grid" style={`--atlas-columns: ${mapColumns};`} data-projection={worldPixelAtlas.projection}>
    {mapCells.map((cell) => (
      cell.active ? (
        <span
          class="curated-map-cell"
          data-land="true"
          data-active="true"
          data-density={cell.density}
          data-cell={`${cell.column}:${cell.row}`}
          title={`${cell.active.count} pin${cell.active.count === 1 ? '' : 's'}: ${cell.active.names.join(', ')}`}
        ></span>
      ) : (
        <span
          class="curated-map-cell"
          data-land={cell.isLand ? 'true' : 'false'}
          data-cell={`${cell.column}:${cell.row}`}
          aria-hidden="true"
        ></span>
      )
    ))}
  </div>
</div>

<style>
  .curated-map {
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: 18px;
    background:
      radial-gradient(circle at 25% 35%, rgb(140 47 34 / 0.08), transparent 18%),
      radial-gradient(circle at 54% 31%, rgb(198 164 107 / 0.12), transparent 18%),
      linear-gradient(145deg, #ffffff, #f2f0ed);
    padding: clamp(0.55rem, 1.7vw, 1rem);
    align-self: start;
  }

  .curated-map-compact {
    border-radius: 14px;
    padding: 0.5rem;
  }

  .curated-map-grid {
    display: grid;
    grid-template-columns: repeat(var(--atlas-columns), minmax(0, 1fr));
    gap: clamp(0.04rem, 0.16vw, 0.12rem);
  }

  .curated-map-cell {
    aspect-ratio: 1;
    border-radius: 1px;
    background: transparent;
  }

  .curated-map-cell[data-land="true"] {
    background: rgb(214 211 209 / 0.68);
    box-shadow: inset 0 0 0 1px rgb(255 255 255 / 0.38);
  }

  .curated-map-cell[data-active="true"] {
    background: rgb(140 47 34 / 1);
    box-shadow: inset 0 0 0 1px rgb(255 255 255 / 0.42);
  }

  .curated-map-cell[data-density="2"] {
    background: rgb(124 42 32 / 1);
  }

  .curated-map-cell[data-density="3"] {
    background: rgb(112 37 28 / 1);
  }

  .curated-map-cell[data-density="4"] {
    background: rgb(88 28 22 / 1);
  }

  .curated-map-cell[data-density="5"] {
    background: rgb(68 22 17 / 1);
  }
</style>
