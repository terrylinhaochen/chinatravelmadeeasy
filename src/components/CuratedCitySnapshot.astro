---
import type { CuratedCollection, CuratedCollectionRegionBucket } from '../data/curatedCollections';

type SnapshotCell = {
  column: number;
  row: number;
  active?: {
    count: number;
    names: string[];
  };
  water: boolean;
};

type CitySnapshotPreset = {
  columns: number;
  rows: number;
  bounds: {
    minLat: number;
    maxLat: number;
    minLon: number;
    maxLon: number;
  };
  label: string;
  water: Array<{ type: 'rect' | 'ellipse'; x: number; y: number; width: number; height: number }>;
  roadPaths: string[];
  waterPaths: string[];
};

interface Props {
  city: CuratedCollectionRegionBucket;
  compact?: boolean;
  places: CuratedCollection['places'];
}

const { city, compact = false, places } = Astro.props;

const presets: Partial<Record<CuratedCollectionRegionBucket, CitySnapshotPreset>> = {
  nyc: {
    columns: 30,
    rows: 18,
    bounds: { minLat: 40.68, maxLat: 40.79, minLon: -74.03, maxLon: -73.94 },
    label: 'Manhattan grid',
    water: [
      { type: 'rect', x: 0, y: 0, width: 0.2, height: 1 },
      { type: 'rect', x: 0.82, y: 0, width: 0.18, height: 1 },
      { type: 'ellipse', x: 0.66, y: 0.8, width: 0.18, height: 0.18 },
    ],
    waterPaths: ['M6 5 C5 34 7 68 4 96', 'M86 2 C81 30 86 64 80 98'],
    roadPaths: ['M38 5 C44 26 47 54 55 96', 'M24 20 H78', 'M22 38 H75', 'M25 56 H78', 'M30 75 H72'],
  },
  milan: {
    columns: 28,
    rows: 18,
    bounds: { minLat: 45.455, maxLat: 45.49, minLon: 9.165, maxLon: 9.205 },
    label: 'Centro ring',
    water: [{ type: 'ellipse', x: 0.12, y: 0.66, width: 0.32, height: 0.16 }],
    waterPaths: ['M8 76 C22 70 32 75 42 68'],
    roadPaths: [
      'M50 12 C72 12 87 28 87 50 C87 72 70 86 50 86 C28 86 13 70 13 50 C13 29 29 12 50 12',
      'M50 12 V88',
      'M14 50 H88',
      'M24 24 L76 76',
    ],
  },
  rome: {
    columns: 28,
    rows: 18,
    bounds: { minLat: 41.885, maxLat: 41.905, minLon: 12.46, maxLon: 12.505 },
    label: 'Tiber bend',
    water: [
      { type: 'ellipse', x: 0.16, y: 0.1, width: 0.2, height: 0.34 },
      { type: 'ellipse', x: 0.27, y: 0.42, width: 0.2, height: 0.42 },
      { type: 'ellipse', x: 0.19, y: 0.72, width: 0.18, height: 0.2 },
    ],
    waterPaths: ['M26 2 C18 20 37 34 27 51 C18 66 24 77 17 98'],
    roadPaths: ['M40 18 C55 25 63 38 66 52 C70 66 62 78 48 84', 'M34 50 H82', 'M50 18 V84'],
  },
  switzerland: {
    columns: 30,
    rows: 18,
    bounds: { minLat: 46.45, maxLat: 46.72, minLon: 7.52, maxLon: 7.9 },
    label: 'Alpine route',
    water: [{ type: 'ellipse', x: 0.64, y: 0.58, width: 0.22, height: 0.18 }],
    waterPaths: ['M2 66 C22 58 38 62 54 54 C70 45 86 48 98 38'],
    roadPaths: ['M0 72 C25 63 47 66 64 57 C82 48 90 44 100 35', 'M20 20 L36 42 L52 20', 'M54 28 L67 48 L82 24'],
  },
};

const fallbackPreset: CitySnapshotPreset = {
  columns: 28,
  rows: 18,
  bounds: { minLat: -60, maxLat: 85, minLon: -180, maxLon: 180 },
  label: 'Saved area',
  water: [],
  waterPaths: [],
  roadPaths: ['M10 50 H90', 'M50 10 V90'],
};

const preset = presets[city] ?? fallbackPreset;
const cellCounts = new Map<string, { count: number; names: string[] }>();

for (const place of places) {
  const column = clamp(
    Math.floor(((place.longitude - preset.bounds.minLon) / (preset.bounds.maxLon - preset.bounds.minLon)) * preset.columns) + 1,
    1,
    preset.columns
  );
  const row = clamp(
    Math.floor(((preset.bounds.maxLat - place.latitude) / (preset.bounds.maxLat - preset.bounds.minLat)) * preset.rows) + 1,
    1,
    preset.rows
  );
  const key = `${column}:${row}`;
  const existing = cellCounts.get(key);
  if (existing) {
    existing.count += 1;
    if (existing.names.length < 4) existing.names.push(place.name);
  } else {
    cellCounts.set(key, { count: 1, names: [place.name] });
  }
}

const maxCellCount = Math.max(1, ...Array.from(cellCounts.values()).map((cell) => cell.count));
const cells: SnapshotCell[] = Array.from({ length: preset.columns * preset.rows }).map((_, index) => {
  const column = (index % preset.columns) + 1;
  const row = Math.floor(index / preset.columns) + 1;
  const x = (column - 0.5) / preset.columns;
  const y = (row - 0.5) / preset.rows;
  return {
    column,
    row,
    active: cellCounts.get(`${column}:${row}`),
    water: preset.water.some((shape) => isInShape(shape, x, y)),
  };
});

function clamp(value: number, min: number, max: number) {
  return Math.max(min, Math.min(max, value));
}

function isInShape(shape: CitySnapshotPreset['water'][number], x: number, y: number) {
  if (shape.type === 'rect') {
    return x >= shape.x && x <= shape.x + shape.width && y >= shape.y && y <= shape.y + shape.height;
  }
  const cx = shape.x + shape.width / 2;
  const cy = shape.y + shape.height / 2;
  const rx = shape.width / 2;
  const ry = shape.height / 2;
  return ((x - cx) ** 2) / (rx ** 2) + ((y - cy) ** 2) / (ry ** 2) <= 1;
}
---

<div
  class:list={['city-snapshot', compact && 'city-snapshot-compact']}
  aria-label={`${preset.label} city snapshot with ${places.length} pins`}
>
  <div class="city-snapshot-grid" style={`--city-columns: ${preset.columns};`}>
    {cells.map((cell) => {
      const density = cell.active ? Math.max(1, Math.min(5, Math.ceil((cell.active.count / maxCellCount) * 5))) : 0;
      return (
        <span
          class="city-snapshot-cell"
          data-water={cell.water ? 'true' : 'false'}
          data-active={cell.active ? 'true' : 'false'}
          data-density={density}
          title={cell.active ? `${cell.active.count} pin${cell.active.count === 1 ? '' : 's'}: ${cell.active.names.join(', ')}` : undefined}
          aria-hidden={cell.active ? undefined : 'true'}
        ></span>
      );
    })}
  </div>
  <svg class="city-snapshot-lines" viewBox="0 0 100 100" aria-hidden="true">
    {preset.waterPaths.map((path) => <path class="city-snapshot-water-line" d={path}></path>)}
    {preset.roadPaths.map((path) => <path class="city-snapshot-road-line" d={path}></path>)}
  </svg>
  <div class="city-snapshot-label">
    <span>{preset.label}</span>
    <strong>{places.length} pins</strong>
  </div>
</div>

<style>
  .city-snapshot {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: 18px;
    background:
      radial-gradient(circle at 24% 28%, rgb(140 47 34 / 0.08), transparent 22%),
      linear-gradient(145deg, #fff, #f4f1ed);
    padding: clamp(0.6rem, 1.7vw, 0.95rem);
  }

  .city-snapshot-compact {
    height: 100%;
    border: 0;
    border-radius: 0;
    background: transparent;
    padding: 0;
  }

  .city-snapshot-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(var(--city-columns), minmax(0, 1fr));
    gap: clamp(0.055rem, 0.16vw, 0.13rem);
  }

  .city-snapshot-cell {
    aspect-ratio: 1;
    border-radius: 1.5px;
    background: rgb(214 211 209 / 0.72);
    box-shadow: inset 0 0 0 1px rgb(255 255 255 / 0.34);
  }

  .city-snapshot-cell[data-water='true'] {
    background: rgb(157 181 190 / 0.38);
  }

  .city-snapshot-cell[data-active='true'] {
    background: rgb(140 47 34 / 1);
    box-shadow:
      0 0 0 1px rgb(255 255 255 / 0.58),
      0 0 0 3px rgb(140 47 34 / 0.12);
  }

  .city-snapshot-cell[data-density='2'] {
    background: rgb(124 42 32 / 1);
  }

  .city-snapshot-cell[data-density='3'] {
    background: rgb(112 37 28 / 1);
  }

  .city-snapshot-cell[data-density='4'] {
    background: rgb(88 28 22 / 1);
  }

  .city-snapshot-cell[data-density='5'] {
    background: rgb(68 22 17 / 1);
  }

  .city-snapshot-lines {
    position: absolute;
    inset: 0.55rem;
    z-index: 2;
    pointer-events: none;
  }

  .city-snapshot-road-line,
  .city-snapshot-water-line {
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .city-snapshot-road-line {
    stroke: rgb(80 72 66 / 0.28);
    stroke-dasharray: 2 3;
    stroke-width: 1.2;
  }

  .city-snapshot-water-line {
    stroke: rgb(91 126 145 / 0.58);
    stroke-width: 3.4;
  }

  .city-snapshot-label {
    position: absolute;
    right: 0.7rem;
    bottom: 0.65rem;
    z-index: 3;
    display: flex;
    max-width: calc(100% - 1.4rem);
    align-items: center;
    gap: 0.5rem;
    border: 1px solid rgb(255 255 255 / 0.58);
    border-radius: 999px;
    background: rgb(255 255 255 / 0.84);
    padding: 0.42rem 0.62rem;
    color: var(--color-ink);
    font-size: 0.72rem;
    line-height: 1;
    box-shadow: 0 8px 18px rgb(12 10 9 / 0.08);
  }

  .city-snapshot-label span {
    color: var(--color-soft);
    font-weight: 750;
  }

  .city-snapshot-label strong {
    font-weight: 850;
  }
</style>
