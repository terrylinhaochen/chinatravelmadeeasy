---
import Icon from './Icon.astro';
import { communityVideos, nativeEmbedUrl } from '../data/communityVideos';
import { amapLink, videoMapImportHref } from '../utils/communityMap.js';
import { videoCuratedCollectionHref } from '../utils/videoEmbed.js';
import { selectHomepageVideos } from '../utils/destinationQuality.js';

const {
  limit = 3,
  offset = 0,
  destinationSlug,
  heading = 'What travelers actually did',
  intro = 'Watch the story, then follow the practical context and the exact places it supports.',
  showHeader = true,
} = Astro.props;
const matchingVideos = destinationSlug
  ? communityVideos.filter((video) => video.destinationSlug === destinationSlug)
  : selectHomepageVideos(communityVideos, Math.max(limit + offset, 3));
const videos = matchingVideos.slice(offset, offset + limit);
const appleMapsUrl = (place) => `https://maps.apple.com/?q=${encodeURIComponent(`${place.localName} ${place.address}`)}`;
---

{videos.length > 0 && (
  <section
    id={destinationSlug && offset === 0 ? 'field-notes' : undefined}
    class="community-stories"
    aria-labelledby={showHeader ? `community-video-heading-${destinationSlug ?? 'home'}` : undefined}
    aria-label={showHeader ? undefined : 'Traveler story'}
  >
    {showHeader && (
      <div class="grid gap-5 lg:grid-cols-[0.72fr_1.28fr] lg:items-end">
        <div>
          <p class="ds-eyebrow">Traveler stories</p>
          <h2 id={`community-video-heading-${destinationSlug ?? 'home'}`} class="mt-2 text-3xl leading-tight sm:text-4xl">{heading}</h2>
        </div>
        <p class="leading-relaxed text-soft">{intro}</p>
      </div>
    )}

    <div class:list={["grid gap-3", showHeader && "mt-6"]}>
      {videos.map((video, index) => {
        const platformName = video.platform === 'instagram' ? 'Instagram' : 'TikTok';
        const resolvedPlaces = video.places.filter((place) => place.resolution === 'resolved');
        const probablePlaces = video.places.filter((place) => place.resolution === 'probable');
        const handoffHref = videoMapImportHref(video);
        const collectionHref = videoCuratedCollectionHref(video);
        return (
          <details
            id={`field-note-${video.slug}`}
            class="group ds-card scroll-mt-24 overflow-hidden p-0"
            name={`community-video-${destinationSlug ?? 'home'}`}
            open={index === 0 && Boolean(destinationSlug)}
          >
            <summary class="grid cursor-pointer list-none gap-4 p-4 sm:grid-cols-[88px_1fr_auto] sm:items-center sm:p-5">
              <div class="relative aspect-[3/4] overflow-hidden rounded-md bg-surface-strong sm:h-28 sm:w-[84px]">
                <span class="absolute inset-x-0 bottom-2 px-2 text-center text-[9px] font-semibold uppercase tracking-[0.12em] text-faint">{platformName}</span>
                <img src={video.poster} alt="" class="absolute inset-0 h-full w-full object-cover" loading="lazy" referrerpolicy="no-referrer" onerror="this.classList.add('hidden')" />
                <span class="absolute inset-0 grid place-items-center bg-ink/10 text-xl text-white" aria-hidden="true">▶</span>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.12em] text-faint">{video.creator} · {platformName}</p>
                <h3 class="mt-2 text-2xl leading-tight group-hover:text-accent">{video.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-soft">{video.summary}</p>
              </div>
              <span class="grid h-10 w-10 shrink-0 place-items-center rounded-full border border-line text-lg font-bold text-soft group-open:border-accent group-open:text-accent" aria-hidden="true">
                <span class="group-open:hidden">+</span><span class="hidden group-open:inline">−</span>
              </span>
            </summary>

            <div class="border-t border-line p-4 sm:p-6">
              <div class="grid gap-6 lg:grid-cols-[minmax(250px,0.7fr)_1.3fr]">
                <div>
                  <div class="aspect-[9/14] max-h-[570px] overflow-hidden rounded-lg bg-ink" data-video-shell>
                    <span class="absolute inset-x-0 top-8 px-6 text-center text-xs font-semibold uppercase tracking-[0.16em] text-white/60">{platformName} preview unavailable</span>
                    <img src={video.poster} alt={`${video.title} ${platformName} preview`} class="absolute inset-0 h-full w-full object-cover" loading="lazy" referrerpolicy="no-referrer" data-video-poster onerror="this.classList.add('hidden')" />
                    <button type="button" class="absolute ds-button ds-button-primary" data-load-video data-embed-url={nativeEmbedUrl(video)} aria-label={`Play ${video.title}`}>Play {platformName}</button>
                  </div>
                  <a href={video.sourceUrl} target="_blank" rel="noopener" class="mt-3 inline-flex min-h-8 items-center gap-2 text-sm font-semibold text-accent hover:underline">
                    Open original on {platformName} <Icon name="arrow" class="h-3.5 w-3.5" />
                  </a>
                </div>

                <div>
                  <p class="ds-tag">The story, in context</p>
                  <h4 class="mt-3 text-3xl leading-tight">{video.guideTitle ?? video.title}</h4>
                  <p class="mt-4 text-base leading-7 text-soft">{video.guideBody ?? video.summary}</p>

                  {video.guideFacts?.length > 0 && (
                    <dl class="mt-6 grid gap-3 sm:grid-cols-2">
                      {video.guideFacts.map((fact) => (
                        <div class="rounded-md border border-line bg-paper p-4">
                          <dt class="ds-tag">{fact.label}</dt>
                          <dd class="mt-2 text-sm leading-relaxed text-ink">{fact.value}</dd>
                        </div>
                      ))}
                    </dl>
                  )}

                  <div class="mt-6 rounded-lg border border-line bg-paper p-5">
                    <div class="flex flex-wrap items-start justify-between gap-3">
                      <div>
                        <p class="ds-eyebrow">Keep the places from this story</p>
                        <h5 class="mt-2 text-2xl">{video.title}</h5>
                      </div>
                      <span class="ds-chip">{resolvedPlaces.length} {resolvedPlaces.length === 1 ? 'pin' : 'pins'}</span>
                    </div>
                    <p class="mt-3 text-sm leading-relaxed text-soft">
                      The source stays attached. Named venues can become places; dishes, moods, and uncertain branches remain part of the story without turning into guessed stops.
                    </p>
                    <div class="mt-5 flex flex-wrap gap-2">
                      {collectionHref ? (
                        <a href={collectionHref} class="ds-button ds-button-dark">Keep these places</a>
                      ) : (
                        <span class="ds-button ds-button-secondary cursor-not-allowed" aria-disabled="true">Waiting for a verifiable place</span>
                      )}
                      {handoffHref && <a href={handoffHref} class="ds-button ds-button-secondary">Review {resolvedPlaces.length === 1 ? 'this place' : `all ${resolvedPlaces.length} places`}</a>}
                      <a href={video.sourceUrl} target="_blank" rel="noopener" class="ds-button ds-button-secondary">Open source</a>
                    </div>
                  </div>

                  <div class="mt-5 grid gap-3">
                    {video.places.map((place) => (
                      <article class="ds-panel p-5">
                        <div class="flex flex-wrap items-start justify-between gap-3">
                          <div>
                            <p class="ds-tag">{place.resolution === 'resolved' ? 'Place identified' : 'Identity needs checking'}</p>
                            <h5 class="mt-2 text-2xl">{place.name}</h5>
                            <p class="mt-1 text-base font-medium">{place.localName}</p>
                          </div>
                          <span class="rounded-full border border-line bg-white px-3 py-1 text-xs font-semibold text-soft">{Math.round(place.confidence * 100)}% match</span>
                        </div>
                        <p class="mt-3 text-sm text-soft">{place.address}</p>
                        <blockquote class="mt-4 border-l-2 border-accent pl-4 text-sm leading-relaxed text-soft">{place.evidence}</blockquote>
                        <div class="mt-5 flex flex-wrap gap-3">
                          <a href={`/places/${place.slug}/`} class="ds-button ds-button-primary">Read about this place</a>
                          <a href={amapLink(place)} target="_blank" rel="noopener" class="ds-button ds-button-secondary">AMap</a>
                          <a href={appleMapsUrl(place)} target="_blank" rel="noopener" class="ds-button ds-button-secondary">Apple Maps</a>
                        </div>
                      </article>
                    ))}
                    {video.places.length === 0 && (
                      <div class="ds-panel p-5">
                        <p class="ds-tag">Research lead, not a pin</p>
                        <h5 class="mt-2 text-2xl">The exact branch is missing</h5>
                        <p class="mt-3 leading-relaxed text-soft">The experience can still shape the trip, but publishing a guessed venue would make the collection less trustworthy. Keep the lead until a Chinese name, storefront, neighborhood, or address is available.</p>
                        <a href={`/regions/${video.destinationSlug ?? 'hong-kong'}/#places`} class="mt-5 inline-flex min-h-8 items-center gap-2 text-sm font-semibold text-accent hover:underline">Browse grounded alternatives <Icon name="arrow" class="h-3.5 w-3.5" /></a>
                      </div>
                    )}
                  </div>

                  <div class="mt-5 border-t border-line pt-4 text-xs leading-relaxed text-faint">
                    <span class="font-semibold text-soft">Evidence checked {video.checkedAt}: </span>
                    {video.contextSources?.map((source, sourceIndex) => (
                      <><span class={sourceIndex ? '' : 'hidden'}> · </span><a href={source.url} target="_blank" rel="noopener" class="hover:text-accent hover:underline">{source.title}</a></>
                    ))}
                    {probablePlaces.length > 0 && <span> · Probable matches are shown for correction and are not treated as confirmed pins.</span>}
                  </div>
                </div>
              </div>
            </div>
          </details>
        );
      })}
    </div>
  </section>
)}

<script>
  const unloadVideo = (scope = document) => {
    scope.querySelectorAll('[data-video-shell] iframe').forEach((frame) => frame.remove());
    scope.querySelectorAll('[data-video-poster]').forEach((poster) => poster.classList.remove('hidden'));
    scope.querySelectorAll('[data-load-video]').forEach((play) => play.classList.remove('hidden'));
  };

  document.addEventListener('click', (event) => {
    const button = event.target.closest('[data-load-video]');
    if (!button) return;
    unloadVideo();
    const shell = button.closest('[data-video-shell]');
    const iframe = document.createElement('iframe');
    iframe.src = button.dataset.embedUrl;
    iframe.title = button.getAttribute('aria-label') || 'Short-form travel video';
    iframe.allow = 'autoplay; encrypted-media; picture-in-picture';
    iframe.allowFullscreen = true;
    iframe.className = 'h-full w-full border-0';
    shell.querySelector('[data-video-poster]')?.classList.add('hidden');
    button.classList.add('hidden');
    shell.appendChild(iframe);
  });

  document.querySelectorAll('.community-stories details').forEach((details) => {
    details.addEventListener('toggle', () => {
      if (!details.open) unloadVideo(details);
    });
  });

  const openHashFieldNote = () => {
    if (!window.location.hash.startsWith('#field-note-')) return;
    const fieldNote = document.querySelector(window.location.hash);
    if (!(fieldNote instanceof HTMLDetailsElement)) return;
    fieldNote.open = true;
    requestAnimationFrame(() => fieldNote.scrollIntoView({ block: 'start' }));
  };
  openHashFieldNote();
  window.addEventListener('hashchange', openHashFieldNote);
</script>

<style>
  [data-video-shell] { position: relative; display: grid; place-items: center; }
  details > summary::-webkit-details-marker { display: none; }
</style>
