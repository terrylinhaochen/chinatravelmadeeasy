---
import '../styles/global.css';
import { getGeneratedImage } from '../data/generatedImages';

interface Props {
  title: string;
  description: string;
  ogType?: string;
  image?: string;
  imageAlt?: string;
  jsonLd?: object[];
  lang?: string;
  alternates?: { hreflang: string; href: string }[];
  robots?: string;
}

const {
  title,
  description,
  ogType = 'website',
  image = getGeneratedImage('home:hero')?.src ?? '/images/curated/home-hero.jpg',
  imageAlt = 'China travel planning guide preview',
  jsonLd = [],
  lang = 'en',
  alternates = [],
  robots = 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1',
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const imageUrl = new URL(image, Astro.site);
const siteName = 'China Travel Made Easy';
const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;
const siteUrl = new URL('/', Astro.site).toString();
const localeByLang: Record<string, string> = {
  en: 'en_US',
  ko: 'ko_KR',
  ja: 'ja_JP',
};
const ogLocale = localeByLang[lang] ?? 'en_US';
const alternateLocales = Object.values(localeByLang).filter((locale) => locale !== ogLocale);
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${siteUrl}#organization`,
  name: siteName,
  url: siteUrl,
  logo: new URL('/favicon.svg', Astro.site).toString(),
  sameAs: ['https://chinatravelmadeeasy.com/'],
};
const gaMeasurementIds = (
  import.meta.env.PUBLIC_GA_MEASUREMENT_IDS ||
  import.meta.env.PUBLIC_GA_MEASUREMENT_ID ||
  'G-X2F8XWJWY6'
)
  .split(',')
  .map((id) => id.trim())
  .filter(Boolean);
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    {googleSiteVerification && <meta name="google-site-verification" content={googleSiteVerification} />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {alternates.map((alternate) => (
      <link rel="alternate" hreflang={alternate.hreflang} href={new URL(alternate.href, Astro.site)} />
    ))}
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={ogLocale} />
    {alternateLocales.map((locale) => <meta property="og:locale:alternate" content={locale} />)}
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    {jsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
    {
      gaMeasurementIds.length > 0 && (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementIds[0]}`} />
          <script
            is:inline
            set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());${gaMeasurementIds
              .map((id) => `gtag('config','${id}');`)
              .join('')}`}
          />
        </>
      )
    }
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-line bg-paper/95">
      <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-3 px-4 py-3 sm:h-20 sm:px-6 sm:py-0">
        <a href="/" class="group flex min-w-0 items-center gap-2" aria-label="China Travel Made Easy — home">
          <span
            class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-accent text-sm font-medium leading-none text-white"
            >中</span
          >
          <span class="truncate text-[1.05rem] font-medium transition-colors"
            >China Travel Made Easy</span
          >
        </a>
        <nav class="flex w-full items-center gap-4 overflow-x-auto text-sm font-semibold text-soft sm:w-auto sm:gap-6 sm:overflow-visible">
          <a href="/regions/" class="flex min-h-11 items-center hover:text-accent transition-colors">Guides</a>
          <a href="/curated/" class="flex min-h-11 items-center hover:text-accent transition-colors">Curated</a>
          <a href="/answers/" class="flex min-h-11 items-center hover:text-accent transition-colors">Answers</a>
          <a
            href="/map-import/"
            class="ds-button ds-button-primary hidden min-h-0 px-4 py-2 sm:inline-flex"
            >Save Places</a
          >
        </nav>
      </div>
    </header>

    <main class="flex-1 w-full">
      <slot />
    </main>

    <footer class="mt-16 border-t border-line bg-paper">
      <div class="mx-auto max-w-6xl space-y-3 px-4 py-10 text-sm text-faint sm:px-6">
        <p class="text-base font-bold text-soft">China Travel Made Easy</p>
        <p>Practical China travel answers, kept current.</p>
        <p>&copy; {new Date().getFullYear()} chinatravelmadeeasy.com</p>
      </div>
    </footer>
  </body>
</html>
