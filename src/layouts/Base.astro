---
import '../styles/global.css';
import { getGeneratedImage } from '../data/generatedImages';

interface Props {
  title: string;
  description: string;
  ogType?: string;
  image?: string;
  imageAlt?: string;
  jsonLd?: object[];
  lang?: string;
  alternates?: { hreflang: string; href: string }[];
  robots?: string;
}

const {
  title,
  description,
  ogType = 'website',
  image = getGeneratedImage('home:hero')?.src ?? '/images/curated/home-hero.jpg',
  imageAlt = 'China travel planning guide preview',
  jsonLd = [],
  lang = 'en',
  alternates = [],
  robots = 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1',
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const imageUrl = new URL(image, Astro.site);
const siteName = 'China Travel Made Easy';
const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;
const siteUrl = new URL('/', Astro.site).toString();
const localeByLang: Record<string, string> = {
  en: 'en_US',
  ko: 'ko_KR',
  ja: 'ja_JP',
};
const ogLocale = localeByLang[lang] ?? 'en_US';
const alternateLocales = Object.values(localeByLang).filter((locale) => locale !== ogLocale);
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${siteUrl}#organization`,
  name: siteName,
  url: siteUrl,
  logo: new URL('/favicon.svg', Astro.site).toString(),
  sameAs: ['https://chinatravelmadeeasy.com/'],
};
const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${canonical.toString()}#webpage`,
  name: fullTitle,
  description,
  url: canonical.toString(),
  isPartOf: { '@type': 'WebSite', '@id': `${siteUrl}#website`, name: siteName, url: siteUrl },
};
const gaMeasurementIds = (
  import.meta.env.PUBLIC_GA_MEASUREMENT_IDS ||
  import.meta.env.PUBLIC_GA_MEASUREMENT_ID ||
  'G-X2F8XWJWY6'
)
  .split(',')
  .map((id) => id.trim())
  .filter(Boolean);
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    {googleSiteVerification && <meta name="google-site-verification" content={googleSiteVerification} />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {alternates.map((alternate) => (
      <link rel="alternate" hreflang={alternate.hreflang} href={new URL(alternate.href, Astro.site)} />
    ))}
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={ogLocale} />
    {alternateLocales.map((locale) => <meta property="og:locale:alternate" content={locale} />)}
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
    {jsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
    {
      gaMeasurementIds.length > 0 && (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementIds[0]}`} />
          <script
            is:inline
            set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());${gaMeasurementIds
              .map((id) => `gtag('config','${id}');`)
              .join('')}`}
          />
        </>
      )
    }
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-line bg-paper/95">
      <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-3 px-4 py-3 sm:h-20 sm:px-6 sm:py-0">
        <a href="/" class="group flex min-w-0 items-center gap-2" aria-label="China Travel Made Easy — home">
          <span
            class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-accent text-sm font-medium leading-none text-white"
            >中</span
          >
          <span class="truncate text-[1.05rem] font-medium transition-colors"
            >China Travel Made Easy</span
          >
        </a>
        <nav class="flex w-full items-center gap-4 overflow-x-auto text-sm font-semibold text-soft sm:w-auto sm:gap-6 sm:overflow-visible">
          <a href="/discover/" class="flex min-h-11 items-center hover:text-accent transition-colors">Discover</a>
          <a href="/curated/" class="flex min-h-11 items-center hover:text-accent transition-colors">Curated</a>
          <a href="/answers/" class="flex min-h-11 items-center hover:text-accent transition-colors">Answers</a>
          <a
            href="/profile/"
            class="ds-button ds-button-primary min-h-0 px-4 py-2"
            data-profile-nav
            >Profile</a
          >
        </nav>
      </div>
    </header>

    <main class="flex-1 w-full">
      <slot />
    </main>

    <footer class="mt-16 border-t border-line bg-paper">
      <div class="mx-auto max-w-6xl space-y-3 px-4 py-10 text-sm text-faint sm:px-6">
        <p class="text-base font-bold text-soft">China Travel Made Easy</p>
        <p>Practical China travel answers, kept current.</p>
        <p>&copy; {new Date().getFullYear()} chinatravelmadeeasy.com</p>
      </div>
    </footer>

    <div id="ctmeSigninModal" class="ctme-modal is-hidden" role="dialog" aria-modal="true" aria-labelledby="ctmeSigninTitle">
      <div class="ctme-modal-backdrop" data-ctme-signin-close></div>
      <div class="ctme-modal-panel">
        <button type="button" class="ctme-modal-close" data-ctme-signin-close aria-label="Close sign in">×</button>
        <p class="ds-eyebrow">Sign in</p>
        <h2 id="ctmeSigninTitle" class="mt-2 text-3xl leading-tight">Save this to your profile.</h2>
        <p id="ctmeSigninCopy" class="mt-2 text-sm leading-relaxed text-soft">Enter an email to keep uploaded lists and collected maps in this browser.</p>
        <div class="mt-4 grid gap-3 sm:grid-cols-[1fr_auto]">
          <input id="ctmeSigninEmail" type="email" class="ds-input text-sm" placeholder="you@example.com" />
          <button id="ctmeSigninSubmit" type="button" class="ds-button ds-button-dark">Continue</button>
        </div>
        <p id="ctmeSigninError" class="mt-3 hidden text-sm text-error">Enter a valid email.</p>
      </div>
    </div>

    <script>
      import { CTME_STATE_EVENT, getUser, isValidEmail, setUser } from '../utils/localPrototypeState.js';
      import { isSupabaseConfigured, sendSupabaseEmailLink } from '../utils/supabaseAuth.js';

      const modal = document.querySelector('#ctmeSigninModal');
      const modalEmail = document.querySelector('#ctmeSigninEmail');
      const modalCopy = document.querySelector('#ctmeSigninCopy');
      const modalError = document.querySelector('#ctmeSigninError');
      const modalSubmit = document.querySelector('#ctmeSigninSubmit');
      const profileNav = document.querySelector('[data-profile-nav]');
      let signinResolver = null;

      renderSignedInState();

      window.addEventListener(CTME_STATE_EVENT, renderSignedInState);
      document.querySelectorAll('[data-ctme-signin-close]').forEach((button) => {
        button.addEventListener('click', () => resolveSignin(null));
      });
      modalSubmit.addEventListener('click', submitSignin);
      modalEmail.addEventListener('keydown', (event) => {
        if (event.key === 'Enter') submitSignin();
      });

      window.ctmeRequireUser = function requireUser(actionCopy = 'save this to your profile') {
        const existing = getUser();
        if (existing) return Promise.resolve(existing);
        modalCopy.textContent = isSupabaseConfigured()
          ? 'Enter an email to ' + actionCopy + '. We will send a magic link and return you to this page to finish the action.'
          : 'Enter an email to ' + actionCopy + '. This local prototype stores it in this browser.';
        modalError.classList.add('hidden');
        modal.classList.remove('is-hidden');
        modalEmail.focus();
        return new Promise((resolve) => {
          signinResolver = resolve;
        });
      };

      async function submitSignin() {
        const email = modalEmail.value.trim();
        if (!isValidEmail(email)) {
          modalError.classList.remove('hidden');
          return;
        }
        modalSubmit.disabled = true;
        modalSubmit.textContent = 'Sending...';
        if (isSupabaseConfigured()) {
          const nextPath = window.location.pathname + window.location.search;
          const result = await sendSupabaseEmailLink(email, nextPath || '/profile/');
          modalSubmit.disabled = false;
          modalSubmit.textContent = 'Continue';
          if (result.error) {
            modalError.textContent = result.error.message || 'Could not send the email link.';
            modalError.classList.remove('hidden');
            return;
          }
          modalCopy.textContent = 'Check your email. The link will return here and finish sign-in before opening your profile.';
          modalError.classList.add('hidden');
          return;
        }
        modalSubmit.disabled = false;
        modalSubmit.textContent = 'Continue';
        resolveSignin(setUser(email));
      }

      function resolveSignin(user) {
        modal.classList.add('is-hidden');
        if (signinResolver) signinResolver(user);
        signinResolver = null;
      }

      function renderSignedInState() {
        const user = getUser();
        if (!profileNav) return;
        profileNav.textContent = 'Profile';
        profileNav.setAttribute('aria-label', user ? 'Profile, signed in as ' + user.email : 'Profile');
      }
    </script>
  </body>
</html>
