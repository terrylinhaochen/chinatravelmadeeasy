---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogType?: string;
  image?: string;
  jsonLd?: object[];
  lang?: string;
  alternates?: { hreflang: string; href: string }[];
}

const {
  title,
  description,
  ogType = 'website',
  image = '/images/shanghai-skyline.jpg',
  jsonLd = [],
  lang = 'en',
  alternates = [],
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const imageUrl = new URL(image, Astro.site);
const siteName = 'China Travel Made Easy';
const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;
const gaMeasurementId = 'G-X2F8XWJWY6';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {alternates.map((alternate) => (
      <link rel="alternate" hreflang={alternate.hreflang} href={new URL(alternate.href, Astro.site)} />
    ))}
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    {jsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`} />
    <script
      is:inline
      set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${gaMeasurementId}');`}
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-line bg-paper/95">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 flex items-center justify-between h-14">
        <a href="/" class="flex items-center gap-2 group" aria-label="China Travel Made Easy — home">
          <span
            class="inline-flex items-center justify-center w-7 h-7 rounded bg-accent text-white font-display font-bold text-sm leading-none"
            >中</span
          >
          <span class="font-display font-bold text-[1.05rem] tracking-tight group-hover:text-accent transition-colors"
            >China Travel Made Easy</span
          >
        </a>
        <nav class="flex items-center gap-4 sm:gap-6 text-sm font-medium text-soft">
          <a href="/guides/" class="hover:text-accent transition-colors">Guides</a>
          <a href="/questions/" class="hover:text-accent transition-colors">Questions</a>
          <a href="/topics/" class="hover:text-accent transition-colors">Topics</a>
          <a href="/about/" class="hover:text-accent transition-colors">About</a>
          <a
            href="/map-import/"
            class="hidden sm:inline-flex items-center rounded-md bg-accent px-3 py-1.5 text-white hover:bg-accent-dark transition-colors"
            >Save Places</a
          >
        </nav>
      </div>
    </header>

    <main class="flex-1 w-full">
      <slot />
    </main>

    <footer class="border-t border-line mt-16">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 py-10 text-sm text-faint space-y-3">
        <p class="font-display font-bold text-soft text-base">China Travel Made Easy</p>
        <p>Practical China travel answers, kept current.</p>
        <p>&copy; {new Date().getFullYear()} chinatravelmadeeasy.com</p>
      </div>
    </footer>
  </body>
</html>
