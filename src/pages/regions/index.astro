---
import Base from '../../layouts/Base.astro';
import PinDensityPanel from '../../components/PinDensityPanel.astro';
import { destinations } from '../../data/destinations';
import { communityVideos } from '../../data/communityVideos';
import { auditDestination } from '../../utils/destinationQuality.js';

const videosForDestination = (slug) => communityVideos.filter((video) => video.destinationSlug === slug);
const destinationAudit = (destination) => auditDestination(destination, videosForDestination(destination.slug));
const digestDestinations = destinations.filter((destination) => destinationAudit(destination).tier === 'full');
const starterDestinations = destinations.filter((destination) => destinationAudit(destination).tier === 'starter');
const leadMedia = (destination) => videosForDestination(destination.slug)[0]?.poster ?? destination.image.src;
const leadMediaAlt = (destination) => videosForDestination(destination.slug)[0]?.title ?? destination.image.alt;
const description =
  'City-first China travel planning, with practical destination editions, map-ready places, and wider regions for longer routes.';
const faqs = [
  {
    q: 'How should I choose a China region for a first trip?',
    a: 'Start with your entry city, then match the region to the trip you want: Beijing for history, Shanghai for city life, Chengdu and Sichuan for food, Yunnan for scenery, and Hong Kong or Macau for an easier landing.',
  },
  {
    q: 'Can I save places from each region to my map?',
    a: 'Yes. Open a region to inspect starter places, then use Save Places to turn captions, notes, or OCR text into map-ready pins for AMap or Apple Maps. A bare link is not fetched by the static prototype.',
  },
  {
    q: 'Which regions are best if I care about food and local neighborhoods?',
    a: 'Start with a city edition: Chengdu, Shanghai, Hong Kong, Beijing, or Chongqing. Use Sichuan, Guangdong, Yunnan, and other wider regions only when the route genuinely spans several cities or day-trip systems.',
  },
];
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'China cities and regions',
    url: 'https://chinatravelmadeeasy.com/regions/',
    description,
    isPartOf: { '@type': 'WebSite', url: 'https://chinatravelmadeeasy.com/' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'China cities and regions',
    description,
    numberOfItems: destinations.length,
    itemListElement: destinations.map((destination, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: destination.name,
      description: destination.summary,
      url: `https://chinatravelmadeeasy.com/regions/${destination.slug}/`,
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    name: 'China destination questions',
    mainEntity: faqs.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.a,
      },
    })),
  },
];
---

<Base title="China cities and regions" description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16">
    <div class="grid gap-6 lg:grid-cols-[0.82fr_1.18fr] lg:items-end">
      <div>
        <p class="ds-eyebrow">Where to go</p>
        <h1 class="mt-2 text-4xl leading-tight sm:text-5xl">Cities first. Regions when the route is ready.</h1>
      </div>
      <p class="text-lg leading-relaxed text-soft">
        Start with a city edition you can actually use. Move to a wider province or region only when its transfers, day trips, and multiple cities belong in the plan.
      </p>
    </div>

    <section class="mt-10 border-t border-line pt-10" aria-labelledby="city-editions-heading">
      <p class="ds-eyebrow">Destination digests</p>
      <h2 id="city-editions-heading" class="mt-2 text-3xl leading-tight">Stories, judgment, and places that hold up on the map</h2>
      <p class="mt-3 max-w-3xl leading-relaxed text-soft">Every published digest passes the same standard: a point of view, usable trip rhythm, execution and recovery advice, bilingual place identity, and dated sources. Grounded traveler stories replace stock imagery where they exist.</p>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {digestDestinations.map((destination) => (
          <a href={`/regions/${destination.slug}/`} class="ds-card-link group overflow-hidden">
            <div class="relative aspect-[4/3] overflow-hidden bg-surface-strong">
              <img src={leadMedia(destination)} alt={leadMediaAlt(destination)} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" referrerpolicy="no-referrer" />
              {videosForDestination(destination.slug).length > 0 && <span class="absolute bottom-3 left-3 rounded-full bg-ink/85 px-3 py-1 text-xs font-semibold text-white">▶ Traveler story</span>}
            </div>
            <div class="p-5">
              <p class="ds-tag">{destination.type} · Full digest</p>
              <h3 class="mt-2 text-2xl leading-tight group-hover:text-accent">{destination.name}</h3>
              <p class="mt-2 text-sm leading-relaxed text-soft">{destination.summary}</p>
              {destination.places.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-1.5">
                  {destination.places.slice(0, 2).map((place) => (
                    <span class="inline-flex min-h-8 items-center rounded-full border border-line bg-white px-2 py-1 text-[0.68rem] font-semibold text-soft">
                      {place.name}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    </section>

    <PinDensityPanel
      eyebrow="Explored map"
      title="See where saved-place signal extends"
      description="Darker pixels show where traveler lists and starter pins cluster. Use the map to extend a city trip into a wider route."
      class="mt-12 bg-card"
    />

    <section class="mt-12 border-t border-line pt-10" aria-labelledby="regions-heading">
      <p class="ds-eyebrow">Places in reporting</p>
      <h2 id="regions-heading" class="mt-2 text-3xl leading-tight">Starter pages, not finished destination guides</h2>
      <p class="mt-3 max-w-3xl leading-relaxed text-soft">These places are useful for orientation, but they do not yet meet the digest standard. Their pages remain out of search indexing until local names, routes, recovery advice, and current sources are reviewed.</p>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {starterDestinations.map((destination) => (
          <a href={`/regions/${destination.slug}/`} class="ds-card-link group overflow-hidden">
            <div class="aspect-[4/3] overflow-hidden bg-surface-strong">
              <img src={destination.image.src} alt={destination.image.alt} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
            </div>
            <div class="p-5">
              <p class="ds-tag">{destination.type} · Starter brief</p>
              <h3 class="mt-2 text-2xl leading-tight group-hover:text-accent">{destination.name}</h3>
              <p class="mt-2 text-sm leading-relaxed text-soft">{destination.summary}</p>
              {destination.places.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-1.5">
                  {destination.places.slice(0, 2).map((place) => (
                    <span class="inline-flex min-h-8 items-center rounded-full border border-line bg-white px-2 py-1 text-[0.68rem] font-semibold text-soft">
                      {place.name}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="mt-12 border-t border-line pt-8">
      <p class="ds-eyebrow">Region planning</p>
      <h2 class="mt-2 text-3xl leading-tight">How should I choose where to go in China?</h2>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {faqs.map((item) => (
          <article class="ds-card p-5">
            <h3 class="text-xl leading-tight">{item.q}</h3>
            <p class="mt-3 text-sm leading-relaxed text-soft">{item.a}</p>
          </article>
        ))}
      </div>
    </section>
  </section>
</Base>
