---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';
import { destinations } from '../../data/destinations';

const description =
  'All China destination regions for trip planning, with each region linked to practical China Travel Made Easy guides.';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'China destination regions',
    url: 'https://chinatravelmadeeasy.com/regions/',
    description,
    isPartOf: { '@type': 'WebSite', url: 'https://chinatravelmadeeasy.com/' },
  },
];
---

<Base title="China destination regions" description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16">
    <div class="grid gap-6 lg:grid-cols-[0.82fr_1.18fr] lg:items-end">
      <div>
        <p class="text-[12px] font-semibold uppercase tracking-[0.16em] text-accent">Where to go</p>
        <h1 class="mt-2 font-display text-4xl font-bold leading-tight sm:text-5xl">China destination regions</h1>
      </div>
      <p class="text-lg leading-relaxed text-soft">
        One planning map for municipalities, provinces, autonomous regions, Hong Kong, Macau, and Taiwan as a traveler search region. Each destination links to the guides that matter most for that route.
      </p>
    </div>

    <div class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {destinations.map((destination) => (
        <a href={`/regions/${destination.slug}/`} class="group grid grid-cols-[6.5rem_1fr] overflow-hidden rounded-lg border border-line bg-card transition-colors hover:border-accent/50">
          <div class="h-full min-h-28 overflow-hidden bg-line">
            <img src={destination.image.src} alt={destination.image.alt} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
          </div>
          <div class="p-4">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-[11px] font-semibold uppercase tracking-wider text-faint">{destination.type}</p>
                <h2 class="mt-1 font-display text-xl font-bold group-hover:text-accent">{destination.name}</h2>
              </div>
              <Icon name="arrow" class="mt-1 h-4 w-4 shrink-0 text-faint group-hover:text-accent" />
            </div>
            <p class="mt-3 text-sm leading-relaxed text-soft">{destination.summary}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</Base>
