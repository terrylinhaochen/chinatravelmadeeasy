---
import Base from '../../layouts/Base.astro';
import LocalizedQuestionsPage from '../../components/LocalizedQuestionsPage.astro';
import { questionAlternates, questionLocales } from '../../data/localizedQuestions';

const page = questionLocales.ko;
const answerItems = page.groups.flatMap((group) => group.questions);
const faqEntities = page.groups.flatMap((group) =>
  group.questions.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
      url: new URL(item.href, Astro.site).toString(),
    },
  }))
);
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: page.title,
    description: page.description,
    inLanguage: page.lang,
    about: ['중국 여행 준비', '중국 비자', '중국 결제', '중국 교통'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    name: page.title,
    description: page.description,
    inLanguage: page.lang,
    mainEntity: faqEntities,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: page.title,
    description: page.description,
    inLanguage: page.lang,
    numberOfItems: answerItems.length,
    itemListElement: answerItems.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.q,
      description: item.answer,
      url: new URL(item.href, Astro.site).toString(),
    })),
  },
];
---

<Base title={page.title} description={page.description} lang={page.lang} alternates={questionAlternates} jsonLd={jsonLd}>
  <LocalizedQuestionsPage page={page} />
</Base>
