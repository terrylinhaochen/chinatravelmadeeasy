---
import Base from '../../../layouts/Base.astro';
import CuratedCollectionMap from '../../../components/CuratedCollectionMap.astro';
import {
  curatedCollections,
  curatedRegionMeta,
  type CuratedCollectionRegionBucket,
} from '../../../data/curatedCollections';

export function getStaticPaths() {
  return curatedCollections.map((item) => ({
    params: {
      owner: item.owner.slug,
      collection: item.pathSlug ?? item.title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, ''),
    },
    props: { item },
  }));
}

const { item } = Astro.props;
const displayTitle = item.title.replace(/\b\w/g, (letter) => letter.toUpperCase());
const collectionSlug = item.pathSlug ?? item.title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
const noteCount = item.places.filter((place) => place.note).length;
const isLocalResearch = item.kind === 'local-research';
const resolvedCount = item.places.filter((place) => place.resolutionState === 'resolved' || !place.resolutionState).length;
const researchSourceCount = new Set(item.places.flatMap((place) => place.sources?.map((source) => source.url) ?? [])).size;
const cityEditions = Object.entries(item.regionBuckets)
  .map(([region, count]) => {
    const city = region as CuratedCollectionRegionBucket;
    const places = item.places.filter((place) => place.regionBucket === city);
    return {
      city,
      count,
      places,
      meta: curatedRegionMeta[city],
      noteCount: places.filter((place) => place.note).length,
      href: `/curated/${item.owner.slug}/${collectionSlug}/${city}/`,
    };
  })
  .sort((a, b) => (b.count ?? 0) - (a.count ?? 0));

const description = isLocalResearch
  ? `${displayTitle}: a reviewed collection of Shanghai places with local-use evidence and explicit map-resolution states.`
  : `${item.owner.name}'s uploaded ${displayTitle} collection, split into ${cityEditions.length} city-level map lists.`;
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `${displayTitle} by ${item.owner.name}`,
    description,
    url: `https://chinatravelmadeeasy.com/curated/${item.owner.slug}/${collectionSlug}/`,
    isPartOf: { '@type': 'WebSite', url: 'https://chinatravelmadeeasy.com/' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: `${displayTitle} city editions`,
    numberOfItems: cityEditions.length,
    itemListElement: cityEditions.map((edition, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: `${edition.meta.edition} by ${item.owner.name}`,
      url: `https://chinatravelmadeeasy.com${edition.href}`,
      numberOfItems: edition.count,
    })),
  },
];
---

<Base title={`${displayTitle} by ${item.owner.name}`} description={description} jsonLd={jsonLd}>
  <section class="ds-section curated-overview">
    <nav class="flex flex-wrap items-center gap-2 text-sm text-faint" aria-label="Breadcrumb">
      <a href="/curated/" class="hover:text-accent">Curated</a>
      <span>/</span>
      <span>{item.owner.name}</span>
    </nav>

    <div class="curated-overview-hero mt-6 grid gap-6 lg:grid-cols-[0.82fr_1.18fr] lg:items-stretch">
      <div class="curated-overview-summary ds-card flex h-full flex-col p-5 sm:p-7">
        <p class="ds-eyebrow">{isLocalResearch ? 'Local Lens collection' : 'Uploaded collection'}</p>
        <h1 class="mt-3 text-5xl leading-tight sm:text-6xl">{displayTitle}</h1>
        <div class="mt-5 flex items-center gap-3">
          <span class="curated-owner-mark" aria-hidden="true">{item.owner.name.slice(0, 1)}</span>
          <div>
            <p class="font-semibold">{item.owner.name}</p>
            <p class="text-sm leading-relaxed text-soft">{isLocalResearch ? `Chinese-local evidence reviewed ${item.checkedAt}` : 'One source, automatically separated into city lists.'}</p>
          </div>
        </div>

        <div class="mt-6 grid grid-cols-3 gap-2">
          <div class="curated-stat"><p class="ds-tag">{isLocalResearch ? 'Ideas' : 'Pins'}</p><p class="mt-2 text-3xl leading-none">{item.placeCount}</p></div>
          <div class="curated-stat"><p class="ds-tag">{isLocalResearch ? 'Safe pins' : 'Cities'}</p><p class="mt-2 text-3xl leading-none">{isLocalResearch ? resolvedCount : cityEditions.length}</p></div>
          <div class="curated-stat"><p class="ds-tag">{isLocalResearch ? 'Sources' : 'Notes'}</p><p class="mt-2 text-3xl leading-none">{isLocalResearch ? researchSourceCount : noteCount}</p></div>
        </div>

        <p class="mt-6 text-sm leading-relaxed text-soft">
          {isLocalResearch ? item.description : 'This page preserves the upload provenance. Collecting and remixing happen inside one city edition at a time, so a New York list never silently carries Milan, Rome, or Switzerland pins with it.'}
        </p>

        <div class="mt-auto flex flex-wrap gap-2 pt-6">
          <a href={cityEditions[0]?.href ?? '/curated/'} class="ds-button ds-button-dark">{isLocalResearch ? 'Open reviewed Shanghai slice' : 'Open first city'}</a>
          <a href={item.canonicalUrl || item.sourceUrl} class="ds-button ds-button-secondary" target="_blank" rel="noopener">{isLocalResearch ? 'Open lead evidence' : 'Open source'}</a>
        </div>
      </div>

      <div class="curated-overview-map h-full">
        <CuratedCollectionMap collection={item} />
      </div>
    </div>

    <section class="mt-10" aria-labelledby="city-editions-heading">
      <p class="ds-eyebrow">{isLocalResearch ? 'Reviewed edition' : 'City editions'}</p>
      <div class="mt-2 grid gap-4 lg:grid-cols-[0.72fr_1.28fr] lg:items-end">
        <h2 id="city-editions-heading" class="text-3xl leading-tight">{isLocalResearch ? 'Keep the evidence attached to every place' : 'Choose the city you actually need'}</h2>
        <p class="leading-relaxed text-soft">{isLocalResearch ? 'The Shanghai edition labels direct resident testimony, local-use proxies, and provider confidence separately.' : 'Each edition has its own map, search, saved state, and Collect action.'}</p>
      </div>

      <div class="mt-6 grid gap-4 md:grid-cols-2">
        {cityEditions.map((edition) => (
          <a href={edition.href} class="curated-city-edition ds-card-link grid gap-4 overflow-hidden p-4 sm:grid-cols-[0.72fr_1.28fr]">
            <div class="overflow-hidden rounded-md bg-surface-strong">
              <img src={edition.meta.cover.src} alt={edition.meta.cover.alt} class="h-full min-h-48 w-full object-cover" loading="lazy" />
            </div>
            <div class="flex min-w-0 flex-col p-1">
              <p class="ds-tag">{edition.meta.annotation}</p>
              <h3 class="mt-3 text-3xl leading-tight">{edition.meta.edition}</h3>
              <p class="mt-3 text-sm leading-relaxed text-soft">{isLocalResearch ? item.description : edition.meta.focus}</p>
              <div class="mt-auto flex flex-wrap gap-2 pt-5 text-xs font-semibold uppercase tracking-[0.12em] text-faint">
                <span>{edition.count} {isLocalResearch ? 'ideas' : 'pins'}</span><span>{isLocalResearch ? `${resolvedCount} safe ${resolvedCount === 1 ? 'pin' : 'pins'}` : `${edition.noteCount} notes`}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  </section>
</Base>

<style>
  .curated-owner-mark {
    display: inline-flex;
    width: 3rem;
    height: 3rem;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: var(--color-accent);
    color: white;
    font-size: 1.15rem;
    font-weight: 700;
  }

  .curated-stat {
    border: 1px solid var(--color-line);
    border-radius: 10px;
    background: var(--color-paper);
    padding: 0.85rem;
  }

  .curated-overview-map :global(.curated-map) {
    height: 100%;
    min-height: 100%;
    align-self: stretch;
  }

  .curated-overview-map :global(.curated-map-grid) {
    align-content: center;
    min-height: 100%;
  }

  @media (min-width: 1024px) {
    .curated-overview-hero {
      min-height: 36rem;
    }
  }
</style>
