---
import Base from '../../layouts/Base.astro';
import CuratedCollectionMap from '../../components/CuratedCollectionMap.astro';
import {
  curatedCollections,
  curatedRegionMeta,
  type CuratedCollectionRegionBucket,
} from '../../data/curatedCollections';

const description =
  'Local China guides built from Chinese-language research and grounded traveler stories, with source evidence and bilingual place identities attached.';

function collectionHref(collection: (typeof curatedCollections)[number], city?: CuratedCollectionRegionBucket) {
  const owner = collection.owner.slug;
  const list = collection.pathSlug ?? collection.title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  return city ? `/curated/${owner}/${list}/${city}/` : `/curated/${owner}/${list}/`;
}

const cityEditions = curatedCollections
  .flatMap((collection) =>
    Object.entries(collection.regionBuckets).map(([region, count]) => {
      const city = region as CuratedCollectionRegionBucket;
      const places = collection.places.filter((place) => place.regionBucket === city);
      return {
        id: `${collection.slug}:${city}`,
        collection,
        city,
        count,
        places,
        meta: curatedRegionMeta[city],
        guide: curatedRegionMeta[city].guide,
        scope: curatedRegionMeta[city].scope,
        noteCount: places.filter((place) => place.note).length,
        resolvedCount: places.filter((place) => place.resolutionState === 'resolved' || !place.resolutionState).length,
        directResidentCount: places.filter((place) => place.evidenceGrade === 'resident-direct').length,
        href: collectionHref(collection, city),
      };
    })
  )
  .sort((a, b) => {
    if (a.scope !== b.scope) return a.scope === 'China' ? -1 : 1;
    if (a.collection.kind !== b.collection.kind) {
      if (a.collection.kind === 'local-research') return -1;
      if (b.collection.kind === 'local-research') return 1;
    }
    const cityPriority: Partial<Record<CuratedCollectionRegionBucket, number>> = { 'hong-kong': 0, shanghai: 1, beijing: 2, chongqing: 3 };
    const priorityDifference = (cityPriority[a.city] ?? 99) - (cityPriority[b.city] ?? 99);
    if (priorityDifference) return priorityDifference;
    return (b.count ?? 0) - (a.count ?? 0);
  });
const guideFilters = ['All', ...Array.from(new Set(cityEditions.map((edition) => edition.guide)))];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Local China guides',
    url: 'https://chinatravelmadeeasy.com/curated/',
    description,
    isPartOf: { '@type': 'WebSite', url: 'https://chinatravelmadeeasy.com/' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Local China city guides and field notes',
    numberOfItems: cityEditions.length,
    itemListElement: cityEditions.map((edition, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: `${edition.meta.edition} by ${edition.collection.owner.name}`,
      description: edition.collection.kind === 'local-research'
        ? `${edition.count} locally sourced candidates with explicit evidence and map-resolution states`
        : `${edition.count} imported pins ready to collect and remix`,
      url: `https://chinatravelmadeeasy.com${edition.href}`,
    })),
  },
];
---

<Base title="Local China guides" description={description} jsonLd={jsonLd}>
  <section class="ds-section">
    <p class="ds-eyebrow">Local guides</p>
    <div class="ds-section-head mt-3">
      <div>
        <h1 class="ds-section-title">Go deeper into China.</h1>
      </div>
      <p class="text-lg leading-relaxed text-soft">
        Start with places surfaced through Chinese-language research and grounded traveler stories. Every guide keeps the local evidence, English context, and bilingual map identity together.
      </p>
    </div>

    <div class="mt-8 flex flex-wrap items-center gap-2" aria-label="Guide selector">
      {guideFilters.map((guide, index) => (
        <button
          type="button"
          class:list={['ds-chip curated-guide-filter', index === 0 && '!border-accent']}
          data-curated-guide-filter={guide}
        >
          {guide}
        </button>
      ))}
    </div>

    <div class="mt-5 grid gap-5">
      {cityEditions.map((edition, index) => (
        <>
        {index === 0 && (
          <div class="border-b border-line pb-3" data-curated-section-heading="China">
            <p class="ds-eyebrow">China, researched locally</p>
            <h2 class="mt-2 text-3xl leading-tight">Why locals use it, translated into a trip you can take</h2>
          </div>
        )}
        <article
          class="curated-card ds-card grid gap-5 p-4 sm:p-5 xl:grid-cols-[0.72fr_1.28fr] xl:items-stretch"
          data-curated-card={edition.id}
          data-curated-guide={edition.guide}
          data-curated-scope={edition.scope}
        >
          <a class="curated-cover" href={edition.href} aria-label={`Open ${edition.meta.edition} by ${edition.collection.owner.name}`}>
            <img class="curated-cover-image" src={edition.meta.cover.src} alt={edition.meta.cover.alt} loading="lazy" />
            <div class="curated-cover-map" aria-hidden="true">
              <CuratedCollectionMap collection={edition.collection} places={edition.places} compact />
            </div>
            <div class="curated-cover-copy">
              <span class="curated-owner-mark" aria-hidden="true">{edition.collection.owner.name.slice(0, 1)}</span>
              <div>
                <p class="ds-tag">{edition.meta.annotation}</p>
                <h2 class="mt-2 text-4xl leading-none">{edition.meta.label}</h2>
                <p class="mt-2 text-sm text-soft">{edition.collection.title} · {edition.collection.owner.name}</p>
              </div>
            </div>
          </a>

          <div class="min-w-0">
            <p class="ds-eyebrow">{edition.collection.owner.name}</p>
            <div class="mt-2 flex flex-wrap items-start justify-between gap-3">
              <h3 class="text-3xl leading-tight">{edition.meta.edition}</h3>
              <span class="ds-tag">{edition.guide}</span>
            </div>
            <p class="mt-3 text-sm leading-relaxed text-soft">{edition.collection.kind === 'local-research' ? edition.collection.description : edition.meta.focus}</p>

            <div class="mt-5 grid grid-cols-3 gap-2">
              <div class="curated-stat">
                <p class="ds-tag">{edition.collection.kind === 'local-research' ? 'Ideas' : 'Pins'}</p>
                <p class="mt-2 text-2xl leading-none">{edition.count}</p>
              </div>
              <div class="curated-stat">
                <p class="ds-tag">{edition.collection.kind === 'local-research' ? 'Resident-direct' : 'City'}</p>
                <p class="mt-2 text-lg leading-none">{edition.collection.kind === 'local-research' ? edition.directResidentCount : edition.meta.label}</p>
              </div>
              <div class="curated-stat">
                <p class="ds-tag">{edition.collection.kind === 'local-research' ? 'Safe pins' : 'Notes'}</p>
                <p class="mt-2 text-2xl leading-none">{edition.collection.kind === 'local-research' ? edition.resolvedCount : edition.noteCount}</p>
              </div>
            </div>

            <div class="mt-5 rounded-md border border-line bg-paper p-3">
              <div class="flex flex-wrap items-center justify-between gap-2">
                <p class="ds-tag">{edition.collection.kind === 'local-research' ? 'Evidence rule' : 'Why collect'}</p>
                <p class="text-xs font-semibold uppercase tracking-[0.12em] text-faint">{edition.collection.kind === 'local-research' ? `Checked ${edition.collection.checkedAt}` : edition.scope === 'China' ? `${edition.collection.provider} evidence` : 'Imported source'}</p>
              </div>
              <a class="curated-preview-copy mt-3" href={edition.href}>
                {edition.collection.kind === 'local-research' ? 'Direct resident testimony, local-use proxies, and official claims are labeled separately. Only provider-resolved places become safe pins.' : edition.meta.hook}
              </a>
            </div>

            <div class="mt-5 flex flex-wrap gap-2">
              <button
                type="button"
                class="ds-button ds-button-dark"
                data-curated-collect={edition.id}
                data-curated-title={`${edition.meta.edition}: ${edition.collection.title}`}
                data-curated-owner={edition.collection.owner.name}
                data-curated-href={edition.href}
                data-curated-count={edition.collection.kind === 'local-research' ? edition.resolvedCount : edition.count}
                data-curated-candidate-count={edition.collection.kind === 'local-research' ? edition.count : undefined}
              >
                {edition.collection.kind === 'local-research' ? 'Collect research' : 'Collect'}
              </button>
              <a href={edition.href} class="ds-button ds-button-secondary">Open city</a>
            </div>
            <p class="mt-3 hidden text-sm leading-relaxed text-soft" data-curated-collect-status={edition.id}></p>
          </div>
        </article>
        </>
      ))}
    </div>
  </section>
</Base>

<script>
  import { collectCuratedCollection, getCollectedCollections, getUser } from '../../utils/localPrototypeState.js';

  const collectButtons = document.querySelectorAll('[data-curated-collect]');
  const guideButtons = document.querySelectorAll('[data-curated-guide-filter]');
  const curatedCards = document.querySelectorAll('[data-curated-card]');
  const sectionHeadings = document.querySelectorAll('[data-curated-section-heading]');
  const pendingCollectKey = 'ctme-pending-curated-collect';

  collectButtons.forEach((button) => {
    const existing = getCollectedCollections().find((entry) => entry.id === button.dataset.curatedCollect);
    if (existing) markCollected(button);

    button.addEventListener('click', async () => {
      const item = payloadForButton(button);
      localStorage.setItem(pendingCollectKey, JSON.stringify(item));
      const user = window.ctmeRequireUser
        ? await window.ctmeRequireUser('collect this city map to your profile')
        : null;
      if (!user) return;
      completeCollect(item, button);
    });
  });

  resumePendingCollect();

  guideButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const guide = button.dataset.curatedGuideFilter;
      guideButtons.forEach((item) => item.classList.toggle('!border-accent', item === button));
      curatedCards.forEach((card) => {
        card.hidden = guide !== 'All' && card.dataset.curatedGuide !== guide;
      });
      sectionHeadings.forEach((heading) => {
        heading.hidden = !Array.from(curatedCards).some((card) => !card.hidden && card.dataset.curatedScope === heading.dataset.curatedSectionHeading);
      });
    });
  });

  function markCollected(button) {
    button.textContent = 'Collected';
    button.classList.remove('ds-button-dark');
    button.classList.add('ds-button-secondary');
  }

  function payloadForButton(button) {
    return {
      id: button.dataset.curatedCollect,
      title: button.dataset.curatedTitle,
      owner: button.dataset.curatedOwner,
      href: button.dataset.curatedHref,
      placeCount: Number(button.dataset.curatedCount || 0),
      candidateCount: Number(button.dataset.curatedCandidateCount || 0) || undefined,
      source: 'Curated',
      savedAt: new Date().toISOString(),
    };
  }

  function completeCollect(item, button) {
    collectCuratedCollection(item);
    localStorage.removeItem(pendingCollectKey);
    markCollected(button);
    const status = document.querySelector(`[data-curated-collect-status="${item.id}"]`);
    if (status) {
      status.innerHTML = 'Saved to Profile. <a class="font-semibold text-ink hover:text-accent" href="/profile/">Open Profile</a>';
      status.classList.remove('hidden');
    }
  }

  function resumePendingCollect() {
    if (!getUser()) return;
    let pending;
    try { pending = JSON.parse(localStorage.getItem(pendingCollectKey) || 'null'); } catch { pending = null; }
    if (!pending?.id) return;
    const button = Array.from(collectButtons).find((item) => item.dataset.curatedCollect === pending.id);
    if (button) completeCollect(pending, button);
  }
</script>

<style>
  .curated-card {
    overflow: hidden;
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  .curated-card:hover {
    border-color: #d6d3d1;
    box-shadow:
      rgba(0, 0, 0, 0.02) 0 0 0 1px,
      rgba(0, 0, 0, 0.04) 0 2px 6px,
      rgba(0, 0, 0, 0.1) 0 4px 8px;
  }

  .curated-cover {
    position: relative;
    display: grid;
    min-height: 22rem;
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: 14px;
    background:
      linear-gradient(160deg, rgb(250 250 249 / 0.92), rgb(245 245 244 / 0.8)),
      var(--color-paper);
    color: inherit;
  }

  .curated-cover-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.92) contrast(0.96);
  }

  .curated-cover::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.16), transparent 32%),
      linear-gradient(0deg, rgb(255 255 255 / 0.94), rgb(255 255 255 / 0.62) 46%, transparent 72%);
    pointer-events: none;
  }

  .curated-cover-map {
    position: absolute;
    inset: 0.9rem 0.9rem 6rem;
    opacity: 0.62;
    mix-blend-mode: multiply;
  }

  .curated-cover-map :global(.curated-map) {
    height: 100%;
    border: 0;
    background: transparent;
    padding: 0;
  }

  .curated-cover-copy {
    position: relative;
    z-index: 1;
    display: flex;
    min-height: 100%;
    align-items: end;
    gap: 1rem;
    padding: 1rem;
  }

  .curated-owner-mark {
    display: inline-flex;
    width: 3rem;
    height: 3rem;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-line);
    border-radius: 10px;
    background: var(--color-accent);
    color: white;
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1;
  }

  .curated-stat {
    border: 1px solid var(--color-line);
    border-radius: 10px;
    background: white;
    padding: 0.85rem;
  }

  .curated-preview-copy {
    display: block;
    color: var(--color-ink);
    font-size: 1rem;
    font-weight: 650;
    line-height: 1.45;
  }

  .curated-summary {
    background: rgb(255 255 255 / 0.72);
  }

  @media (max-width: 640px) {
    .curated-cover {
      min-height: 18rem;
    }

    .curated-stat {
      padding: 0.75rem;
    }
  }
</style>
