---
import Base from '../../layouts/Base.astro';
---
<Base title="Traveler videos now live inside Discover" description="Traveler videos are integrated into destination guides and resolved place pages." robots="noindex, follow">
  <meta http-equiv="refresh" content="0;url=/discover/" slot="head" />
  <section class="mx-auto max-w-3xl px-4 py-20 text-center sm:px-6">
    <p class="ds-eyebrow">Moved into destinations</p>
    <h1 class="mt-3 text-4xl">Traveler videos now live inside Discover.</h1>
    <p class="mt-4 leading-relaxed text-soft">Video is evidence for a place and a trip—not a separate feed. Continue to destination guides, where each clip opens into context and map-ready locations.</p>
    <a href="/discover/" class="ds-button ds-button-primary mt-7">Open Discover</a>
  </section>
  <script>window.location.replace('/discover/');</script>
</Base>
