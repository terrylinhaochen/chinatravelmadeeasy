---
import Base from '../../../layouts/Base.astro';
import {
  localLensSeoulStudyVersion,
  seoulBaselineCandidates,
  seoulLocalLanguageCandidates,
} from '../../../data/localLensSeoul.js';

const description = 'A blinded research exercise testing whether Seoul recommendations from Korean-language local sources change an English-speaking traveler’s itinerary.';
const studyData = JSON.stringify({
  baselineCandidates: seoulBaselineCandidates,
  localLanguageCandidates: seoulLocalLanguageCandidates,
  studyVersion: localLensSeoulStudyVersion,
});
---

<Base
  title="Would Korean-language recommendations change your Seoul trip?"
  description={description}
  robots="noindex, nofollow"
>
  <section class="border-b border-line bg-[linear-gradient(135deg,#edf3f1_0%,#fff_58%,#f5efe4_100%)]">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16">
      <a href="/discover/" class="text-sm font-semibold text-soft hover:text-accent">← Back to Discover</a>
      <div class="mt-8 grid gap-8 lg:grid-cols-[1.35fr_.65fr] lg:items-end">
        <div>
          <p class="ds-eyebrow">Seoul Local Lens replication</p>
          <h1 class="mt-3 max-w-4xl text-4xl leading-[1.04] sm:text-6xl">Would the Korean-language web change your Seoul draft?</h1>
        </div>
        <div class="border-l-2 border-accent pl-5 text-sm leading-relaxed text-soft">
          <p>Choose from two recommendation sets before seeing their language or source ecosystem.</p>
          <p class="mt-3 font-semibold text-ink">This is a smaller generalization test, not evidence that Korean sources are inherently better.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-14" data-local-lens-study>
    <ol class="study-progress" aria-label="Study progress">
      <li aria-current="step" data-progress-step="intro"><span>1</span> Your trip</li>
      <li data-progress-step="baseline"><span>2</span> First set</li>
      <li data-progress-step="local"><span>3</span> Second set</li>
      <li data-progress-step="reveal"><span>4</span> Reveal</li>
    </ol>

    <section class="study-step mt-10" data-study-step="intro">
      <div class="grid gap-8 lg:grid-cols-[.72fr_1.28fr]">
        <div>
          <p class="ds-eyebrow">Before the recommendations</p>
          <h2 class="mt-2 text-3xl leading-tight" tabindex="-1">What kind of Seoul trip are you building?</h2>
          <p class="mt-4 leading-relaxed text-soft">Trip context helps separate a useful recommendation from novelty that is too far away, too strenuous, or irrelevant.</p>
          <div class="mt-6 rounded-2xl border border-line bg-surface p-5 text-sm leading-relaxed text-soft">
            <p class="font-semibold text-ink">About four minutes</p>
            <p class="mt-2">No account is required. Results stay on this device unless you download, copy, or prepare an email.</p>
          </div>
        </div>

        <form class="ds-panel p-5 sm:p-7" data-context-form>
          <div class="grid gap-5 sm:grid-cols-2">
            <label class="block text-sm font-semibold">
              Where would you stay?
              <input name="base" class="ds-input mt-2" placeholder="For example, Jongno or Hongdae" />
            </label>
            <label class="block text-sm font-semibold">
              How many full days?
              <select name="days" class="ds-input mt-2">
                <option value="2">2 days</option>
                <option value="3" selected>3 days</option>
                <option value="4">4 days</option>
                <option value="5+">5 or more days</option>
              </select>
            </label>
          </div>

          <fieldset class="mt-6">
            <legend class="text-sm font-semibold">What matters on this trip?</legend>
            <div class="mt-3 flex flex-wrap gap-2">
              {['Food', 'Neighborhood life', 'Architecture', 'Art', 'History', 'Nature', 'Nightlife', 'Low walking'].map((interest) => (
                <label class="study-check">
                  <input type="checkbox" name="interests" value={interest.toLowerCase()} />
                  <span>{interest}</span>
                </label>
              ))}
            </div>
          </fieldset>

          <label class="mt-6 block text-sm font-semibold">
            Stops already in your plan
            <textarea name="existingStops" class="ds-input mt-2 min-h-28" placeholder="One per line — Gyeongbokgung, a market, a Han River evening…"></textarea>
          </label>

          <label class="mt-6 block text-sm font-semibold">
            Constraints that could rule a place out
            <input name="constraints" class="ds-input mt-2" placeholder="Hills, long transfers, children, weather, budget…" />
          </label>

          <button type="submit" class="ds-button ds-button-dark mt-7">Start with the first set</button>
        </form>
      </div>
    </section>

    <section class="study-step mt-10 hidden" data-study-step="baseline" aria-labelledby="seoul-baseline-heading">
      <div class="grid gap-5 lg:grid-cols-[1fr_auto] lg:items-end">
        <div>
          <p class="ds-eyebrow">Recommendation set one</p>
          <h2 id="seoul-baseline-heading" class="mt-2 max-w-3xl text-3xl leading-tight" tabindex="-1">Which ideas would make your first draft?</h2>
          <p class="mt-3 max-w-3xl leading-relaxed text-soft">Keep up to five. Judge the trip value; source labels stay hidden until the end.</p>
        </div>
        <p class="rounded-full border border-line bg-white px-4 py-2 text-sm font-semibold" aria-live="polite" data-baseline-count>0 of 5 kept</p>
      </div>

      <div class="mt-7 grid gap-4 md:grid-cols-2" data-baseline-grid>
        {seoulBaselineCandidates.map((candidate) => (
          <article class="study-card" data-baseline-card data-id={candidate.id}>
            <div>
              <p class="ds-tag">{candidate.type}</p>
              <h3 class="mt-3 text-2xl leading-tight">{candidate.name}</h3>
              <p class="mt-3 font-medium leading-relaxed">{candidate.hook}</p>
              <p class="mt-2 text-sm leading-relaxed text-soft">{candidate.detail}</p>
            </div>
            <button type="button" class="study-keep" aria-pressed="false" data-baseline-keep>Keep</button>
          </article>
        ))}
      </div>
      <p class="mt-4 hidden text-sm font-semibold text-error" data-baseline-error>You can keep up to five ideas.</p>
      <div class="mt-8 flex flex-wrap items-center justify-between gap-4 border-t border-line pt-6">
        <button type="button" class="text-sm font-semibold text-soft hover:text-accent" data-back="intro">← Change trip context</button>
        <button type="button" class="ds-button ds-button-dark" data-continue-local disabled>Continue to the second set</button>
      </div>
    </section>

    <section class="study-step mt-10 hidden" data-study-step="local" aria-labelledby="seoul-local-heading">
      <div class="grid gap-5 lg:grid-cols-[1fr_auto] lg:items-end">
        <div>
          <p class="ds-eyebrow">Recommendation set two</p>
          <h2 id="seoul-local-heading" class="mt-2 max-w-3xl text-3xl leading-tight" tabindex="-1">Would any of these change the draft?</h2>
          <p class="mt-3 max-w-3xl leading-relaxed text-soft">Choose one response for every idea. “Replace” means it deserves time currently assigned to another stop.</p>
        </div>
        <p class="rounded-full border border-line bg-white px-4 py-2 text-sm font-semibold" aria-live="polite" data-local-count>0 of 8 answered</p>
      </div>

      <div class="mt-7 grid gap-5" data-local-grid>
        {seoulLocalLanguageCandidates.map((candidate) => (
          <article class="study-card study-card-wide" data-local-card data-id={candidate.id}>
            <div class="grid gap-5 lg:grid-cols-[1fr_auto] lg:items-start">
              <div>
                <p class="ds-tag">{candidate.type}</p>
                <h3 class="mt-3 text-2xl leading-tight">{candidate.name}</h3>
                <p class="mt-3 font-medium leading-relaxed">{candidate.hook}</p>
                <p class="mt-2 text-sm leading-relaxed text-soft">{candidate.detail}</p>
              </div>
              <div class="study-decisions" role="group" aria-label={`Decision for ${candidate.name}`}>
                <button type="button" data-decision="add" aria-pressed="false">Add</button>
                <button type="button" data-decision="replace" aria-pressed="false">Replace</button>
                <button type="button" data-decision="maybe" aria-pressed="false">Maybe</button>
                <button type="button" data-decision="not-for-me" aria-pressed="false">Not for me</button>
              </div>
            </div>
            <label class="mt-5 hidden border-t border-line pt-4 text-sm font-semibold" data-replace-wrap>
              What would it replace?
              <select class="ds-input mt-2" data-replace-target>
                <option value="">Choose a current stop</option>
              </select>
            </label>
          </article>
        ))}
      </div>

      <p class="mt-4 text-sm text-soft" data-local-guidance>Answer all eight to reveal where each recommendation came from.</p>
      <div class="mt-8 flex flex-wrap items-center justify-between gap-4 border-t border-line pt-6">
        <button type="button" class="text-sm font-semibold text-soft hover:text-accent" data-back="baseline">← Review the first set</button>
        <button type="button" class="ds-button ds-button-dark" data-reveal disabled>Reveal the sources</button>
      </div>
    </section>

    <section class="study-step mt-10 hidden" data-study-step="reveal" aria-labelledby="seoul-reveal-heading">
      <div class="study-result-hero">
        <p class="ds-eyebrow">Your result</p>
        <h2 id="seoul-reveal-heading" class="mt-2 max-w-4xl text-4xl leading-tight" tabindex="-1" data-result-title></h2>
        <p class="mt-4 max-w-3xl text-lg leading-relaxed text-soft" data-result-copy></p>
        <div class="mt-7 grid gap-3 sm:grid-cols-4" data-result-stats></div>
      </div>

      <div class="mt-12 grid gap-10 lg:grid-cols-[.68fr_1.32fr]">
        <aside>
          <p class="ds-eyebrow">What the first set was</p>
          <h3 class="mt-2 text-2xl">English traveler editorial and community web</h3>
          <p class="mt-3 text-sm leading-relaxed text-soft">Recognizable neighborhoods and destinations from English travel editorial and an English community post.</p>
          <div class="mt-5 space-y-3" data-baseline-reveal></div>
        </aside>

        <div>
          <p class="ds-eyebrow">What the second set was</p>
          <h3 class="mt-2 text-2xl">Korean citizen-reporter and local civic editorial</h3>
          <p class="mt-3 max-w-3xl text-sm leading-relaxed text-soft">These Korean-language sources often add sequence, timing, access, and conservation context. They are not a proxy for all Seoul residents or for Naver’s true rankings.</p>
          <div class="mt-5 grid gap-4" data-local-reveal></div>
        </div>
      </div>

      <section class="mt-14 border-t border-line pt-10" aria-labelledby="seoul-feedback-heading">
        <div class="grid gap-8 lg:grid-cols-[.72fr_1.28fr]">
          <div>
            <p class="ds-eyebrow">One last question</p>
            <h3 id="seoul-feedback-heading" class="mt-2 text-3xl leading-tight">Did specificity change the decision—or just make the ideas interesting?</h3>
            <p class="mt-3 leading-relaxed text-soft">This counterfactual separates plan change from curiosity and helps compare Seoul with the Shanghai pilot.</p>
          </div>
          <form class="ds-panel p-5 sm:p-7" data-feedback-form>
            <fieldset>
              <legend class="text-sm font-semibold">How confident are you in your revised draft?</legend>
              <div class="mt-3 flex flex-wrap gap-2">
                {[1, 2, 3, 4, 5].map((rating) => (
                  <label class="study-check"><input required type="radio" name="confidence" value={rating} /><span>{rating}</span></label>
                ))}
              </div>
            </fieldset>

            <fieldset class="mt-6">
              <legend class="text-sm font-semibold">Without the second set, would any of its ideas have entered your trip?</legend>
              <div class="mt-3 grid gap-2 sm:grid-cols-2">
                {[
                  ['definitely-not', 'Definitely not'],
                  ['probably-not', 'Probably not'],
                  ['unsure', 'Unsure'],
                  ['probably-yes', 'Probably yes'],
                ].map(([value, label]) => (
                  <label class="study-check"><input required type="radio" name="counterfactual" value={value} /><span>{label}</span></label>
                ))}
              </div>
            </fieldset>

            <fieldset class="mt-6">
              <legend class="text-sm font-semibold">What most affected your decision?</legend>
              <div class="mt-3 flex flex-wrap gap-2">
                {[
                  ['more-specific', 'More specific'],
                  ['better-context', 'Better context'],
                  ['route-ready', 'Usable route'],
                  ['too-far', 'Too far'],
                  ['map-uncertain', 'Map match uncertain'],
                  ['not-my-trip', 'Not my trip'],
                ].map(([value, label]) => (
                  <label class="study-check"><input type="checkbox" name="reasons" value={value} /><span>{label}</span></label>
                ))}
              </div>
            </fieldset>

            <label class="mt-6 block text-sm font-semibold">
              What would you need before committing one of these?
              <textarea name="note" maxlength="500" class="ds-input mt-2 min-h-28" placeholder="Current Naver/Kakao match, travel time, opening hours, more first-person evidence…"></textarea>
            </label>

            <div class="mt-6 flex flex-wrap items-center gap-3">
              <button type="submit" class="ds-button ds-button-dark">Save and prepare email</button>
              <button type="button" class="ds-button ds-button-secondary" data-copy-result>Copy result</button>
              <button type="button" class="ds-button ds-button-secondary" data-download-result>Download JSON</button>
              <button type="button" class="text-sm font-semibold text-soft hover:text-accent" data-reset-study>Start over</button>
            </div>
            <p class="mt-3 hidden text-sm text-soft" data-feedback-status aria-live="polite"></p>
          </form>
        </div>
      </section>
    </section>

    <script id="seoulLocalLensData" type="application/json" set:html={studyData}></script>
  </div>
</Base>

<script>
  import {
    LOCAL_LENS_MAX_BASELINE,
    createLocalLensRecord,
    seededRank,
    summarizeLocalLensStudy,
  } from '../../../utils/localLensStudy.js';
  import { buildKoreaLocalLensHandoff } from '../../../utils/localLensKoreaHandoff.js';

  const root = document.querySelector('[data-local-lens-study]');
  const dataNode = document.querySelector('#seoulLocalLensData');
  const studyData = JSON.parse(dataNode?.textContent || '{}');
  const baselineById = new Map((studyData.baselineCandidates || []).map((candidate) => [candidate.id, candidate]));
  const localById = new Map((studyData.localLanguageCandidates || []).map((candidate) => [candidate.id, candidate]));
  const sessionKey = 'ctme-local-lens-seoul-session-v1';
  const resultKey = 'ctme-local-lens-results-v1';
  let sessionId = localStorage.getItem(sessionKey);
  if (!sessionId) {
    sessionId = globalThis.crypto?.randomUUID?.() || `study-${Date.now()}-${Math.random().toString(36).slice(2)}`;
    localStorage.setItem(sessionKey, sessionId);
  }

  let profile = {};
  const baselineKept = new Set();
  const treatmentDecisions = {};
  const replaceTargets = {};
  let currentRecord = null;

  randomizeGrid('[data-baseline-grid]', '[data-baseline-card]', 'baseline');
  randomizeGrid('[data-local-grid]', '[data-local-card]', 'local');

  root?.querySelector('[data-context-form]')?.addEventListener('submit', (event) => {
    event.preventDefault();
    const formData = new FormData(event.currentTarget);
    profile = {
      base: String(formData.get('base') || '').trim(),
      days: String(formData.get('days') || ''),
      interests: formData.getAll('interests').map(String),
      existingStops: String(formData.get('existingStops') || '').split('\n').map((item) => item.trim()).filter(Boolean),
      constraints: String(formData.get('constraints') || '').trim(),
    };
    showStep('baseline');
  });

  root?.querySelectorAll('[data-baseline-card]').forEach((card) => {
    card.querySelector('[data-baseline-keep]')?.addEventListener('click', () => {
      const id = card.dataset.id;
      const error = root.querySelector('[data-baseline-error]');
      if (baselineKept.has(id)) baselineKept.delete(id);
      else if (baselineKept.size >= LOCAL_LENS_MAX_BASELINE) {
        error?.classList.remove('hidden');
        return;
      } else baselineKept.add(id);
      error?.classList.add('hidden');
      renderBaselineState();
    });
  });

  root?.querySelector('[data-continue-local]')?.addEventListener('click', () => {
    populateReplaceTargets();
    showStep('local');
  });

  root?.querySelectorAll('[data-local-card]').forEach((card) => {
    card.querySelectorAll('[data-decision]').forEach((button) => {
      button.addEventListener('click', () => {
        const id = card.dataset.id;
        treatmentDecisions[id] = button.dataset.decision;
        card.querySelectorAll('[data-decision]').forEach((choice) => choice.setAttribute('aria-pressed', String(choice === button)));
        card.querySelector('[data-replace-wrap]')?.classList.toggle('hidden', button.dataset.decision !== 'replace');
        if (button.dataset.decision !== 'replace') delete replaceTargets[id];
        renderTreatmentState();
      });
    });
    card.querySelector('[data-replace-target]')?.addEventListener('change', (event) => {
      const id = card.dataset.id;
      if (event.currentTarget.value) replaceTargets[id] = event.currentTarget.value;
      else delete replaceTargets[id];
      renderTreatmentState();
    });
  });

  root?.querySelector('[data-reveal]')?.addEventListener('click', () => {
    renderReveal();
    showStep('reveal');
  });
  root?.querySelectorAll('[data-back]').forEach((button) => button.addEventListener('click', () => showStep(button.dataset.back)));

  root?.querySelector('[data-feedback-form]')?.addEventListener('submit', (event) => {
    event.preventDefault();
    const formData = new FormData(event.currentTarget);
    const feedback = {
      confidence: Number(formData.get('confidence')),
      counterfactual: String(formData.get('counterfactual') || ''),
      reasons: formData.getAll('reasons').map(String),
      note: String(formData.get('note') || '').trim(),
    };
    currentRecord = buildRecord(feedback);
    persistRecord(currentRecord);
    setStatus('Saved on this device. Your email app has the study result ready to send.');
    window.gtag?.('event', 'local_lens_feedback', { destination: 'seoul', changed_plan: currentRecord.summary.changedPlan, confidence: feedback.confidence });
    window.location.href = `mailto:hello@chinatravelmadeeasy.com?subject=${encodeURIComponent('Seoul Local Lens study result')}&body=${encodeURIComponent(formatRecord(currentRecord))}`;
  });

  root?.querySelector('[data-copy-result]')?.addEventListener('click', async () => {
    currentRecord ||= buildRecord(null);
    persistRecord(currentRecord);
    try {
      await navigator.clipboard.writeText(formatRecord(currentRecord));
      setStatus('Result copied. It is also saved on this device.');
    } catch {
      setStatus('Result saved on this device. Clipboard access was unavailable.');
    }
  });

  root?.querySelector('[data-download-result]')?.addEventListener('click', () => {
    currentRecord ||= buildRecord(null);
    persistRecord(currentRecord);
    const blob = new Blob([`${JSON.stringify(currentRecord, null, 2)}\n`], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = `ctme-seoul-local-lens-${currentRecord.sessionId}.json`;
    document.body.append(link);
    link.click();
    link.remove();
    URL.revokeObjectURL(url);
    setStatus('Structured result downloaded. Send that file with the pilot response.');
  });

  root?.querySelector('[data-reset-study]')?.addEventListener('click', () => {
    localStorage.removeItem(sessionKey);
    window.location.reload();
  });

  function randomizeGrid(gridSelector, cardSelector, suffix) {
    const grid = root?.querySelector(gridSelector);
    if (!grid) return;
    [...grid.querySelectorAll(cardSelector)]
      .sort((left, right) => seededRank(left.dataset.id, `${sessionId}:${suffix}`) - seededRank(right.dataset.id, `${sessionId}:${suffix}`))
      .forEach((card) => grid.append(card));
  }

  function showStep(step) {
    root?.querySelectorAll('[data-study-step]').forEach((section) => section.classList.toggle('hidden', section.dataset.studyStep !== step));
    root?.querySelectorAll('[data-progress-step]').forEach((item) => {
      if (item.dataset.progressStep === step) item.setAttribute('aria-current', 'step');
      else item.removeAttribute('aria-current');
    });
    root?.querySelector(`[data-study-step="${step}"] h1, [data-study-step="${step}"] h2`)?.focus({ preventScroll: true });
    root?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function renderBaselineState() {
    root?.querySelectorAll('[data-baseline-card]').forEach((card) => {
      const selected = baselineKept.has(card.dataset.id);
      card.dataset.selected = String(selected);
      const button = card.querySelector('[data-baseline-keep]');
      button?.setAttribute('aria-pressed', String(selected));
      if (button) button.textContent = selected ? 'Kept' : 'Keep';
    });
    const count = root?.querySelector('[data-baseline-count]');
    if (count) count.textContent = `${baselineKept.size} of ${LOCAL_LENS_MAX_BASELINE} kept`;
    const continueButton = root?.querySelector('[data-continue-local]');
    if (continueButton) continueButton.disabled = baselineKept.size === 0;
  }

  function populateReplaceTargets() {
    const options = [
      ...[...baselineKept].map((id) => ({ value: `set-one:${id}`, label: baselineById.get(id)?.name || id })),
      ...(profile.existingStops || []).map((name) => ({ value: `existing:${name}`, label: name })),
    ];
    root?.querySelectorAll('[data-replace-target]').forEach((select) => {
      select.querySelectorAll('option:not(:first-child)').forEach((option) => option.remove());
      options.forEach((option) => {
        const node = document.createElement('option');
        node.value = option.value;
        node.textContent = option.label;
        select.append(node);
      });
    });
  }

  function renderTreatmentState() {
    const summary = summarizeLocalLensStudy({ baselineKeptIds: [...baselineKept], treatmentDecisions, replaceTargets });
    const count = root?.querySelector('[data-local-count]');
    if (count) count.textContent = `${summary.answeredCount} of ${localById.size} answered`;
    const guidance = root?.querySelector('[data-local-guidance]');
    if (guidance) guidance.textContent = summary.missingReplaceTargets.length
      ? 'Choose what each replacement would remove before revealing the sources.'
      : summary.answeredCount === localById.size
        ? 'All decisions recorded. The sources are ready to reveal.'
        : `Answer all ${localById.size} to reveal where each recommendation came from.`;
    const revealButton = root?.querySelector('[data-reveal]');
    if (revealButton) revealButton.disabled = summary.answeredCount !== localById.size || summary.missingReplaceTargets.length > 0;
  }

  function renderReveal() {
    const summary = summarizeLocalLensStudy({ baselineKeptIds: [...baselineKept], treatmentDecisions, replaceTargets });
    const title = root?.querySelector('[data-result-title]');
    const copy = root?.querySelector('[data-result-copy]');
    if (title) title.textContent = summary.changedPlan ? 'Yes—the second ecosystem changed this draft.' : 'Not yet—the second ecosystem did not change this draft.';
    if (copy) copy.textContent = summary.changedPlan
      ? `${summary.counts.add} idea${summary.counts.add === 1 ? '' : 's'} entered the plan and ${summary.counts.replace} would replace existing time.`
      : `${summary.counts.maybe} idea${summary.counts.maybe === 1 ? '' : 's'} remained a maybe, but none earned itinerary time.`;

    const stats = root?.querySelector('[data-result-stats]');
    if (stats) stats.innerHTML = [
      ['Add', summary.counts.add], ['Replace', summary.counts.replace], ['Maybe', summary.counts.maybe], ['Not for me', summary.counts['not-for-me']],
    ].map(([label, value]) => `<div><strong>${value}</strong><span>${label}</span></div>`).join('');

    const baselineReveal = root?.querySelector('[data-baseline-reveal]');
    if (baselineReveal) baselineReveal.innerHTML = [...baselineKept].map((id) => {
      const candidate = baselineById.get(id);
      return `<article class="study-source-card"><p class="font-semibold">${escapeHtml(candidate.name)}</p><p>${escapeHtml(candidate.sourceLabel)}</p><a href="${candidate.sourceUrl}" target="_blank" rel="noreferrer">Open source ↗</a></article>`;
    }).join('');

    const localReveal = root?.querySelector('[data-local-reveal]');
    if (localReveal) localReveal.innerHTML = [...localById.values()].map((candidate) => {
      const decision = treatmentDecisions[candidate.id];
      const target = replaceTargets[candidate.id] ? replacementLabel(replaceTargets[candidate.id]) : '';
      const handoff = buildKoreaLocalLensHandoff(candidate);
      return `<article class="study-reveal-card" data-decision-result="${decision}">
        <div class="flex flex-wrap items-center justify-between gap-3"><span class="study-decision-label">${decisionLabel(decision)}</span><span class="text-xs font-semibold text-faint">${escapeHtml(candidate.type)}</span></div>
        <h4 class="mt-3 text-2xl leading-tight">${escapeHtml(candidate.name)}</h4>
        <p class="mt-1 font-medium text-accent">${escapeHtml(candidate.originalName)}</p>
        ${target ? `<p class="mt-3 text-sm"><strong>Would replace:</strong> ${escapeHtml(target)}</p>` : ''}
        <p class="mt-3 text-sm leading-relaxed text-soft">${escapeHtml(candidate.sourceLabel)}</p>
        <div class="mt-4 rounded-2xl border border-line bg-surface p-4" data-provider-state="${handoff.statusTone}">
          <p class="text-sm font-semibold text-ink">${escapeHtml(handoff.statusLabel)}</p>
          ${candidate.providerMatch?.address ? `<p class="mt-1 text-sm text-soft">${escapeHtml(candidate.providerMatch.address)}</p>` : ''}
          <p class="mt-2 text-sm leading-relaxed text-soft">${escapeHtml(handoff.note)}</p>
          <p class="mt-2 text-xs font-bold uppercase tracking-[.12em] text-faint">Preview only · not eligible for automatic save</p>
        </div>
        <div class="mt-4 flex flex-wrap gap-3 text-sm font-semibold">
          <a href="${candidate.sourceUrl}" target="_blank" rel="noreferrer">Source ↗</a>
          ${handoff.links.map((link) => `<a href="${link.url}" target="_blank" rel="noreferrer">${escapeHtml(link.label)}</a>`).join('')}
        </div>
      </article>`;
    }).join('');

    currentRecord = buildRecord(null);
    persistRecord(currentRecord);
    window.gtag?.('event', 'local_lens_completed', { destination: 'seoul', changed_plan: summary.changedPlan, add_count: summary.counts.add, replace_count: summary.counts.replace });
  }

  function replacementLabel(value) {
    if (value.startsWith('set-one:')) return baselineById.get(value.replace('set-one:', ''))?.name || value;
    return value.replace('existing:', '');
  }

  function decisionLabel(decision) {
    return { add: 'Add to plan', replace: 'Replace a stop', maybe: 'Maybe', 'not-for-me': 'Not for me' }[decision] || decision;
  }

  function buildRecord(feedback) {
    return createLocalLensRecord({
      studyVersion: studyData.studyVersion,
      destination: 'Seoul',
      sessionId,
      profile,
      baselineKeptIds: [...baselineKept],
      treatmentDecisions,
      replaceTargets,
      feedback,
    });
  }

  function persistRecord(record) {
    try {
      const existing = JSON.parse(localStorage.getItem(resultKey) || '[]');
      const records = [record, ...existing.filter((item) => item.sessionId !== record.sessionId)].slice(0, 50);
      localStorage.setItem(resultKey, JSON.stringify(records));
    } catch {
      localStorage.setItem(resultKey, JSON.stringify([record]));
    }
  }

  function formatRecord(record) {
    const changed = Object.entries(record.treatmentDecisions)
      .filter(([, decision]) => decision === 'add' || decision === 'replace')
      .map(([id, decision]) => {
        const candidate = localById.get(id);
        const target = record.replaceTargets[id] ? ` → replaces ${replacementLabel(record.replaceTargets[id])}` : '';
        return `- ${decisionLabel(decision)}: ${candidate?.name} / ${candidate?.originalName}${target}`;
      });
    return [
      `Study: ${record.studyVersion}`,
      `Destination: ${record.destination}`,
      `Session: ${record.sessionId}`,
      `Changed plan: ${record.summary.changedPlan ? 'yes' : 'no'}`,
      `Add: ${record.summary.counts.add}; Replace: ${record.summary.counts.replace}; Maybe: ${record.summary.counts.maybe}; Not for me: ${record.summary.counts['not-for-me']}`,
      `Base: ${record.profile.base || 'not provided'}; Days: ${record.profile.days}`,
      `Interests: ${(record.profile.interests || []).join(', ') || 'not provided'}`,
      '', 'Decision-changing ideas:', ...(changed.length ? changed : ['- None']), '',
      `Confidence: ${record.feedback?.confidence || 'not provided'}`,
      `Would have entered otherwise: ${record.feedback?.counterfactual || 'not provided'}`,
      `Reasons: ${(record.feedback?.reasons || []).join(', ') || 'not provided'}`,
      `Note: ${record.feedback?.note || 'not provided'}`,
    ].join('\n');
  }

  function setStatus(message) {
    const status = root?.querySelector('[data-feedback-status]');
    if (!status) return;
    status.textContent = message;
    status.classList.remove('hidden');
  }

  function escapeHtml(value) {
    return String(value || '').replace(/[&<>'"]/g, (character) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' })[character]);
  }
</script>

<style>
