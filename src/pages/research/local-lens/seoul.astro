  .study-progress li { display: flex; align-items: center; gap: .5rem; border-top: 2px solid var(--color-line); padding-top: .75rem; }
  .study-progress li span { display: grid; width: 1.75rem; height: 1.75rem; place-items: center; border: 1px solid var(--color-line); border-radius: 999px; background: white; }
  .study-progress li[aria-current='step'] { border-color: var(--color-accent); color: var(--color-ink); }
  .study-progress li[aria-current='step'] span { border-color: var(--color-accent); background: var(--color-accent); color: white; }
  .study-card { display: flex; min-height: 19rem; flex-direction: column; justify-content: space-between; gap: 1.5rem; border: 1px solid var(--color-line); border-radius: 1.25rem; background: white; padding: 1.4rem; transition: border-color .2s ease, box-shadow .2s ease, transform .2s ease; }
  .study-card:hover { border-color: color-mix(in srgb, var(--color-accent) 45%, var(--color-line)); transform: translateY(-2px); }
  .study-card[data-selected='true'] { border-color: var(--color-accent); box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 14%, transparent); }
  .study-card-wide { min-height: 0; }
  .study-keep { min-height: 2.75rem; border: 1px solid var(--color-line); border-radius: 999px; font-size: .875rem; font-weight: 700; }
  .study-keep[aria-pressed='true'] { border-color: var(--color-accent); background: var(--color-accent); color: white; }
  .study-decisions { display: grid; grid-template-columns: repeat(2, minmax(7.5rem, 1fr)); gap: .45rem; }
  .study-decisions button { min-height: 2.6rem; border: 1px solid var(--color-line); border-radius: .75rem; padding: .5rem .8rem; background: white; font-size: .8rem; font-weight: 700; }
  .study-decisions button[aria-pressed='true'] { border-color: var(--color-ink); background: var(--color-ink); color: white; }
  .study-check input { position: absolute; opacity: 0; pointer-events: none; }
  .study-check span { display: inline-flex; min-height: 2.5rem; align-items: center; border: 1px solid var(--color-line); border-radius: 999px; background: white; padding: .45rem .9rem; font-size: .8rem; font-weight: 700; cursor: pointer; }
  .study-check input:checked + span { border-color: var(--color-accent); background: color-mix(in srgb, var(--color-accent) 10%, white); color: var(--color-accent); }
  .study-check input:focus-visible + span { outline: 2px solid var(--color-accent); outline-offset: 2px; }
  .study-result-hero { border: 1px solid var(--color-line); border-radius: 1.5rem; background: linear-gradient(135deg, white, #edf3f1); padding: clamp(1.5rem, 5vw, 3.5rem); }
  [data-result-stats] > div { border-top: 1px solid var(--color-line); padding-top: .8rem; }
  [data-result-stats] strong { display: block; font-family: var(--font-display); font-size: 2rem; }
  [data-result-stats] span { display: block; margin-top: .2rem; color: var(--color-soft); font-size: .75rem; font-weight: 700; }
  .study-source-card, .study-reveal-card { border: 1px solid var(--color-line); border-radius: 1rem; background: white; padding: 1rem; }
  .study-source-card p + p { margin-top: .3rem; color: var(--color-soft); font-size: .75rem; }
  .study-source-card a { display: inline-block; margin-top: .6rem; color: var(--color-accent); font-size: .75rem; font-weight: 700; }
  .study-reveal-card[data-decision-result='not-for-me'] { opacity: .62; }
  .study-decision-label { display: inline-flex; border-radius: 999px; background: var(--color-ink); padding: .35rem .7rem; color: white; font-size: .7rem; font-weight: 800; letter-spacing: .04em; text-transform: uppercase; }
  .study-reveal-card[data-decision-result='add'] .study-decision-label, .study-reveal-card[data-decision-result='replace'] .study-decision-label { background: var(--color-accent); }
  .study-reveal-card a { color: var(--color-accent); }
  button:disabled { cursor: not-allowed; opacity: .45; }
  @media (max-width: 640px) {
    .study-progress li { align-items: flex-start; flex-direction: column; font-size: .65rem; }
    .study-card { min-height: 0; }
    .study-decisions { grid-template-columns: 1fr 1fr; width: 100%; }
  }
</style>
