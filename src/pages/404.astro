---
import Base from '../layouts/Base.astro';
---

<Base title="Page not found" description="This page doesn't exist on China Travel Made Easy.">
  <section class="mx-auto max-w-3xl px-4 sm:px-6 py-24 text-center">
    <p class="text-6xl font-bold text-accent">404</p>
    <h1 class="mt-4 text-2xl font-bold">This page doesn't exist</h1>
    <p class="text-soft mt-3">Maybe the guide moved, or the link was mistyped.</p>
    <a
      href="/guides/"
      class="ds-button ds-button-primary mt-6"
    >
      Browse all guides
    </a>
  </section>
</Base>
