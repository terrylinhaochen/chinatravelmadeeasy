---
import Base from '../layouts/Base.astro';
---

<Base title="Page not found" description="This page doesn't exist on China Travel Made Easy.">
  <section class="mx-auto max-w-3xl px-4 sm:px-6 py-24 text-center">
    <p class="font-display font-bold text-6xl text-accent">404</p>
    <h1 class="font-display font-bold text-2xl mt-4">This page doesn't exist</h1>
    <p class="text-soft mt-3">Maybe the guide moved, or the link was mistyped.</p>
    <a
      href="/guides/"
      class="inline-flex items-center rounded-md bg-accent px-5 py-2.5 text-white font-medium mt-6 hover:bg-accent-dark transition-colors"
    >
      Browse all guides
    </a>
  </section>
</Base>
