---
import Base from '../layouts/Base.astro';
import contentSeedsData from '../data/contentSeeds.json';

const payload = contentSeedsData as {
  generated_at?: string;
  source: string;
  quality_thresholds?: {
    min_evidence_count: number;
    min_source_types: number;
    require_editor_review: boolean;
  };
  seeds: {
    id: string;
    kind: string;
    category: string;
    priority: number;
    question: string;
    concern: string;
    answer_seed: string;
    audience: string[];
    related_guides: { title: string; href: string }[];
    recommended_places: { name: string; area: string; maps_query: string }[];
    evidence_summary: string;
    evidence_count: number;
    source_mix: string[];
    search_phrases: string[];
    codex_brief: string;
    status: string;
  }[];
};

const generated = payload.generated_at
  ? new Date(payload.generated_at).toLocaleDateString('en-US', {
      month: 'long',
      day: 'numeric',
      year: 'numeric',
    })
  : null;
const description =
  'CrowdListen content seeds for China travel questions, concerns, recommendations, and AI-search guide updates.';
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    name: 'China travel content seeds',
    description,
    mainEntity: payload.seeds.slice(0, 12).map((seed) => ({
      '@type': 'Question',
      name: seed.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: seed.answer_seed,
      },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Dataset',
    name: 'China Travel Made Easy content seeds',
    description,
    creator: {
      '@type': 'Organization',
      name: 'China Travel Made Easy',
    },
    dateModified: payload.generated_at,
    distribution: {
      '@type': 'DataDownload',
      encodingFormat: 'application/json',
      contentUrl: 'https://chinatravelmadeeasy.com/content-seeds.json',
    },
  },
];
---

<Base title="Content seeds for AI search" description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16">
    <p class="ds-eyebrow">
      CrowdListen seed loop{generated && ` · Updated ${generated}`}
    </p>
    <div class="mt-3 grid gap-6 lg:grid-cols-[0.85fr_1.15fr] lg:items-end">
      <div>
        <h1 class="text-4xl font-bold leading-tight sm:text-5xl">
          Traveler answers and recommendations ready for guide updates.
        </h1>
      </div>
      <p class="text-lg leading-relaxed text-soft">
        These are content seeds, not raw trends. CrowdListen clusters traveler language,
        Codex turns the cluster into an editorial brief, and the public site publishes
        clear QA answers, guide updates, and save-ready places only after review.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="ds-panel p-4 sm:p-6">
      <div class="grid gap-4 md:grid-cols-3">
        <div class="ds-card p-5">
          <p class="ds-tag">1. Listen</p>
          <p class="mt-2 text-sm leading-relaxed text-soft">
            Collect review language, social posts, forum questions, hotel notes, food discussions,
            and destination writeups.
          </p>
        </div>
        <div class="ds-card p-5">
          <p class="ds-tag">2. Seed</p>
          <p class="mt-2 text-sm leading-relaxed text-soft">
            Convert repeated concerns into questions, answer seeds, related guide links, and place
            candidates for trip planning.
          </p>
        </div>
        <div class="ds-card p-5">
          <p class="ds-tag">3. Publish</p>
          <p class="mt-2 text-sm leading-relaxed text-soft">
            Codex drafts or updates guides, adds FAQ schema, refreshes llms.txt, and keeps direct
            source claims reviewable.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <div class="grid gap-4 lg:grid-cols-2">
      {payload.seeds.map((seed) => (
        <article class="ds-card p-5">
          <div class="flex flex-wrap items-center gap-2">
            <span class="ds-chip">{seed.category}</span>
            <span class="ds-chip">{seed.kind}</span>
            <span class="ds-chip">priority {seed.priority}</span>
          </div>
          <h2 class="mt-3 text-2xl font-bold leading-snug">{seed.question}</h2>
          <p class="mt-3 text-sm font-semibold text-ink">Concern</p>
          <p class="mt-1 text-sm leading-relaxed text-soft">{seed.concern}</p>
          <p class="mt-4 text-sm font-semibold text-ink">Answer seed</p>
          <p class="mt-1 text-sm leading-relaxed text-soft">{seed.answer_seed}</p>

          {seed.recommended_places.length > 0 && (
            <div class="mt-4">
              <p class="text-sm font-semibold text-ink">Save-ready places</p>
              <div class="mt-2 flex flex-wrap gap-2">
                {seed.recommended_places.map((place) => (
                  <a
                    href={`https://maps.apple.com/?q=${encodeURIComponent(place.maps_query)}`}
                    class="ds-chip hover:border-accent/50 hover:text-accent"
                  >
                    {place.name} · {place.area}
                  </a>
                ))}
              </div>
            </div>
          )}

          <div class="mt-4 border-t border-line pt-4">
            <p class="ds-tag">Guide targets</p>
            <div class="mt-2 flex flex-wrap gap-2">
              {seed.related_guides.map((guide) => (
                <a href={guide.href} class="ds-chip hover:border-accent/50 hover:text-accent">
                  {guide.title}
                </a>
              ))}
            </div>
          </div>

          <div class="mt-4 grid gap-3 border-t border-line pt-4 sm:grid-cols-2">
            <div>
              <p class="ds-tag">Evidence</p>
              <p class="mt-1 text-sm leading-relaxed text-soft">{seed.evidence_summary}</p>
            </div>
            <div>
              <p class="ds-tag">Codex action</p>
              <p class="mt-1 text-sm leading-relaxed text-soft">{seed.codex_brief}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</Base>
