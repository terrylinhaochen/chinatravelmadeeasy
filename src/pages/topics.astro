---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import { getCollection } from 'astro:content';

const guides = await getCollection('guides');
const guideById = Object.fromEntries(guides.map((guide) => [guide.id, guide]));

const topics = [
  {
    title: 'Start here',
    icon: 'checklist',
    body: 'The setup sequence before a first China trip: entry rules, apps, payments, internet, hotels, and bookings.',
    question: 'What should I set up before my first China trip?',
    answer:
      'Start with entry rules, then set up payments, internet, hotel bookings, transport apps, passport copies, and map saves before you fly.',
    href: '/guides/china-pre-departure-checklist/',
    guideIds: ['china-pre-departure-checklist', 'china-visa-free-2026', 'alipay-wechat-pay-foreign-cards'],
  },
  {
    title: 'Places',
    icon: 'map',
    body: 'Province-level destination regions, first-trip cities, and where each route should point next.',
    question: 'Which China destinations should I compare first?',
    answer:
      'Start with Beijing, Shanghai, Hong Kong, and Taiwan for common search intent, then open the full region guide when you need every province-level destination.',
    href: '/regions/',
    guideIds: ['7-day-china-itinerary', 'neighborhoods-beyond-landmarks', 'festivals-and-local-experiences'],
  },
  {
    title: 'Money and apps',
    icon: 'wallet',
    body: 'Alipay, WeChat Pay, foreign cards, cash backup, blocked apps, roaming eSIMs, and mobile setup.',
    question: 'Can foreign visitors pay and use apps normally in China?',
    answer:
      'Usually yes, but Alipay, WeChat Pay, foreign cards, cash backup, eSIMs, and blocked-app workarounds should be tested before arrival.',
    href: '/guides/alipay-wechat-pay-foreign-cards/',
    guideIds: ['alipay-wechat-pay-foreign-cards', 'internet-esim-vpn-blocked-apps', 'china-pre-departure-checklist'],
  },
  {
    title: 'Transport',
    icon: 'train',
    body: 'High-speed trains, Didi, metro QR codes, airport pickup, and choosing rail versus flights.',
    question: 'Should I use trains, Didi, metro, or domestic flights in China?',
    answer:
      'High-speed rail is often easiest between major cities, while Alipay metro QR codes and Didi handle most city movement without spoken Chinese.',
    href: '/guides/china-high-speed-trains/',
    guideIds: ['china-high-speed-trains', 'didi-metro-getting-around', '7-day-china-itinerary'],
  },
  {
    title: 'Staying',
    icon: 'bed',
    body: 'Hotels that accept foreign passports, police registration, neighborhood choices, and booking traps.',
    question: 'How do I avoid hotel check-in problems with a foreign passport?',
    answer:
      'Book mainstream hotels that clearly accept foreign guests, keep the passport name exact, and confirm smaller properties before arrival.',
    href: '/guides/hotels-foreigners-china/',
    guideIds: ['hotels-foreigners-china', 'translation-language-survival', 'china-pre-departure-checklist'],
  },
  {
    title: 'Eating',
    icon: 'bowl',
    body: 'Street food, QR menus, dietary needs, tea houses, spice levels, and food streets worth skipping.',
    question: 'How do I order food in China without getting stuck at QR menus?',
    answer:
      'Prepare camera translation, dietary cards, simple ordering phrases, and payment setup; use the food guides to choose where social recommendations are actually useful.',
    href: '/guides/street-food-night-markets/',
    guideIds: ['street-food-night-markets', 'food-ordering-dietary', 'tea-houses-and-rituals'],
  },
  {
    title: 'Language',
    icon: 'chat',
    body: 'Camera translation, offline packs, screenshots, WeChat translate, and phrases that actually help.',
    question: 'Can I travel in China if I do not speak Chinese?',
    answer:
      'Yes for common first-trip routes if you prepare translation tools, saved addresses, screenshots, and a few practical phrases for hotels, food, and transport.',
    href: '/guides/translation-language-survival/',
    guideIds: ['translation-language-survival', 'food-ordering-dietary', 'hotels-foreigners-china'],
  },
  {
    title: 'Authentic experiences',
    icon: 'compass',
    body: 'Hutongs, longtang lanes, tea houses, morning parks, festivals, and local etiquette.',
    question: 'How do I find more authentic experiences beyond big landmarks?',
    answer:
      'Use local neighborhoods, tea houses, morning parks, seasonal festivals, and crowd-vetted recommendations as the planning layer around famous sights.',
    href: '/guides/neighborhoods-beyond-landmarks/',
    guideIds: ['neighborhoods-beyond-landmarks', 'tea-houses-and-rituals', 'festivals-and-local-experiences'],
  },
  {
    title: 'Save Places',
    icon: 'map',
    body: 'Turn TikTok or Instagram inspiration into saved Apple Maps links and trip collections.',
    question: 'How do I turn TikTok or Instagram China travel posts into saved map places?',
    answer:
      'Paste the link, extract the likely place from the post text, sign in only when saving, then keep the place in a trip collection with Apple Maps as the default.',
    href: '/map-import/',
    guideIds: ['street-food-night-markets', 'neighborhoods-beyond-landmarks', 'didi-metro-getting-around'],
  },
];

const description =
  'China travel topics grouped by planning intent: places, payments, apps, transport, hotels, food, language, authentic experiences, and saved map collections.';
const faqEntities = topics.map((topic) => ({
  '@type': 'Question',
  name: topic.question,
  acceptedAnswer: {
    '@type': 'Answer',
    text: topic.answer,
    url: new URL(topic.href, Astro.site).toString(),
  },
}));

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'China travel topics',
    url: 'https://chinatravelmadeeasy.com/topics/',
    description,
    isPartOf: { '@type': 'WebSite', url: 'https://chinatravelmadeeasy.com/' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    name: 'China travel topics as questions',
    description,
    inLanguage: 'en',
    mainEntity: faqEntities,
  },
];
---

<Base title="China travel topics" description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16">
    <div class="grid gap-6 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
      <div>
        <p class="ds-eyebrow">Topics</p>
        <h1 class="mt-2 text-4xl font-bold leading-tight sm:text-5xl">Plan by what you need to solve.</h1>
      </div>
      <p class="text-lg leading-relaxed text-soft">
        Guides are grouped around traveler intent, not a generic table of contents: where to go,
        how to pay, how to move, where to stay, what to eat, and how to save places from social posts.
      </p>
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {topics.map((topic) => (
        <a href={topic.href} class="ds-card-link group p-5">
          <span class="ds-icon-tile">
            <Icon name={topic.icon} class="h-5 w-5" />
          </span>
          <h2 class="mt-3 text-2xl font-bold group-hover:text-accent">{topic.title}</h2>
          <p class="mt-3 font-semibold leading-snug text-ink">{topic.question}</p>
          <p class="mt-2 text-sm leading-relaxed text-soft">{topic.body}</p>
          <div class="mt-4 border-t border-line pt-3">
            <p class="ds-tag">Related guides</p>
            <div class="mt-2 flex flex-wrap gap-2">
              {topic.guideIds.map((id) => guideById[id]).filter(Boolean).map((guide) => (
                <span class="ds-chip">
                  {guide.data.category}
                </span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="ds-panel p-5 sm:p-8">
      <div class="grid gap-5 lg:grid-cols-[0.7fr_1.3fr] lg:items-end">
        <div>
          <p class="ds-eyebrow">QA index</p>
          <h2 class="mt-2 text-3xl font-bold">Questions this page answers</h2>
        </div>
        <p class="leading-relaxed text-soft">
          Each topic is written as a search question first, then linked to the guide or tool that
          answers the planning problem.
        </p>
      </div>
      <dl class="ds-card mt-6 divide-y divide-line">
        {topics.map((topic) => (
          <div class="grid gap-2 p-4 sm:grid-cols-[0.9fr_1.1fr] sm:p-5">
            <dt class="text-xl font-bold">{topic.question}</dt>
            <dd class="text-sm leading-relaxed text-soft">
              {topic.answer}
              <a href={topic.href} class="ml-2 font-semibold text-accent hover:text-accent-dark">
                Open {topic.title}
              </a>
            </dd>
          </div>
        ))}
      </dl>
    </div>
  </section>
</Base>
