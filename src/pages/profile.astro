---
import Base from '../layouts/Base.astro';
const description =
  'A local profile workspace organized by city for saved map pins, visited places, and compact place updates.';
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ProfilePage',
    name: 'China travel profile',
    description,
    url: 'https://chinatravelmadeeasy.com/profile/',
    isPartOf: { '@type': 'WebSite', url: 'https://chinatravelmadeeasy.com/' },
  },
];
---

<Base title="Profile" description={description} jsonLd={jsonLd}>
  <section class="ds-section profile-page">
    <p class="ds-eyebrow">Profile</p>
    <div class="mt-3 grid gap-8 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
      <div>
        <div class="flex items-center gap-3">
          <span class="profile-owner-mark" aria-hidden="true" data-profile-mark>P</span>
          <div>
            <h1 class="text-5xl leading-tight sm:text-6xl" data-profile-heading>My places</h1>
            <p class="mt-2 text-sm leading-relaxed text-soft" data-profile-session-copy>Sign in to keep uploaded lists and collected maps together.</p>
          </div>
        </div>

        <div class="mt-6 grid grid-cols-3 gap-2">
          <div class="profile-stat">
            <p class="ds-tag">Pins</p>
            <p class="mt-2 text-3xl leading-none" data-profile-pin-stat>0</p>
          </div>
          <div class="profile-stat">
            <p class="ds-tag">Lists</p>
            <p class="mt-2 text-3xl leading-none" data-profile-list-stat>0</p>
          </div>
          <div class="profile-stat">
            <p class="ds-tag">Collected</p>
            <p class="mt-2 text-3xl leading-none" data-profile-collected-stat>0</p>
          </div>
        </div>
      </div>

      <div class="ds-panel p-5 sm:p-6">
        <p class="ds-eyebrow">Personal map library</p>
        <h2 class="mt-2 text-3xl leading-tight">Only the places you reviewed or collected</h2>
        <p class="mt-3 text-sm leading-relaxed text-soft" data-profile-map-copy>
          Start with a caption, traveler story, or city collection. Nothing appears here merely because it exists in the community catalog.
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          <a href="/map-import/" class="ds-button ds-button-dark">Add places</a>
          <a href="/curated/" class="ds-button ds-button-secondary">Browse city collections</a>
        </div>
      </div>
    </div>

    <section class="profile-workspace ds-card mt-8 p-4 sm:p-5">
      <div class="flex flex-wrap items-end justify-between gap-3">
        <div>
          <p class="ds-eyebrow">Workspace</p>
          <h2 class="mt-2 text-3xl leading-tight">Saved and collected</h2>
          <p class="mt-2 max-w-2xl text-sm leading-relaxed text-soft">
            Uploaded lists and collected city maps show up here.
          </p>
        </div>
        <div class="flex flex-wrap gap-2">
          <button type="button" class="ds-button ds-button-dark" data-profile-signin>Sign in</button>
          <a href="/map-import/" class="ds-button ds-button-secondary">Add places</a>
        </div>
      </div>

      <div class="mt-5 grid gap-4 lg:grid-cols-2">
        <div>
          <div class="flex items-center justify-between gap-3">
            <p class="ds-tag">Uploaded lists</p>
            <span class="text-xs font-semibold text-faint" data-profile-uploaded-count>0</span>
          </div>
          <div class="mt-3 grid gap-3" data-profile-uploaded-lists></div>
        </div>
        <div>
          <div class="flex items-center justify-between gap-3">
            <p class="ds-tag">Collected maps</p>
            <span class="text-xs font-semibold text-faint" data-profile-collected-count>0</span>
          </div>
          <div class="mt-3 grid gap-3" data-profile-collected-lists></div>
        </div>
      </div>
    </section>

  </section>

  <script>
    import {
      getProfileSummary,
      getUser,
    } from '../utils/localPrototypeState.js';
    import { createSharedWorkspace, encodeSharedWorkspace } from '../utils/sharedLocationTask.js';

    const signinButton = document.querySelector('[data-profile-signin]');

    signinButton.addEventListener('click', async () => {
      if (window.ctmeRequireUser) await window.ctmeRequireUser('start your profile');
      renderWorkspace();
    });
    window.addEventListener('ctme-state-updated', renderWorkspace);
    renderWorkspace();

    function renderWorkspace() {
      const user = getUser();
      const summary = getProfileSummary();
      const uploadedLists = summary.uploadedLists;
      const collectedMaps = summary.collectedCollections;
      document.querySelector('[data-profile-mark]').textContent = user ? user.email.slice(0, 1).toUpperCase() : 'P';
      document.querySelector('[data-profile-heading]').textContent = user ? user.email.split('@')[0] + "'s places" : 'My places';
      document.querySelector('[data-profile-session-copy]').textContent = user
        ? 'Uploaded lists and collected maps are saved in this browser.'
        : 'Sign in to keep uploaded lists and collected maps together.';
      document.querySelector('[data-profile-pin-stat]').textContent = String(summary.totalPins);
      document.querySelector('[data-profile-list-stat]').textContent = String(uploadedLists.length + collectedMaps.length);
      document.querySelector('[data-profile-collected-stat]').textContent = String(collectedMaps.length);
      document.querySelector('[data-profile-uploaded-count]').textContent = uploadedLists.length + ' list' + (uploadedLists.length === 1 ? '' : 's');
      document.querySelector('[data-profile-collected-count]').textContent = collectedMaps.length + ' map' + (collectedMaps.length === 1 ? '' : 's');
      document.querySelector('[data-profile-map-copy]').textContent = summary.totalPins
        ? 'Your workspace currently holds ' + summary.totalPins + ' reviewed pin' + (summary.totalPins === 1 ? '' : 's') + ' across ' + (uploadedLists.length + collectedMaps.length) + ' city set' + ((uploadedLists.length + collectedMaps.length) === 1 ? '' : 's') + '.'
        : 'Start with a caption, traveler story, or city collection. Nothing appears here merely because it exists in the community catalog.';
      signinButton.textContent = user ? 'Signed in' : 'Sign in';
      signinButton.classList.toggle('ds-button-secondary', Boolean(user));
      signinButton.classList.toggle('ds-button-dark', !user);
      renderUploaded(uploadedLists);
      renderCollected(collectedMaps);
    }

    function renderUploaded(lists) {
      const target = document.querySelector('[data-profile-uploaded-lists]');
      if (!lists.length) {
        target.innerHTML = '<div class="profile-empty-card">Add a link, caption, screenshot note, or list to create your first pin set.</div>';
        return;
      }
      target.innerHTML = lists.map((list) => {
        const places = Array.isArray(list.places) ? list.places : [];
        const savedDecisions = Array.isArray(list.decisions) ? list.decisions : [];
        const taskPlaces = places.map((place) => {
          const savedDecision = savedDecisions.find((decision) => decision.name === place.name && decision.city === place.city);
          return { ...place, decision: savedDecision?.decision || 'keep', decisionReason: savedDecision?.decisionReason || '' };
        });
        const workspace = createSharedWorkspace({
          title: list.name || 'Saved pin list',
          source: { url: list.sourceUrl || '', platform: list.platform || 'Saved list', text: '' },
          places: taskPlaces,
          constraints: list.constraints || {},
        });
        const remixHref = '/map-import/?task=' + encodeURIComponent(encodeSharedWorkspace(workspace));
        return '<article class="profile-saved-card">' +
          '<div><p class="ds-tag">' + escapeHtml(list.platform || 'Uploaded') + '</p>' +
          '<h3 class="mt-1 text-xl leading-tight">' + escapeHtml(list.name || 'Saved pin list') + '</h3></div>' +
          '<p class="mt-2 text-sm text-soft">' + places.length + ' pin' + (places.length === 1 ? '' : 's') + '</p>' +
          '<div class="mt-3 flex flex-wrap gap-2">' + places.slice(0, 4).map((place) => '<span class="ds-chip">' + escapeHtml(place.name || place.label || 'Place') + '</span>').join('') + '</div>' +
          '<div class="mt-4 flex flex-wrap gap-3">' +
            '<a class="text-sm font-semibold text-ink hover:text-accent" href="' + escapeHtml(remixHref) + '">Review or share</a>' +
            (list.sourceUrl ? '<a class="text-sm font-semibold text-ink hover:text-accent" target="_blank" rel="noopener" href="' + escapeHtml(list.sourceUrl) + '">Open source</a>' : '') +
          '</div>' +
        '</article>';
      }).join('');
    }

    function renderCollected(collections) {
      const target = document.querySelector('[data-profile-collected-lists]');
      if (!collections.length) {
        target.innerHTML = '<div class="profile-empty-card">Collect a city map from Curated to remix it here.</div>';
        return;
      }
      target.innerHTML = collections.map((collection) => (
        '<article class="profile-saved-card">' +
          '<div><p class="ds-tag">' + escapeHtml(collection.owner || collection.source || 'Curated') + '</p>' +
          '<h3 class="mt-1 text-xl leading-tight">' + escapeHtml(collection.title || 'Collected map') + '</h3></div>' +
          '<p class="mt-2 text-sm text-soft">' + Number(collection.placeCount || 0) + ' pin' + (Number(collection.placeCount || 0) === 1 ? '' : 's') + '</p>' +
          '<a class="mt-3 inline-flex text-sm font-semibold text-ink hover:text-accent" href="' + escapeHtml(collection.href || '/curated/') + '">Open collection</a>' +
        '</article>'
      )).join('');
    }

    function escapeHtml(value) {
      return String(value || '').replace(/[&<>"']/g, (char) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#039;',
      })[char]);
    }
  </script>
</Base>

<style>
  .profile-owner-mark {
    display: inline-flex;
    width: 3.5rem;
    height: 3.5rem;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-line);
    border-radius: 12px;
    background: var(--color-accent);
    color: white;
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1;
  }

  .profile-stat {
    border: 1px solid var(--color-line);
    border-radius: 10px;
    background: white;
    padding: 0.85rem;
  }

  .profile-workspace {
    background:
      radial-gradient(circle at 95% 8%, rgb(41 37 36 / 0.05), transparent 24%),
      white;
  }

  :global(.profile-saved-card),
  .profile-empty-card {
    border: 1px solid var(--color-line);
    border-radius: 12px;
    background: var(--color-paper);
    padding: 1rem;
  }

  .profile-empty-card {
    color: var(--color-soft);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  @media (max-width: 640px) {
    .profile-stat {
      padding: 0.75rem;
    }
  }
</style>
