---
import Base from '../layouts/Base.astro';
import CuratedCollectionMap from '../components/CuratedCollectionMap.astro';
import {
  curatedCollections,
  curatedRegionMeta,
  type CuratedCollectionRegionBucket,
} from '../data/curatedCollections';

const owner = curatedCollections[0]?.owner;
const allPlaces = curatedCollections.flatMap((collection) =>
  collection.places.map((place) => ({
    ...place,
    collectionSlug: collection.slug,
    collectionTitle: collection.title,
    ownerName: collection.owner.name,
    ownerSlug: collection.owner.slug,
  }))
);
const cityGroups = Array.from(new Set(allPlaces.map((place) => place.regionBucket)))
  .map((city) => {
    const places = allPlaces.filter((place) => place.regionBucket === city);
    return {
      city: city as CuratedCollectionRegionBucket,
      meta: curatedRegionMeta[city as CuratedCollectionRegionBucket],
      places,
      noteCount: places.filter((place) => place.note).length,
    };
  })
  .sort((a, b) => b.places.length - a.places.length);
const noteCount = allPlaces.filter((place) => place.note).length;
const description =
  'A local profile workspace organized by city for saved map pins, visited places, and compact place updates.';
const profileCollection = {
  ...curatedCollections[0],
  places: allPlaces,
  placeCount: allPlaces.length,
};
function collectionHref(collection: (typeof curatedCollections)[number], city?: CuratedCollectionRegionBucket) {
  const ownerSlug = collection.owner.slug;
  const list = collection.title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  return `/curated/${ownerSlug}/${list}/${city ? `?city=${city}` : ''}`;
}
const profileCityEditions = cityGroups.map((city) => {
  const collection = curatedCollections[0];
  return {
    id: `${owner?.slug ?? 'profile'}:${city.city}`,
    collection,
    href: collection ? collectionHref(collection, city.city) : '/curated/',
    ...city,
  };
});
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ProfilePage',
    name: owner ? `${owner.name} travel profile` : 'Travel profile',
    description,
    url: 'https://chinatravelmadeeasy.com/profile/',
    isPartOf: { '@type': 'WebSite', url: 'https://chinatravelmadeeasy.com/' },
  },
];
---

<Base title="Profile" description={description} jsonLd={jsonLd}>
  <section class="ds-section profile-page">
    <p class="ds-eyebrow">Profile</p>
    <div class="mt-3 grid gap-8 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
      <div>
        <div class="flex items-center gap-3">
          <span class="profile-owner-mark" aria-hidden="true">{owner?.name.slice(0, 1) ?? 'P'}</span>
          <div>
            <h1 class="text-5xl leading-tight sm:text-6xl">{owner?.name ?? 'My places'}</h1>
            <p class="mt-2 text-sm leading-relaxed text-soft">Raw map saves turned into city travel sets.</p>
          </div>
        </div>

        <div class="mt-6 grid grid-cols-3 gap-2">
          <div class="profile-stat">
            <p class="ds-tag">Pins</p>
            <p class="mt-2 text-3xl leading-none">{allPlaces.length}</p>
          </div>
          <div class="profile-stat">
            <p class="ds-tag">Cities</p>
            <p class="mt-2 text-3xl leading-none">{cityGroups.length}</p>
          </div>
          <div class="profile-stat">
            <p class="ds-tag">Notes</p>
            <p class="mt-2 text-3xl leading-none">{noteCount}</p>
          </div>
        </div>
      </div>

      <div class="profile-map-wrap">
        <CuratedCollectionMap collection={profileCollection} compact />
      </div>
    </div>

    <section class="mt-8">
      <p class="ds-eyebrow">Cities</p>
      <div class="mt-2 grid gap-2 md:grid-cols-[1fr_minmax(16rem,0.45fr)] md:items-end">
        <h2 class="text-3xl leading-tight">City travel sets</h2>
        <p class="text-sm leading-relaxed text-soft">Ingest map, cluster pins, add travel context, collect the set.</p>
      </div>

      <div class="profile-city-grid mt-5">
        {profileCityEditions.map((edition) => (
          <article class="profile-city-edition ds-card grid gap-4 p-3 sm:p-4">
            <a class="profile-cover" href={edition.href} aria-label={`Open ${edition.meta.edition}`}>
              <img class="profile-cover-image" src={edition.meta.cover.src} alt={edition.meta.cover.alt} loading="lazy" />
              <div class="profile-cover-map" aria-hidden="true">
                <CuratedCollectionMap collection={edition.collection} places={edition.places} compact />
              </div>
              <div class="profile-cover-copy">
                <span class="profile-owner-mark is-small" aria-hidden="true">{owner?.name.slice(0, 1) ?? 'P'}</span>
                <div>
                  <p class="ds-tag">{edition.meta.annotation}</p>
                  <h3 class="mt-2 text-4xl leading-none">{edition.meta.label}</h3>
                  <p class="mt-2 text-sm text-soft">{edition.places.length} saved pins</p>
                </div>
              </div>
            </a>

            <div class="min-w-0">
              <p class="ds-eyebrow">{owner?.name ?? 'Profile'}</p>
              <div class="mt-2 flex flex-wrap items-start justify-between gap-3">
                <h3 class="text-2xl leading-tight">{edition.meta.edition}</h3>
                <span class="ds-tag">{edition.meta.guide}</span>
              </div>
              <p class="mt-3 text-sm leading-relaxed text-soft">{edition.meta.focus}</p>

              <div class="mt-5 grid grid-cols-3 gap-2">
                <div class="profile-stat">
                  <p class="ds-tag">Pins</p>
                  <p class="mt-2 text-2xl leading-none">{edition.places.length}</p>
                </div>
                <div class="profile-stat">
                  <p class="ds-tag">City</p>
                  <p class="mt-2 text-lg leading-none">{edition.meta.label}</p>
                </div>
                <div class="profile-stat">
                  <p class="ds-tag">Notes</p>
                  <p class="mt-2 text-2xl leading-none">{edition.noteCount}</p>
                </div>
              </div>

              <div class="mt-5 rounded-md border border-line bg-paper p-3">
                <div class="flex flex-wrap items-center justify-between gap-2">
                  <p class="ds-tag">Why collect</p>
                  <p class="text-xs font-semibold uppercase tracking-[0.12em] text-faint">Pipeline output</p>
                </div>
                <a class="profile-preview-copy mt-3" href={edition.href}>
                  {edition.meta.hook}
                </a>
              </div>

              <div class="mt-5 flex flex-wrap gap-2">
                <button
                  type="button"
                  class="ds-button ds-button-dark"
                  data-profile-collect={edition.id}
                  data-profile-title={`${edition.meta.edition}: ${owner?.name ?? 'Profile'}`}
                  data-profile-href={edition.href}
                  data-profile-count={edition.places.length}
                >
                  Collect
                </button>
                <a href={edition.href} class="ds-button ds-button-secondary">Open city</a>
              </div>
              <p class="mt-3 hidden text-sm leading-relaxed text-soft" data-profile-collect-status={edition.id}></p>
            </div>
          </article>
        ))}
      </div>
    </section>
  </section>

  <script>
    const collectButtons = document.querySelectorAll('[data-profile-collect]');
    const collectedKey = 'ctme-collected-curated';

    collectButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const collected = getCollected();
        const id = button.dataset.profileCollect;
        const item = {
          id,
          title: button.dataset.profileTitle,
          href: button.dataset.profileHref,
          placeCount: Number(button.dataset.profileCount || 0),
          savedAt: new Date().toISOString(),
        };
        localStorage.setItem(collectedKey, JSON.stringify([item, ...collected.filter((entry) => entry.id !== id)].slice(0, 24)));
        button.textContent = 'Collected';
        button.classList.remove('ds-button-dark');
        button.classList.add('ds-button-secondary');
        const status = document.querySelector(`[data-profile-collect-status="${id}"]`);
        if (status) {
          status.textContent = 'Saved on this device.';
          status.classList.remove('hidden');
        }
      });
    });

    function getCollected() {
      try {
        return JSON.parse(localStorage.getItem(collectedKey) || '[]');
      } catch {
        return [];
      }
    }
  </script>
</Base>

<style>
  .profile-owner-mark {
    display: inline-flex;
    width: 3.5rem;
    height: 3.5rem;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-line);
    border-radius: 12px;
    background: var(--color-accent);
    color: white;
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1;
  }

  .profile-stat {
    border: 1px solid var(--color-line);
    border-radius: 10px;
    background: white;
    padding: 0.85rem;
  }

  .profile-map-wrap :global(.curated-map) {
    min-height: 17rem;
  }

  .profile-owner-mark.is-small {
    width: 2.7rem;
    height: 2.7rem;
    border-radius: 10px;
    font-size: 1.05rem;
  }

  .profile-city-grid {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 900px) {
    .profile-city-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .profile-city-edition {
    overflow: hidden;
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  .profile-city-edition:hover {
    border-color: #d6d3d1;
    box-shadow:
      rgba(0, 0, 0, 0.02) 0 0 0 1px,
      rgba(0, 0, 0, 0.04) 0 2px 6px,
      rgba(0, 0, 0, 0.1) 0 4px 8px;
  }

  .profile-cover {
    position: relative;
    display: grid;
    min-height: 14rem;
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: 14px;
    background: var(--color-paper);
    color: inherit;
  }

  .profile-cover-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.92) contrast(0.96);
  }

  .profile-cover::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.16), transparent 32%),
      linear-gradient(0deg, rgb(255 255 255 / 0.94), rgb(255 255 255 / 0.62) 46%, transparent 72%);
    pointer-events: none;
  }

  .profile-cover-map {
    position: absolute;
    inset: 0.75rem 0.75rem 4.7rem;
    opacity: 0.58;
    mix-blend-mode: multiply;
  }

  .profile-cover-map :global(.curated-map) {
    height: 100%;
    border: 0;
    background: transparent;
    padding: 0;
  }

  .profile-cover-copy {
    position: relative;
    z-index: 1;
    display: flex;
    min-height: 100%;
    align-items: end;
    gap: 1rem;
    padding: 0.85rem;
  }

  .profile-preview-copy {
    display: block;
    color: var(--color-ink);
    font-size: 1rem;
    font-weight: 650;
    line-height: 1.45;
  }

  @media (max-width: 640px) {
    .profile-cover {
      min-height: 13rem;
    }

    .profile-stat {
      padding: 0.75rem;
    }
  }
</style>
