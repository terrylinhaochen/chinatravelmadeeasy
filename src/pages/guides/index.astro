---
import Base from '../../layouts/Base.astro';
import GuideCard from '../../components/GuideCard.astro';
import { getCollection } from 'astro:content';

const guides = (await getCollection('guides')).sort(
  (a, b) => a.data.order - b.data.order
);
const guideById = Object.fromEntries(guides.map((guide) => [guide.id, guide]));
const demandUpdates = [
  {
    label: 'Updated from traveler payment failures',
    title: 'Foreign-card payments need fallback planning, not just setup steps',
    href: '/guides/alipay-wechat-pay-foreign-cards/',
    body: 'The payment guide now covers linked-card failures, private QR problems, second-card strategy, and cash fallback order.',
  },
  {
    label: 'Next guide queue',
    title: 'Visa routing, hotel passport checks, food ordering, and social-save workflows',
    href: '/content-seeds/',
    body: 'The public seed queue shows which traveler questions are ready for evidence gathering and guide updates.',
  },
  {
    label: 'Product workflow',
    title: 'Turn social travel links into save-ready map places',
    href: '/map-import/',
    body: 'A lightweight place extraction flow converts social inspiration into Apple Maps and AMap search cards.',
  },
];
const priorityGuides = [
  guideById['alipay-wechat-pay-foreign-cards'],
  guideById['china-visa-free-2026'],
  guideById['hotels-foreigners-china'],
  guideById['food-ordering-dietary'],
].filter(Boolean);

const description =
  'Every China Travel Made Easy guide: payments, internet, visas, trains, city transport, language, hotels, food, and demand-backed travel questions from CrowdListen.';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'All China travel guides',
    url: 'https://chinatravelmadeeasy.com/guides/',
    description,
    isPartOf: { '@type': 'WebSite', url: 'https://chinatravelmadeeasy.com/' },
  },
];
---

<Base title="All guides" description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-12">
    <h1 class="text-3xl font-bold">All guides</h1>
    <p class="text-soft mt-3 max-w-2xl leading-relaxed">
      Read the <a href="/guides/china-pre-departure-checklist/" class="text-accent underline">pre-departure
      checklist</a> first — it links to everything else in the order you'll actually need it.
    </p>
    <div class="ds-panel mt-8 p-5 sm:p-6">
      <div class="grid gap-5 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
        <div>
          <p class="ds-eyebrow">
            CrowdListen guide desk
          </p>
          <h2 class="mt-2 text-3xl font-bold leading-tight">
            Demand-backed updates to make the site less sparse.
          </h2>
          <p class="mt-3 text-soft leading-relaxed">
            The guide queue starts from repeated traveler problems, then turns them into finished
            pages, FAQ blocks, and save-ready planning tools.
          </p>
        </div>
        <div class="grid gap-3">
          {demandUpdates.map((update) => (
            <a href={update.href} class="ds-card-link group p-4">
              <p class="ds-tag">{update.label}</p>
              <h3 class="mt-1 text-xl font-bold leading-snug group-hover:text-accent">{update.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-soft">{update.body}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
    <div class="mt-8">
      <p class="ds-eyebrow">
        Highest-intent planning questions
      </p>
      <div class="grid sm:grid-cols-2 gap-4 mt-3">
        {priorityGuides.map((guide) => <GuideCard guide={guide} />)}
      </div>
    </div>
    <div class="grid sm:grid-cols-2 gap-4 mt-8">
      {guides.map((guide) => <GuideCard guide={guide} />)}
    </div>
  </section>
</Base>
