---
import Base from '../../layouts/Base.astro';
import GuideListingPage from '../../components/GuideListingPage.astro';
import { getCollection } from 'astro:content';

const guides = (await getCollection('guides')).sort((a, b) => a.data.order - b.data.order);
const perPage = 12;
const currentPage = 1;
const totalPages = Math.ceil(guides.length / perPage);
const pagedGuides = guides.slice(0, perPage);

const description =
  'China Travel Made Easy guides for payments, internet, visas, trains, city transport, language, hotels, food, and first-trip planning.';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'China travel guides',
    url: 'https://chinatravelmadeeasy.com/guides/',
    description,
    isPartOf: { '@type': 'WebSite', url: 'https://chinatravelmadeeasy.com/' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'China travel guides',
    description,
    numberOfItems: pagedGuides.length,
    itemListElement: pagedGuides.map((guide, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: guide.data.seoTitle ?? guide.data.title,
      description: guide.data.seoDescription ?? guide.data.description,
      url: `https://chinatravelmadeeasy.com/guides/${guide.id}/`,
    })),
  },
];
---

<Base title="Guides" description={description} jsonLd={jsonLd}>
  <GuideListingPage guides={pagedGuides} currentPage={currentPage} totalPages={totalPages} />
</Base>
