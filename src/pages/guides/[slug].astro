---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((guide) => ({
    params: { slug: guide.id },
    props: { guide },
  }));
}

interface Props {
  guide: CollectionEntry<'guides'>;
}

const { guide } = Astro.props;
const { Content } = await render(guide);
const { title, description, updated, category, icon, faqs } = guide.data;

const updatedISO = updated.toISOString().split('T')[0];
const updatedHuman = updated.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const pageUrl = `https://chinatravelmadeeasy.com/guides/${guide.id}/`;

const jsonLd: object[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    description,
    dateModified: updatedISO,
    datePublished: updatedISO,
    inLanguage: 'en',
    mainEntityOfPage: pageUrl,
    author: {
      '@type': 'Person',
      name: 'Terry Chen',
      url: 'https://chinatravelmadeeasy.com/about/',
    },
    publisher: {
      '@type': 'Organization',
      name: 'China Travel Made Easy',
      url: 'https://chinatravelmadeeasy.com/',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://chinatravelmadeeasy.com/' },
      { '@type': 'ListItem', position: 2, name: 'Guides', item: 'https://chinatravelmadeeasy.com/guides/' },
      { '@type': 'ListItem', position: 3, name: title, item: pageUrl },
    ],
  },
];

if (faqs.length > 0) {
  jsonLd.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  });
}
---

<Base title={title} description={description} ogType="article" jsonLd={jsonLd}>
  <article class="mx-auto max-w-3xl px-4 sm:px-6 py-10 sm:py-14">
    <nav class="text-sm text-faint" aria-label="Breadcrumb">
      <a href="/" class="hover:text-accent">Home</a>
      <span class="mx-1.5">/</span>
      <a href="/guides/" class="hover:text-accent">Guides</a>
    </nav>

    <header class="mt-5">
      <div class="flex items-center gap-2.5">
        <span class="inline-flex w-8 h-8 items-center justify-center rounded-md bg-accent-soft text-accent">
          <Icon name={icon} class="w-4.5 h-4.5" />
        </span>
        <p class="text-[12px] font-semibold uppercase tracking-wider text-accent">{category}</p>
      </div>
      <h1 class="font-display font-bold text-3xl sm:text-4xl leading-tight mt-4">{title}</h1>
      <p class="text-soft text-lg mt-3 leading-relaxed">{description}</p>
      <p class="text-sm text-faint mt-4 pb-6 border-b border-line">
        By <a href="/about/" class="underline hover:text-accent">Terry Chen</a> ·
        Last updated <time datetime={updatedISO}>{updatedHuman}</time>
      </p>
    </header>

    <div class="prose mt-8">
      <Content />
    </div>

    {faqs.length > 0 && (
      <section class="mt-12" aria-labelledby="faq-heading">
        <h2 id="faq-heading" class="font-display font-bold text-2xl pb-3 border-b border-line">
          Frequently asked questions
        </h2>
        <dl class="mt-2 divide-y divide-line">
          {faqs.map((f) => (
            <div class="py-5">
              <dt class="font-semibold text-[1.05rem]">{f.q}</dt>
              <dd class="text-soft mt-2 leading-relaxed">{f.a}</dd>
            </div>
          ))}
        </dl>
      </section>
    )}

    <aside class="mt-12 rounded-lg border border-line bg-accent-soft/50 p-5 text-sm text-soft leading-relaxed">
      <strong class="text-ink">A note on accuracy:</strong> rules in China change quickly and
      enforcement varies by city. This guide reflects what worked as of {updatedHuman}. For
      anything visa- or entry-related, confirm with an official source (Chinese embassy,
      National Immigration Administration) before booking.
    </aside>
  </article>
</Base>
