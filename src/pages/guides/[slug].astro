---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';
import { getGuideImage } from '../../data/guideImages';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((guide) => ({
    params: { slug: guide.id },
    props: { guide },
  }));
}

interface Props {
  guide: CollectionEntry<'guides'>;
}

const { guide } = Astro.props;
const { Content } = await render(guide);
const { title, description, seoTitle, seoDescription, updated, category, icon, decision, sources, faqs, mapPlaces } = guide.data;
const metaTitle = seoTitle ?? title;
const metaDescription = seoDescription ?? description;

const updatedISO = updated.toISOString().split('T')[0];
const updatedHuman = updated.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});

const guideImage = getGuideImage(guide.id);
const pageUrl = new URL(`/guides/${guide.id}/`, Astro.site).toString();
const guideImageUrl = new URL(guideImage.src, Astro.site).toString();
const mapHandoffText = mapPlaces
  .map((place, index) => `${index + 1}. ${place.name}${place.localName ? ` / ${place.localName}` : ''} — ${place.city}${place.note ? ` — ${place.note}` : ''}`)
  .join('\n');
const mapHandoffHref = `/map-import/?title=${encodeURIComponent(`${title} places`)}&text=${encodeURIComponent(mapHandoffText)}`;

const jsonLd: object[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    description: metaDescription,
    dateModified: updatedISO,
    datePublished: updatedISO,
    image: guideImageUrl,
    inLanguage: 'en',
    mainEntityOfPage: pageUrl,
    author: {
      '@type': 'Organization',
      name: 'China Travel Made Easy',
      url: 'https://chinatravelmadeeasy.com/',
    },
    publisher: {
      '@type': 'Organization',
      name: 'China Travel Made Easy',
      url: 'https://chinatravelmadeeasy.com/',
    },
    citation: sources.map((source) => source.url),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://chinatravelmadeeasy.com/' },
      { '@type': 'ListItem', position: 2, name: 'Guides', item: 'https://chinatravelmadeeasy.com/guides/' },
      { '@type': 'ListItem', position: 3, name: title, item: pageUrl },
    ],
  },
];

if (faqs.length > 0) {
  jsonLd.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  });
}
---

<Base title={metaTitle} description={metaDescription} ogType="article" image={guideImage.src} imageAlt={guideImage.alt} jsonLd={jsonLd}>
  <article class="mx-auto max-w-3xl px-4 sm:px-6 py-10 sm:py-14">
    <nav class="flex flex-wrap items-center gap-1.5 text-sm text-faint" aria-label="Breadcrumb">
      <a href="/" class="flex min-h-9 items-center hover:text-accent">Home</a>
      <span class="mx-1.5">/</span>
      <a href="/guides/" class="flex min-h-9 items-center hover:text-accent">Guides</a>
    </nav>

    <header class="mt-5">
      <div class="flex items-center gap-2.5">
        <span class="ds-icon-tile h-8 w-8">
          <Icon name={icon} class="w-4.5 h-4.5" />
        </span>
        <p class="ds-eyebrow">{category}</p>
      </div>
      <h1 class="mt-4 text-3xl font-bold leading-tight sm:text-4xl">{title}</h1>
      <p class="text-soft text-lg mt-3 leading-relaxed">{description}</p>
      <p class="text-sm text-faint mt-4 pb-6 border-b border-line">
        China Travel Made Easy concierge desk · Last updated <time datetime={updatedISO}>{updatedHuman}</time>
        {sources.length > 0 && <> · {sources.length} primary source{sources.length === 1 ? '' : 's'} checked</>}
      </p>
    </header>

    {decision && (
      <section class="ds-panel mt-8 p-5" aria-labelledby="decision-heading">
        <p class="ds-eyebrow">Decision first</p>
        <h2 id="decision-heading" class="mt-2 text-2xl font-bold">What should I do?</h2>
        <dl class="mt-4 grid gap-4 sm:grid-cols-3">
          <div>
            <dt class="ds-tag">Best for</dt>
            <dd class="mt-2 text-sm leading-relaxed text-soft">{decision.bestFor}</dd>
          </div>
          <div>
            <dt class="ds-tag">Do this</dt>
            <dd class="mt-2 text-sm leading-relaxed text-soft">{decision.doThis}</dd>
          </div>
          <div>
            <dt class="ds-tag">Watch for</dt>
            <dd class="mt-2 text-sm leading-relaxed text-soft">{decision.watchFor}</dd>
          </div>
        </dl>
      </section>
    )}

    <figure class="ds-photo mt-8">
      <img src={guideImage.src} alt={guideImage.alt} class="h-72 w-full object-cover sm:h-96" />
    </figure>

    <div class="prose mt-8">
      <Content />
    </div>

    {mapPlaces.length > 0 && (
      <section class="ds-panel mt-12 p-5 sm:p-6" aria-labelledby="map-ready-heading">
        <p class="ds-eyebrow">From guide to map</p>
        <div class="mt-2 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <h2 id="map-ready-heading" class="text-2xl font-bold">Review the places from this guide</h2>
            <p class="mt-2 max-w-2xl text-sm leading-relaxed text-soft">
              We keep the Chinese name and city together so you can verify the right branch before opening AMap, Apple Maps, or Didi.
            </p>
          </div>
          <a href={mapHandoffHref} class="ds-button ds-button-primary shrink-0">Review {mapPlaces.length} places</a>
        </div>
        <ul class="mt-5 grid gap-3 sm:grid-cols-2">
          {mapPlaces.map((place) => (
            <li class="rounded-md border border-line bg-white p-4">
              <p class="font-semibold">{place.name}{place.localName && <> / {place.localName}</>}</p>
              <p class="mt-1 text-sm text-soft">{place.city}{place.note && <> · {place.note}</>}</p>
            </li>
          ))}
        </ul>
      </section>
    )}

    {faqs.length > 0 && (
      <section class="mt-12" aria-labelledby="faq-heading">
        <h2 id="faq-heading" class="border-b border-line pb-3 text-2xl font-bold">
          Frequently asked questions
        </h2>
        <dl class="mt-2 divide-y divide-line">
          {faqs.map((f) => (
            <div class="py-5">
              <dt class="font-semibold text-[1.05rem]">{f.q}</dt>
              <dd class="text-soft mt-2 leading-relaxed">{f.a}</dd>
            </div>
          ))}
        </dl>
      </section>
    )}

    {sources.length > 0 && (
      <section class="mt-12" aria-labelledby="sources-heading">
        <h2 id="sources-heading" class="border-b border-line pb-3 text-2xl font-bold">Sources checked</h2>
        <p class="mt-3 text-sm leading-relaxed text-soft">
          We use official or first-party sources for rules and fast-changing product details. Community reports shape the failure-mode advice, not the underlying policy.
        </p>
        <ul class="mt-4 grid gap-3">
          {sources.map((source) => (
            <li class="ds-card p-4 text-sm">
              <a href={source.url} target="_blank" rel="noopener" class="font-semibold text-ink hover:text-accent hover:underline">
                {source.title}
              </a>
              <p class="mt-1 text-faint">Checked {source.checked.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' })}</p>
            </li>
          ))}
        </ul>
      </section>
    )}

    <aside class="ds-panel mt-12 p-5 text-sm leading-relaxed text-soft">
      <strong class="text-ink">A note on accuracy:</strong> rules in China change quickly and
      enforcement varies by city. This guide reflects what worked as of {updatedHuman}. For
      anything visa- or entry-related, confirm with an official source (Chinese embassy,
      National Immigration Administration) before booking.
    </aside>
  </article>
</Base>
