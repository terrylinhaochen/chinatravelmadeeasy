---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import PinDensityPanel from '../components/PinDensityPanel.astro';
import CommunityVideoRail from '../components/CommunityVideoRail.astro';
import { destinations } from '../data/destinations';
import { getGeneratedImage } from '../data/generatedImages';
import { communityVideos } from '../data/communityVideos';
import { destinationFieldNoteHref, videoCuratedCollectionHref } from '../utils/videoEmbed.js';

const heroImage = getGeneratedImage('home:hero') ?? {
  src: '/images/curated/home-local-treasures.jpg',
  alt: 'Night street storefront with Chinese calligraphy signs and warm lantern light',
};
const homepageDestinations = destinations.slice(0, 6);
const homeVideoCache = communityVideos.map((video) => ({
  platform: video.platform,
  externalId: video.externalId,
  title: video.title,
  creator: video.creator,
  city: video.city,
  resolvedCount: video.places.filter((place) => place.resolution === 'resolved').length,
  fieldNoteHref: destinationFieldNoteHref(video),
  collectionHref: videoCuratedCollectionHref(video),
}));
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '';

const travelModes = [
  {
    title: 'Places',
    icon: 'map',
    body: 'Find entry regions and starter pins before you build the route.',
    href: '/discover/?intent=places',
    image: getGeneratedImage('home:places')?.src ?? '/images/curated/home-places.jpg',
    alt: getGeneratedImage('home:places')?.alt ?? 'Great Wall landscape in northern China',
  },
  {
    title: 'Eating',
    icon: 'bowl',
    body: 'Save food streets, tea houses, and local meals worth detouring for.',
    href: '/discover/?intent=eating',
    image: getGeneratedImage('home:eating')?.src ?? '/images/curated/home-eating.jpg',
    alt: getGeneratedImage('home:eating')?.alt ?? 'Street food stall in China',
  },
  {
    title: 'Traveling',
    icon: 'train',
    body: 'Keep trains, metros, and hard-to-find addresses tied to the same plan.',
    href: '/discover/?intent=traveling',
    image: getGeneratedImage('home:traveling')?.src ?? '/images/curated/home-traveling.jpg',
    alt: getGeneratedImage('home:traveling')?.alt ?? 'High-speed train at a China rail platform',
  },
  {
    title: 'Hospitality',
    icon: 'passport',
    body: 'Choose neighborhoods and hotels that actually work for foreign passports.',
    href: '/discover/?intent=hospitality',
    image: getGeneratedImage('home:hospitality')?.src ?? '/images/curated/home-hospitality.jpg',
    alt: getGeneratedImage('home:hospitality')?.alt ?? 'Hotel lobby in China',
  },
];

const essentialCards = [
  {
    label: 'Entry',
    title: 'Check the visa route first',
    body: 'Know whether you need a tourist visa, 30-day visa-free entry, or the 240-hour transit route before you book flights.',
    href: '/guides/china-visa-free-2026/',
    image: getGeneratedImage('guide:china-visa-free-2026')?.src ?? '/images/curated/visa-free-entry.jpg',
    alt: getGeneratedImage('guide:china-visa-free-2026')?.alt ?? 'China immigration and arrival area',
  },
  {
    label: 'Payments',
    title: 'Set up mobile payments',
    body: 'Prepare Alipay and WeChat Pay before arrival, then keep a second card or cash fallback for the places that still fail.',
    href: '/guides/alipay-wechat-pay-foreign-cards/',
    image: getGeneratedImage('guide:alipay-wechat-pay-foreign-cards')?.src ?? '/images/curated/mobile-payment.jpg',
    alt: getGeneratedImage('guide:alipay-wechat-pay-foreign-cards')?.alt ?? 'Mobile payment QR codes in China',
  },
  {
    label: 'Internet',
    title: 'Pick your phone setup',
    body: 'Verify the exact plan’s mainland routing, activation, hotspot, and app access—then keep a separate arrival fallback.',
    href: '/guides/internet-esim-vpn-blocked-apps/',
    image: getGeneratedImage('guide:internet-esim-vpn-blocked-apps')?.src ?? '/images/curated/internet-esim.jpg',
    alt: getGeneratedImage('guide:internet-esim-vpn-blocked-apps')?.alt ?? 'Smartphone store in Shenzhen for China mobile setup planning',
  },
  {
    label: 'Transport',
    title: 'Use trains, metro, and Didi',
    body: 'Book high-speed rail between cities, use metro QR codes in town, and keep Didi ready for hard addresses.',
    href: '/guides/china-high-speed-trains/',
    image: getGeneratedImage('guide:china-high-speed-trains')?.src ?? '/images/curated/high-speed-train.jpg',
    alt: getGeneratedImage('guide:china-high-speed-trains')?.alt ?? 'China railway ticket detail for train booking planning',
  },
  {
    label: 'Food',
    title: 'Eat well without Chinese',
    body: 'Resolve the right food street or stall, complete the order, and know when translation or popularity is not enough.',
    href: '/guides/street-food-night-markets/',
    image: getGeneratedImage('guide:street-food-night-markets')?.src ?? '/images/curated/street-food.jpg',
    alt: getGeneratedImage('guide:street-food-night-markets')?.alt ?? "Xi'an Muslim food street market at night",
  },
  {
    label: 'Stay',
    title: 'Book hotels that accept foreigners',
    body: 'Check passport acceptance, Chinese addresses, and neighborhood tradeoffs before the first night.',
    href: '/guides/hotels-foreigners-china/',
    image: getGeneratedImage('guide:hotels-foreigners-china')?.src ?? '/images/curated/hotel-checkin.jpg',
    alt: getGeneratedImage('guide:hotels-foreigners-china')?.alt ?? 'Hotel reception desk for China check-in planning',
  },
];
const primaryEssentialCards = essentialCards.slice(0, 3);
const extraEssentialCards = essentialCards.slice(3);

const homeFaqs = [
  {
    question: 'What can I save?',
    answer:
      'Paste a caption, OCR text, a note, or a friend list with place names. The prototype extracts candidates for you to review; it does not fetch a social post or read pixels from an image.',
  },
  {
    question: 'Who is this for?',
    answer:
      'It is built for independent travelers and backpackers who already collect pins from social posts, friends, and guides, then need a faster way to make those places usable.',
  },
  {
    question: 'Can I still use the travel guides?',
    answer:
      'Yes. The guides are there when you need practical context, but the homepage is centered on collecting, cleaning, and saving places.',
  },
  {
    question: 'Why not just keep pins in one map app?',
    answer:
      'Travel inspiration comes from too many places: screenshots, captions, shared lists, and different map apps. This keeps the list portable before you choose where to save it.',
  },
];

const description =
  'Turn scattered China travel tips into reviewed, map-ready places that keep local names when available.';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'China Travel Made Easy',
    url: 'https://chinatravelmadeeasy.com/',
    description,
    inLanguage: 'en',
    publisher: {
      '@type': 'Organization',
      name: 'China Travel Made Easy',
      url: 'https://chinatravelmadeeasy.com/',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    name: 'China Travel Made Easy homepage questions',
    mainEntity: homeFaqs.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  },
];
---

<Base title="Make China travel tips map-ready" description={description} image={heroImage.src} imageAlt={heroImage.alt} jsonLd={jsonLd}>
  <section class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-12">
    <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div class="min-w-0 max-w-xl">
        <p class="ds-eyebrow">
          Save places
        </p>
        <h1 class="mt-4 text-4xl leading-[1.02] sm:text-6xl lg:text-7xl">
          Make China travel tips map-ready.
        </h1>
        <p class="mt-5 text-lg leading-relaxed text-soft">
          Paste the caption or place list. Review the matches, keep the source context, and hand off map-ready places with the Chinese name when we can resolve it.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="#save-places" class="ds-button ds-button-primary">
            Add places
          </a>
          <a href="/discover/?intent=places" class="ds-button ds-button-secondary">
            Explore map-ready tips
          </a>
        </div>
      </div>
      <div id="heroFlipCard" class="hero-flip-card" tabindex="0">
        <div class="hero-flip-inner">
          <div class="hero-flip-face hero-flip-front">
            <img src={heroImage.src} alt={heroImage.alt} class="h-full w-full object-cover" fetchpriority="high" />
          </div>
          <div class="hero-flip-face hero-flip-back" aria-label="Pinned map preview for the hero photo">
            <div class="hero-pin-map" aria-hidden="true">
              <div class="hero-map-route"></div>
              <div class="hero-map-pin"></div>
            </div>
            <div class="hero-pin-copy">
              <p class="ds-eyebrow">Pinned from photo</p>
              <h2 class="mt-2 text-3xl leading-tight">Chongqing night street storefront</h2>
              <p class="mt-2 text-sm leading-relaxed text-soft">
                Saved from WechatIMG4641.jpg at 29.56086 N, 106.57751 E.
              </p>
              <button id="heroSavePlace" type="button" class="ds-button ds-button-dark mt-5">Review this pin</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-8 sm:px-6 sm:pb-10">
    <div class="ds-context-grid">
      {travelModes.map((mode) => (
        <a href={mode.href} class="ds-context-card group">
          <div class="ds-context-thumb">
            <img src={mode.image} alt={mode.alt} loading="lazy" />
          </div>
          <div class="p-4">
            <span class="ds-icon-tile">
              <Icon name={mode.icon} class="h-5 w-5" />
            </span>
            <h2 class="mt-4 text-2xl leading-tight group-hover:text-accent">{mode.title}</h2>
            <p class="mt-2 text-sm leading-relaxed text-soft">{mode.body}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section id="save-places" class="mx-auto max-w-6xl scroll-mt-24 px-4 py-10 sm:px-6 sm:py-12">
    <div class="ds-panel home-save-panel overflow-hidden p-5 sm:p-8">
      <div class="grid gap-5 lg:grid-cols-[0.72fr_1.28fr] lg:items-start">
        <div>
          <p class="ds-eyebrow">Add places</p>
          <h2 class="mt-2 text-3xl leading-tight sm:text-4xl">Paste a caption or list</h2>
        </div>

        <div class="grid gap-4">
          <details class="group ds-card p-0">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4">
              <div>
                <span class="ds-eyebrow">TikTok or Instagram</span>
                <span class="mt-1 block text-xl font-semibold">Add a short video link</span>
              </div>
              <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full border border-line text-sm font-bold text-soft group-open:border-accent group-open:text-accent" aria-hidden="true">
                <span class="group-open:hidden">+</span><span class="hidden group-open:inline">−</span>
              </span>
            </summary>
            <div class="border-t border-line px-5 py-4">
              <p class="text-sm leading-relaxed text-soft">Processed links open the original story, its editorial context, and the places it identifies. For an unseen link, use the caption fallback below until live ingestion is connected.</p>
              <div class="mt-4 grid gap-3 sm:grid-cols-[1fr_auto]">
                <input id="homeVideoUrl" type="url" class="ds-input text-sm" placeholder="https://www.tiktok.com/@creator/video/..." />
                <button id="homeVideoFind" type="button" class="ds-button ds-button-dark">Find places</button>
              </div>
              {turnstileSiteKey && (
                <div class="mt-3">
                  <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-size="flexible"></div>
                  <p class="mt-2 text-xs text-faint">Verification protects anonymous video submissions.</p>
                </div>
              )}
              <p id="homeVideoStatus" class="mt-3 hidden rounded-md border border-line bg-paper p-3 text-sm leading-relaxed text-soft"></p>
              <div id="homeVideoActions" class="mt-3 hidden flex flex-wrap gap-2">
                <a id="homeVideoFieldNote" href="#" class="ds-button ds-button-primary">Open story</a>
                <a id="homeVideoCollection" href="#" class="ds-button ds-button-secondary">Open city collection</a>
              </div>
            </div>
          </details>

          <label
            id="homeMapDropZone"
            for="homeMapFile"
            class="block cursor-pointer rounded-md border-2 border-dashed border-line bg-white/70 p-5 transition-colors hover:border-accent/50 sm:p-6"
          >
            <input id="homeMapFile" type="file" accept=".txt,.md,.json,text/plain,application/json" class="hidden" />
            <span class="ds-eyebrow">Upload</span>
            <span class="mt-2 block text-xl">Text export or saved list</span>
            <span id="homeMapFileName" class="mt-2 block text-sm text-soft">
              For screenshots, paste OCR text below. Images are not read in this static prototype.
            </span>
          </label>

          <textarea
            id="homeMapText"
            class="ds-input min-h-20 resize-y text-sm"
            placeholder="Paste a caption, OCR text, or one-place-per-line list..."
          ></textarea>

          <div class="flex flex-wrap justify-end gap-2">
            <button type="button" id="homeMapAnalyze" class="ds-button ds-button-dark">Extract pins</button>
          </div>

          <p id="homeMapStatus" class="hidden rounded-md border border-line bg-white p-3 text-sm leading-relaxed text-soft"></p>
          <a id="homeMapOpenSaved" href="#" target="_blank" rel="noopener" class="ds-button ds-button-primary hidden justify-self-start">Open in AMap</a>
          <div id="homeMapResults" class="hidden grid gap-3"></div>

          <div id="homeMapMapChoice" class="hidden rounded-md border border-line bg-white p-4">
            <p class="ds-eyebrow">Choose a map</p>
            <p class="mt-1 text-sm leading-relaxed text-soft">
              Pick where this place should open after sign-in.
            </p>
            <div class="mt-3 flex flex-wrap gap-2">
              <button type="button" data-map-provider="amap" class="homeMapProvider ds-button ds-button-dark">AMap</button>
              <button type="button" data-map-provider="apple" class="homeMapProvider ds-button ds-button-secondary">Apple Maps</button>
            </div>
          </div>

          <div id="homeMapSavedWorkspace" class="hidden rounded-md border border-line bg-white p-4">
            <div class="grid gap-3 sm:grid-cols-[1fr_auto] sm:items-start">
              <div>
                <p class="ds-eyebrow">Saved lists</p>
                <p class="mt-1 text-sm leading-relaxed text-soft">
                  Search the places you saved here, then remix a list back into the planner.
                </p>
              </div>
              <span class="ds-chip justify-center">Your pins</span>
            </div>
            <input
              id="homeMapSearch"
              type="search"
              class="ds-input mt-4 text-sm"
              placeholder="Search saved places..."
            />
            <div id="homeMapSavedLists" class="mt-4 grid gap-3"></div>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-10 border-t border-line pt-10 sm:mt-12 sm:pt-12">
      <CommunityVideoRail
        heading="What travelers actually did"
        intro="A harbour race, a skyline at blue hour, or a street twenty floors above another: watch the story first, then keep the places it genuinely identifies."
      />
    </div>
    <script id="homeVideoCache" type="application/json" is:inline set:html={JSON.stringify(homeVideoCache).replace(/</g, '\\u003c')}></script>
  </section>

  <section id="places" class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16">
    <div class="grid gap-6 lg:grid-cols-[0.78fr_1.22fr] lg:items-end">
      <div>
        <p class="ds-eyebrow">Where to go</p>
        <h2 class="mt-2 text-3xl font-bold leading-tight sm:text-4xl">Start with the places travelers search first</h2>
      </div>
      <p class="text-soft leading-relaxed">
        The homepage stays focused on the four highest-intent entry regions. The full destination index
        lists every province-level planning region and links each one to guide recommendations.
      </p>
    </div>
    <div class="home-destination-grid mt-8">
      {homepageDestinations.map((destination) => (
        <a href={`/regions/${destination.slug}/`} class="home-destination-card ds-card-link group overflow-hidden">
          <div class="home-destination-thumb overflow-hidden bg-surface-strong">
            <img src={destination.image.src} alt={destination.image.alt} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
          </div>
          <div class="home-destination-copy p-5">
            <p class="ds-tag">{destination.type}</p>
            <h3 class="mt-2 text-2xl font-bold group-hover:text-accent">{destination.name}</h3>
            <p class="destination-summary mt-2 text-sm leading-relaxed text-soft">{destination.summary}</p>
          </div>
        </a>
      ))}
    </div>
    <div class="mt-6">
      <a href="/regions/" class="ds-button ds-button-secondary">
        View all destinations
        <Icon name="arrow" class="h-3.5 w-3.5" />
      </a>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-12 sm:px-6 sm:pb-16">
    <PinDensityPanel
      eyebrow="Explored map"
      title="Your saved-place atlas"
      description="Darker pixels show where pins and traveler lists cluster. Built to feel like a shareable map of what you have explored."
      class="bg-card"
    />
  </section>

  <section class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="grid gap-6 border-t border-line pt-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
      <div>
        <p class="ds-eyebrow">Travel essentials</p>
        <h2 class="mt-2 text-3xl font-bold leading-tight sm:text-4xl">Fix the basics first</h2>
      </div>
      <p class="leading-relaxed text-soft">
        Visa rules, mobile payments, eSIMs, hotels, and train bookings are the practical layer underneath
        every good China trip.
      </p>
    </div>
    <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {primaryEssentialCards.map((card) => (
        <a href={card.href} class="ds-card-link group overflow-hidden">
          <div class="aspect-[16/9] overflow-hidden bg-surface-strong">
            <img src={card.image} alt={card.alt} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
          </div>
          <div class="p-5">
            <p class="ds-tag text-accent">{card.label}</p>
            <h3 class="mt-2 text-2xl font-bold group-hover:text-accent">{card.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-soft">{card.body}</p>
          </div>
        </a>
      ))}
    </div>
    <div id="essentialMore" class="mt-4 hidden grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {extraEssentialCards.map((card) => (
        <a href={card.href} class="ds-card-link group overflow-hidden">
          <div class="aspect-[16/9] overflow-hidden bg-surface-strong">
            <img src={card.image} alt={card.alt} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
          </div>
          <div class="p-5">
            <p class="ds-tag text-accent">{card.label}</p>
            <h3 class="mt-2 text-2xl font-bold group-hover:text-accent">{card.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-soft">{card.body}</p>
          </div>
        </a>
      ))}
    </div>
    <div class="mt-5">
      <button
        id="essentialToggle"
        type="button"
        class="ds-button ds-button-secondary"
        aria-expanded="false"
        aria-controls="essentialMore"
      >
        Expand essentials
      </button>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16">
    <div class="border-t border-line pt-8">
      <p class="ds-eyebrow">FAQ</p>
      <h2 class="mt-2 text-3xl font-bold leading-tight sm:text-4xl">Quick answers before you save places</h2>
      <div class="mt-6 grid gap-3">
        {homeFaqs.map((item) => (
          <details class="group ds-card p-0">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4">
              <h3 class="text-xl font-bold leading-snug">{item.question}</h3>
              <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full border border-line text-sm font-bold text-soft group-open:border-accent group-open:text-accent">
                <span class="group-open:hidden">+</span>
                <span class="hidden group-open:inline">-</span>
              </span>
            </summary>
            <p class="px-5 pb-5 leading-relaxed text-soft">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  {turnstileSiteKey && <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>}

</Base>

<style>
  .hero-flip-card {
    position: relative;
    min-height: 408px;
    perspective: 1200px;
    outline: none;
  }

  .hero-flip-inner {
    position: relative;
    min-height: 408px;
    transform-style: preserve-3d;
    transition: transform 520ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero-flip-card:hover .hero-flip-inner,
  .hero-flip-card:focus-within .hero-flip-inner,
  .hero-flip-card.is-flipped .hero-flip-inner {
    transform: rotateY(180deg);
  }

  .hero-flip-face {
    min-height: 408px;
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: 24px;
    background: var(--color-surface-strong);
    backface-visibility: hidden;
  }

  .hero-flip-front {
    position: relative;
  }

  .hero-flip-back {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-rows: 8.75rem auto;
    align-content: start;
    padding: 0.75rem;
    transform: rotateY(180deg);
  }

  .hero-pin-map {
    position: relative;
    min-height: 8.75rem;
    overflow: hidden;
    border-radius: 18px;
    background:
      linear-gradient(90deg, rgb(231 229 228 / 0.72) 1px, transparent 1px),
      linear-gradient(0deg, rgb(231 229 228 / 0.72) 1px, transparent 1px),
      radial-gradient(circle at 66% 36%, rgb(140 47 34 / 0.16), transparent 22%),
      linear-gradient(135deg, #f8f7f5, #edeae5);
    background-size:
      42px 42px,
      42px 42px,
      auto,
      auto;
  }

  .hero-map-route {
    position: absolute;
    inset: 26% 14% 30% 16%;
    border-bottom: 3px solid rgb(140 47 34 / 0.42);
    border-left: 3px solid rgb(140 47 34 / 0.18);
    border-radius: 999px;
    transform: rotate(-8deg);
  }

  .hero-map-pin {
    position: absolute;
    top: 31%;
    left: 61%;
    width: 1.8rem;
    height: 1.8rem;
    border: 4px solid white;
    border-radius: 999px 999px 999px 0;
    background: #8c2f22;
    box-shadow: 0 18px 28px rgb(12 10 9 / 0.22);
    transform: rotate(-45deg);
  }

  .hero-map-pin::after {
    content: "";
    position: absolute;
    inset: 0.32rem;
    border-radius: 999px;
    background: white;
  }

  .hero-pin-copy {
    padding: 1rem 0.25rem 0.25rem;
  }

  .home-destination-grid {
    display: grid;
    gap: 1rem;
  }

  .home-destination-thumb {
    aspect-ratio: 4 / 3;
  }

  @media (min-width: 640px) {
    .hero-flip-card,
    .hero-flip-inner,
    .hero-flip-face {
      min-height: 380px;
    }

    .hero-flip-back {
      grid-template-rows: minmax(11rem, 1fr) auto;
    }

    .home-destination-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .hero-flip-card,
    .hero-flip-inner,
    .hero-flip-face {
      min-height: 440px;
    }

    .home-destination-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 639px) {
    .home-destination-card {
      display: grid;
      grid-template-columns: minmax(7.5rem, 34%) minmax(0, 1fr);
      min-height: 9rem;
    }

    .home-destination-thumb {
      aspect-ratio: auto;
      height: 100%;
      min-height: 9rem;
    }

    .home-destination-copy {
      padding: 1rem;
    }

    .home-destination-card h3 {
      font-size: 1.35rem;
      line-height: 1.08;
    }

    .destination-summary {
      display: -webkit-box;
      overflow: hidden;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
    }
  }
</style>

<script>
  import { DEFAULT_MAINLAND_MAP_PROVIDER, displayName, extractTripPlaces, mapProviderUrl, normalizeSource } from '../utils/placeExtraction.js';
  import { getSavedPinLists, getUser, savePinList } from '../utils/localPrototypeState.js';
  import { getVideoStatus, submitVideo } from '../utils/communityApi.js';
  import { parseShortFormVideoUrl } from '../utils/videoEmbed.js';

  const homeVideoUrl = document.querySelector('#homeVideoUrl');
  const homeVideoFind = document.querySelector('#homeVideoFind');
  const homeVideoStatus = document.querySelector('#homeVideoStatus');
  const homeVideoActions = document.querySelector('#homeVideoActions');
  const homeVideoFieldNote = document.querySelector('#homeVideoFieldNote');
  const homeVideoCollection = document.querySelector('#homeVideoCollection');
  const homeVideoCache = JSON.parse(document.querySelector('#homeVideoCache')?.textContent || '[]');
  const homeMapDropZone = document.querySelector('#homeMapDropZone');
  const homeMapFile = document.querySelector('#homeMapFile');
  const homeMapFileName = document.querySelector('#homeMapFileName');
  const homeMapText = document.querySelector('#homeMapText');
  const homeMapAnalyze = document.querySelector('#homeMapAnalyze');
  const homeMapStatus = document.querySelector('#homeMapStatus');
  const homeMapOpenSaved = document.querySelector('#homeMapOpenSaved');
  const homeMapResults = document.querySelector('#homeMapResults');
  const homeMapMapChoice = document.querySelector('#homeMapMapChoice');
  const homeMapSearch = document.querySelector('#homeMapSearch');
  const homeMapSavedWorkspace = document.querySelector('#homeMapSavedWorkspace');
  const homeMapSavedLists = document.querySelector('#homeMapSavedLists');
  const homeMapProviderButtons = document.querySelectorAll('.homeMapProvider');
  const heroFlipCard = document.querySelector('#heroFlipCard');
  const heroSavePlace = document.querySelector('#heroSavePlace');
  const essentialMore = document.querySelector('#essentialMore');
  const essentialToggle = document.querySelector('#essentialToggle');
  const heroPhotoPlace = {
    name: 'Chongqing night street storefront',
    city: 'Chongqing',
    category: 'See',
    confidence: 'coordinate pin',
    latitude: 29.56086,
    longitude: 106.57751,
    note: 'Saved from WechatIMG4641.jpg at 29.56086 N, 106.57751 E.',
  };
  const homeMapPendingKey = 'ctme-pending-home-map-save';
  let homeMapProvider = DEFAULT_MAINLAND_MAP_PROVIDER;
  let homeMapFileText = '';
  let homeMapPlaces = [];
  let homeMapPendingPlace = null;
  let homeMapDisplayedSaved = [];

  homeVideoFind.addEventListener('click', findHomeVideo);
  homeVideoUrl.addEventListener('keydown', (event) => {
    if (event.key === 'Enter') findHomeVideo();
  });

  essentialToggle?.addEventListener('click', () => {
    const expanded = essentialToggle.getAttribute('aria-expanded') === 'true';
    essentialToggle.setAttribute('aria-expanded', String(!expanded));
    essentialToggle.textContent = expanded ? 'Expand essentials' : 'Collapse essentials';
    essentialMore?.classList.toggle('hidden', expanded);
  });

  homeMapProviderButtons.forEach((button) => {
    button.addEventListener('click', () => {
      homeMapProvider = button.dataset.mapProvider;
      syncHomeMapProviderButtons();
      if (homeMapPendingPlace) requestHomeMapSignIn(homeMapPendingPlace);
    });
  });

  heroFlipCard.addEventListener('click', (event) => {
    if (event.target instanceof Element && event.target.closest('button')) return;
    heroFlipCard.classList.toggle('is-flipped');
  });
  heroSavePlace.addEventListener('click', () => {
    showHomeMapMapChoice(heroPhotoPlace);
    document.querySelector('#save-places')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  homeMapFile.addEventListener('change', () => readHomeMapFile(homeMapFile.files?.[0]));
  ['dragenter', 'dragover'].forEach((eventName) => {
    homeMapDropZone.addEventListener(eventName, (event) => {
      event.preventDefault();
      homeMapDropZone.classList.add('border-accent');
    });
  });
  ['dragleave', 'drop'].forEach((eventName) => {
    homeMapDropZone.addEventListener(eventName, (event) => {
      event.preventDefault();
      homeMapDropZone.classList.remove('border-accent');
    });
  });
  homeMapDropZone.addEventListener('drop', (event) => readHomeMapFile(event.dataTransfer?.files?.[0]));

  homeMapAnalyze.addEventListener('click', analyzeHomeMapInput);
  homeMapSearch.addEventListener('input', () => renderHomeMapSavedLists(homeMapSearch.value));
  syncHomeMapProviderButtons();
  renderHomeMapSavedLists();
  resumePendingHomeMapSave();

  function readHomeMapFile(file) {
    if (!file) return;
    homeMapFileName.textContent = file.name;
    homeMapFileText = file.name.replace(/\.[^.]+$/, '').replace(/[-_]+/g, ' ');
    if (/^text\/|markdown|json/i.test(file.type) || /\.(txt|md|json)$/i.test(file.name)) {
      const reader = new FileReader();
      reader.addEventListener('load', () => {
        homeMapFileText = [homeMapFileText, String(reader.result || '')].join('\n');
        showHomeMapStatus('File loaded. Click Save to maps when ready.', false);
      });
      reader.readAsText(file);
    }
  }

  async function findHomeVideo() {
    homeVideoActions.classList.add('hidden');
    homeVideoCollection.classList.add('hidden');
    let parsed;
    try {
      parsed = parseShortFormVideoUrl(homeVideoUrl.value);
    } catch (error) {
      const code = error instanceof Error ? error.message : 'invalid_video_url';
      const message = code === 'use_full_tiktok_url'
        ? 'Use the full TikTok post URL. Short redirect links cannot be matched inside this static build.'
        : code === 'use_instagram_reel_url'
          ? 'Use a full Instagram Reel or post URL.'
          : code === 'unsupported_video_platform'
            ? 'Use a TikTok or Instagram Reel link. YouTube is intentionally not supported.'
            : 'Enter a complete TikTok or Instagram Reel URL.';
      showHomeVideoStatus(message, true);
      return;
    }
    const match = homeVideoCache.find((video) => video.platform === parsed.platform && video.externalId === parsed.externalId);
    if (!match) {
      homeVideoFind.disabled = true;
      homeVideoFind.textContent = 'Checking…';
      const turnstileToken = document.querySelector('[name="cf-turnstile-response"]')?.value || '';
      const result = await submitVideo(homeVideoUrl.value, turnstileToken);
      homeVideoFind.disabled = false;
      homeVideoFind.textContent = 'Find places';
      if (!result.configured) {
        showHomeVideoStatus('This link format is supported, but it is not in the processed cache and live ingestion is not connected in this build. Paste the caption, OCR text, or named places below to review them now.', false);
        homeMapText.focus();
        return;
      }
      if (result.error || result.data?.error) {
        const code = result.data?.error || 'submission_failed';
        const message = code === 'turnstile_failed'
          ? 'Complete the verification check, then submit the link again.'
          : code === 'rate_limited'
            ? 'Submission limit reached. Try again after the displayed retry window.'
            : 'The source could not be queued safely. Paste its caption or named places below for manual review.';
        showHomeVideoStatus(message, true);
        return;
      }
      const status = result.data?.status;
      if (status === 'published' && result.data?.slug) {
        showHomeVideoStatus('This source has passed place review. Open its destination story to inspect the evidence before saving.', false);
        homeVideoFieldNote.href = `/videos/${result.data.slug}/`;
        homeVideoActions.classList.remove('hidden');
        return;
      }
      if (status === 'rejected' || status === 'removed') {
        showHomeVideoStatus('This source is unavailable or did not pass the publication checks. No place was added.', true);
        return;
      }
      showHomeVideoStatus('Source accepted for official metadata review. No pin has been added; place evidence and branch identity still have to pass review.', false);
      if (result.data?.videoId) pollHomeVideoStatus(result.data.videoId, 0);
      return;
    }
    const placeCopy = match.resolvedCount
      ? match.resolvedCount + ' identified ' + (match.resolvedCount === 1 ? 'place' : 'places')
      : 'a useful travel idea, but no identified venue yet';
    showHomeVideoStatus('Already processed: ' + match.title + ' by ' + match.creator + ' · ' + placeCopy + '.', false);
    homeVideoFieldNote.href = match.fieldNoteHref;
    homeVideoActions.classList.remove('hidden');
    if (match.collectionHref) {
      homeVideoCollection.href = match.collectionHref;
      homeVideoCollection.classList.remove('hidden');
    }
  }

  async function pollHomeVideoStatus(videoId, attempt) {
    if (attempt >= 5) return;
    window.setTimeout(async () => {
      const result = await getVideoStatus(videoId);
      const state = result.data;
      if (!result.configured || result.error || !state) return;
      if (state.status === 'published') {
        showHomeVideoStatus(`Place review complete: ${state.places?.length || 0} grounded ${state.places?.length === 1 ? 'place' : 'places'} ready.`, false);
        if (state.slug) {
          homeVideoFieldNote.href = `/videos/${state.slug}/`;
          homeVideoActions.classList.remove('hidden');
        }
        return;
      }
      if (state.status === 'rejected' || state.stage === 'failed') {
        showHomeVideoStatus('The official source was unavailable or failed a terminal check. No place was added.', true);
        return;
      }
      if (state.stage === 'metadata_ready') {
        showHomeVideoStatus('Official source metadata is ready. Place extraction and branch verification are still pending; no pin has been published.', false);
        return;
      }
      if (state.stage === 'retryable') {
        showHomeVideoStatus('The platform is temporarily unavailable. The source remains queued for a controlled retry; no pin has been added.', false);
      }
      pollHomeVideoStatus(videoId, attempt + 1);
    }, 3000);
  }

  function showHomeVideoStatus(message, isError) {
    homeVideoStatus.textContent = message;
    homeVideoStatus.classList.remove('hidden');
    homeVideoStatus.classList.toggle('border-accent', Boolean(isError));
  }

  function analyzeHomeMapInput() {
    const text = [homeMapText.value, homeMapFileText].filter(Boolean).join('\n');
    if (!text.trim()) {
      showHomeMapStatus('Drop a file or paste a caption first.', true);
      return;
    }
    const result = extractTripPlaces(normalizeSource({ text }));
    homeMapPlaces = result.places;
    homeMapPendingPlace = null;
    homeMapMapChoice.classList.add('hidden');
    homeMapOpenSaved.classList.add('hidden');
    if (!homeMapPlaces.length) {
      homeMapResults.classList.add('hidden');
      showHomeMapStatus('No clear place found yet. Add a city and place name, then try again.', true);
      return;
    }
    showHomeMapStatus('Found ' + homeMapPlaces.length + ' place' + (homeMapPlaces.length === 1 ? '' : 's') + '. Review the result before saving.', false);
    renderHomeMapResults();
  }

  function renderHomeMapResults() {
    homeMapResults.classList.remove('hidden');
    homeMapResults.innerHTML = homeMapPlaces.map((place, index) => (
      '<article class="ds-card p-4">' +
        '<p class="ds-tag">' + escapeHomeMapHtml(place.category || 'Place') + '</p>' +
        '<h3 class="mt-1 text-2xl font-bold">' + escapeHomeMapHtml(displayName(place)) + '</h3>' +
        '<p class="mt-2 text-sm leading-relaxed text-soft">' + escapeHomeMapHtml(place.note || 'Found in the uploaded note.') + '</p>' +
        '<div class="mt-4 flex flex-wrap gap-2">' +
          '<button type="button" data-home-map-save="' + index + '" class="ds-button ds-button-dark">Save to maps</button>' +
        '</div>' +
      '</article>'
    )).join('');
    document.querySelectorAll('[data-home-map-save]').forEach((button) => {
      button.addEventListener('click', () => showHomeMapMapChoice(homeMapPlaces[Number(button.dataset.homeMapSave)]));
    });
  }

  function showHomeMapMapChoice(item) {
    homeMapPendingPlace = item;
    homeMapMapChoice.classList.remove('hidden');
    homeMapOpenSaved.classList.add('hidden');
    showHomeMapStatus('Choose a map for ' + displaySaveName(item) + '. AMap is the mainland default; Apple Maps remains available as a second check.', false);
  }

  async function requestHomeMapSignIn(item) {
    homeMapPendingPlace = item;
    const pending = { clientRequestId: crypto.randomUUID(), saveItem: item, mapProvider: homeMapProvider };
    localStorage.setItem(homeMapPendingKey, JSON.stringify(pending));
    const user = await window.ctmeRequireUser('save this reviewed place and return to its map handoff');
    if (!user) {
      showHomeMapStatus('The place is staged. Complete the email link to save it, or close sign-in to keep reviewing.', false);
      return;
    }
    saveHomeMapPlace(item, true, pending.clientRequestId, pending.mapProvider);
    localStorage.removeItem(homeMapPendingKey);
  }

  function saveHomeMapPlace(saveItem, openAfterSave, clientRequestId = crypto.randomUUID(), provider = homeMapProvider) {
    const user = getHomeMapUser();
    if (!user) {
      requestHomeMapSignIn(saveItem);
      return;
    }
    const places = placesForSave(saveItem);
    const firstPlace = places[0];
    const savedItem = {
      id: clientRequestId,
      clientRequestId,
      name: displaySaveName(saveItem),
      platform: 'Homepage upload',
      savedAt: new Date().toISOString(),
      savedBy: user.email,
      mapProvider: provider,
      places,
    };
    savePinList(savedItem);
    showHomeMapStatus('Saved to your trip list' + (openAfterSave ? '. Opening ' + mapProviderName(provider) + '.' : '. Continue with the map handoff below.'), false);
    homeMapPendingPlace = null;
    renderHomeMapSavedLists(homeMapSearch.value);
    if (!firstPlace) return;
    const handoffUrl = mapProviderUrl(provider, firstPlace);
    if (openAfterSave) {
      window.open(handoffUrl, '_blank', 'noopener');
      return;
    }
    homeMapOpenSaved.href = handoffUrl;
    homeMapOpenSaved.textContent = 'Open in ' + mapProviderName(provider);
    homeMapOpenSaved.classList.remove('hidden');
  }

  function showHomeMapStatus(message, isError) {
    homeMapStatus.textContent = message;
    homeMapStatus.classList.remove('hidden');
    homeMapStatus.classList.toggle('border-accent', Boolean(isError));
  }
  function syncHomeMapProviderButtons() {
    homeMapProviderButtons.forEach((item) => {
      const active = item.dataset.mapProvider === homeMapProvider;
      item.classList.toggle('ds-button-dark', active);
      item.classList.toggle('ds-button-secondary', !active);
    });
  }
  function resumePendingHomeMapSave() {
    const user = getHomeMapUser();
    if (!user) return;
    let pending = null;
    try { pending = JSON.parse(localStorage.getItem(homeMapPendingKey) || 'null'); } catch { pending = null; }
    if (!pending?.saveItem || !pending?.clientRequestId) return;
    homeMapProvider = pending.mapProvider === 'apple' ? 'apple' : DEFAULT_MAINLAND_MAP_PROVIDER;
    syncHomeMapProviderButtons();
    saveHomeMapPlace(pending.saveItem, false, pending.clientRequestId, homeMapProvider);
    localStorage.removeItem(homeMapPendingKey);
  }
  function mapProviderName(provider = homeMapProvider) { return provider === 'amap' ? 'AMap' : 'Apple Maps'; }
  function placesForSave(item) { return Array.isArray(item?.places) ? item.places : [item].filter(Boolean); }
  function displaySaveName(item) { return item?.places ? item.name : displayName(item); }
  function getHomeMapUser() { return getUser(); }
  function getHomeMapSaved() { return getSavedPinLists(); }
  function renderHomeMapSavedLists(query) {
    const saved = getHomeMapSaved();
    homeMapDisplayedSaved = filterHomeMapSaved(saved, query);
    if (!saved.length) {
      homeMapSavedWorkspace.classList.add('hidden');
      homeMapSavedLists.innerHTML = '<p class="rounded-md border border-line bg-paper p-3 text-sm leading-relaxed text-soft">Saved and shared place lists appear here after sign-in.</p>';
      return;
    }
    homeMapSavedWorkspace.classList.remove('hidden');
    if (!homeMapDisplayedSaved.length) {
      homeMapSavedLists.innerHTML = '<p class="rounded-md border border-line bg-paper p-3 text-sm leading-relaxed text-soft">No saved list matches that search yet. Try food, metro, neighborhood, or first trip.</p>';
      return;
    }
    homeMapSavedLists.innerHTML = homeMapDisplayedSaved.map((item, index) => (
      '<article class="rounded-md border border-line bg-paper p-3">' +
        '<div class="grid gap-3 sm:grid-cols-[1fr_auto] sm:items-start">' +
          '<div>' +
            '<p class="ds-tag">Saved list</p>' +
            '<h3 class="mt-1 text-xl font-bold">' + escapeHomeMapHtml(item.name || 'Saved places') + '</h3>' +
            '<p class="mt-1 text-sm leading-relaxed text-soft">' + escapeHomeMapHtml(summarizeHomeMapItem(item)) + '</p>' +
          '</div>' +
          '<div class="flex flex-wrap gap-2 sm:justify-end">' +
            '<button type="button" data-home-map-remix="' + index + '" class="ds-button ds-button-dark min-h-0 px-3 py-2 text-sm">Remix</button>' +
            '<button type="button" data-home-map-copy="' + index + '" class="ds-button ds-button-secondary min-h-0 px-3 py-2 text-sm">Copy</button>' +
          '</div>' +
        '</div>' +
      '</article>'
    )).join('');
    document.querySelectorAll('[data-home-map-remix]').forEach((button) => {
      button.addEventListener('click', () => remixHomeMapList(homeMapDisplayedSaved[Number(button.dataset.homeMapRemix)]));
    });
    document.querySelectorAll('[data-home-map-copy]').forEach((button) => {
      button.addEventListener('click', () => copyHomeMapList(homeMapDisplayedSaved[Number(button.dataset.homeMapCopy)]));
    });
  }
  function filterHomeMapSaved(saved, query) {
    const terms = expandHomeMapQuery(query);
    if (!terms.length) return saved.slice(0, 4);
    return saved.filter((item) => {
      const haystack = [
        item.name,
        item.platform,
        item.mapProvider,
        ...(item.places || []).flatMap((place) => [place.name, place.city, place.category, place.note]),
      ].join(' ').toLowerCase();
      return terms.some((term) => haystack.includes(term));
    }).slice(0, 6);
  }
  function expandHomeMapQuery(query) {
    const terms = String(query || '').toLowerCase().split(/[^a-z0-9\u4e00-\u9fff]+/).filter(Boolean);
    const hints = {
      cheap: ['cheap', 'budget', 'street', 'market', 'snack'],
      food: ['food', 'eat', 'restaurant', 'dumpling', 'bao', 'tea', 'market'],
      metro: ['metro', 'station', 'subway', 'transport'],
      neighborhood: ['neighborhood', 'lane', 'road', 'hutong', 'street'],
      rainy: ['rainy', 'museum', 'tea', 'indoor'],
      classic: ['classic', 'bund', 'great', 'wall', 'forbidden', 'first'],
    };
    return Array.from(new Set(terms.flatMap((term) => hints[term] || [term])));
  }
  function summarizeHomeMapItem(item) {
    const places = item.places || [];
    const names = places.map(displayName).slice(0, 3).join(', ');
    return names ? names + (places.length > 3 ? ' +' + (places.length - 3) + ' more' : '') : 'Ready to remix into a new trip list.';
  }
  function remixHomeMapList(item) {
    if (!item) return;
    homeMapText.value = (item.places || []).map((place) => displayName(place)).join(', ');
    homeMapFileText = '';
    showHomeMapStatus('Remix loaded. Add or remove places, then save to maps again.', false);
    homeMapText.focus();
  }
  function copyHomeMapList(item) {
    if (!item) return;
    const text = (item.places || []).map((place) => displayName(place)).join('\n');
    if (navigator.clipboard && text) {
      navigator.clipboard.writeText(text);
      showHomeMapStatus('Copied list text. Share it or paste it into a new plan.', false);
    } else {
      showHomeMapStatus('No place text to copy yet.', true);
    }
  }
  function escapeHomeMapHtml(value) {
    return String(value || '').replace(/[&<>"]/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[char]));
  }
</script>

<style>
  summary::-webkit-details-marker {
    display: none;
  }

</style>
