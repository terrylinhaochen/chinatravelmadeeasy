---
import Base from '../layouts/Base.astro';
import GuideCard from '../components/GuideCard.astro';
import Icon from '../components/Icon.astro';
import { getCollection } from 'astro:content';

const guides = (await getCollection('guides')).sort(
  (a, b) => a.data.order - b.data.order
);

const guideById = Object.fromEntries(guides.map((guide) => [guide.id, guide]));

const places = [
  {
    name: 'Beijing',
    image: '/images/great-wall.jpg',
    alt: 'The Great Wall of China curving through mountain ridges near Beijing',
    kicker: 'Imperial history + hutongs',
    body: 'Forbidden City, Mutianyu Great Wall, neighborhood lanes, breakfast carts, and parks where daily life starts before 8am.',
    href: '/guides/7-day-china-itinerary/',
  },
  {
    name: 'Shanghai',
    image: '/images/shanghai-skyline.jpg',
    alt: 'Shanghai skyline glowing at night across the Huangpu River',
    kicker: 'Arrival city + food streets',
    body: 'The easiest first landing: skyline walks, longtang lanes, excellent hotels, train access, and the most foreigner-friendly logistics.',
    href: '/guides/neighborhoods-beyond-landmarks/',
  },
  {
    name: "Xi'an",
    image: '/images/china-high-speed-train.jpg',
    alt: 'A Chinese high-speed train waiting at a bright station platform',
    kicker: 'Ancient capital by train',
    body: 'Terracotta Warriors, city walls, Muslim Quarter snacks, and the classic high-speed rail link between Beijing and Shanghai.',
    href: '/guides/china-high-speed-trains/',
  },
  {
    name: 'Chengdu',
    image: '/images/china-street-food.jpg',
    alt: 'A street food stall in China with steam rising from the counter at night',
    kicker: 'Tea, spice, slow mornings',
    body: 'Teahouses, street snacks, residential food streets, parks, and a slower version of urban China that travelers remember.',
    href: '/guides/tea-houses-and-rituals/',
  },
];

const travelModes = [
  {
    title: 'Places',
    icon: 'map',
    body: 'Where to base, what to skip, and how Beijing, Shanghai, Xi\'an, and Chengdu fit together.',
    href: '/guides/7-day-china-itinerary/',
    color: 'bg-[#e8f0e1] text-[#496334]',
  },
  {
    title: 'Eating',
    icon: 'bowl',
    body: 'Street food, QR menus, spice levels, allergy cards, tea houses, and where tourists overpay.',
    href: '/guides/street-food-night-markets/',
    color: 'bg-[#fff0dc] text-[#8c571d]',
  },
  {
    title: 'Traveling',
    icon: 'train',
    body: 'High-speed rail, Didi, metro QR codes, airport pickup, and how to move without Chinese.',
    href: '/guides/china-high-speed-trains/',
    color: 'bg-[#e6f0f5] text-[#315d73]',
  },
  {
    title: 'Hospitality',
    icon: 'passport',
    body: 'Hotels that accept foreign passports, neighborhoods to stay in, and booking-platform traps.',
    href: '/guides/hotels-foreigners-china/',
    color: 'bg-[#f7e7e4] text-accent',
  },
];

const crowdPicks = [
  {
    label: 'Crowd signal',
    title: 'Travelers worry about visas too late',
    body: 'The fix is not a long immigration essay. First determine whether you qualify for 30-day visa-free entry or the 240-hour transit route, then book flights that match the rule.',
    href: '/guides/china-visa-free-2026/',
  },
  {
    label: 'Crowd signal',
    title: 'Payments are the real day-one failure',
    body: 'Set up Alipay and WeChat Pay before the airport. If your card or passport verification fails after landing, every taxi, snack stall, and metro ride gets harder.',
    href: '/guides/alipay-wechat-pay-foreign-cards/',
  },
  {
    label: 'Crowd signal',
    title: 'The best food is usually not the famous market',
    body: 'Walk two streets away from the landmark, look for local queues, point at what is being cooked hot, and pay with a QR code.',
    href: '/guides/street-food-night-markets/',
  },
];

const essentials = [
  guideById['china-pre-departure-checklist'],
  guideById['internet-esim-vpn-blocked-apps'],
  guideById['translation-language-survival'],
  guideById['food-ordering-dietary'],
].filter(Boolean);

const description =
  'A Lonely Planet-style China travel guide built around authentic, crowd-vetted planning questions: places, eating, transport, hotels, payments, visas, internet, and language.';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'China Travel Made Easy',
    url: 'https://chinatravelmadeeasy.com/',
    description,
    inLanguage: 'en',
    publisher: {
      '@type': 'Organization',
      name: 'China Travel Made Easy',
      url: 'https://chinatravelmadeeasy.com/',
    },
  },
];
---

<Base title="China Travel Made Easy — crowd-vetted China travel guide" description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-5xl px-4 py-10 sm:px-6 sm:py-14">
    <div class="grid gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-end">
      <div>
        <p class="text-[12px] font-semibold uppercase tracking-[0.16em] text-accent">
          China travel guide · Crowd-vetted planning
        </p>
        <h1 class="mt-4 font-display text-5xl font-bold leading-none sm:text-7xl lg:text-8xl">
          China
        </h1>
        <p class="mt-5 max-w-xl text-lg leading-relaxed text-soft sm:text-xl">
          Where to go, what to eat, how to travel, where to stay, and which practical setup steps
          matter before you fly.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="#places" class="rounded-md bg-ink px-4 py-2.5 text-sm font-semibold text-white hover:bg-accent">
            Explore places
          </a>
          <a href="/guides/china-pre-departure-checklist/" class="rounded-md border border-line bg-paper px-4 py-2.5 text-sm font-semibold text-ink hover:border-accent/50 hover:text-accent">
            Start planning
          </a>
        </div>
      </div>
      <div class="overflow-hidden rounded-lg border border-line bg-card">
        <img src="/images/shanghai-skyline.jpg" alt="Shanghai skyline glowing at night" class="h-[260px] w-full object-cover sm:h-[360px] lg:h-[420px]" fetchpriority="high" />
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 sm:px-6">
    <div class="rounded-lg border border-line bg-[#f4f0e8] p-3 sm:p-4">
      <div class="grid gap-3 sm:grid-cols-2">
        {travelModes.map((mode) => (
          <a href={mode.href} class="group rounded-lg border border-line bg-white p-5 transition-colors hover:border-accent/50">
            <span class={`inline-flex h-10 w-10 items-center justify-center rounded-md ${mode.color}`}>
              <Icon name={mode.icon} class="h-5 w-5" />
            </span>
            <h2 class="mt-3 font-display text-xl font-bold group-hover:text-accent">{mode.title}</h2>
            <p class="mt-2 text-sm leading-relaxed text-soft">{mode.body}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="places" class="mx-auto max-w-5xl px-4 py-12 sm:px-6 sm:py-16">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-[12px] font-semibold uppercase tracking-[0.16em] text-accent">Where to go</p>
        <h2 class="mt-2 font-display text-3xl font-bold leading-tight sm:text-4xl">China’s first-trip places, made simple</h2>
      </div>
      <a href="/guides/7-day-china-itinerary/" class="inline-flex items-center gap-2 text-sm font-semibold text-accent hover:text-accent-dark">
        See the 7-day route
        <Icon name="arrow" class="h-3.5 w-3.5" />
      </a>
    </div>
    <div class="mt-8 grid gap-5 sm:grid-cols-2">
      {places.map((place) => (
        <a href={place.href} class="group overflow-hidden rounded-lg border border-line bg-card transition-all hover:border-accent/50 hover:shadow-[0_12px_30px_rgba(33,29,25,0.12)]">
          <div class="aspect-[16/10] overflow-hidden bg-line">
            <img src={place.image} alt={place.alt} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
          <div class="p-5">
            <p class="text-[11px] font-semibold uppercase tracking-wider text-faint">{place.kicker}</p>
            <h3 class="mt-1 font-display text-2xl font-bold group-hover:text-accent">{place.name}</h3>
            <p class="mt-2 text-sm leading-relaxed text-soft">{place.body}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 sm:px-6">
    <div class="grid gap-8 rounded-lg bg-ink px-5 py-10 text-white sm:px-8 lg:grid-cols-[0.82fr_1.18fr] lg:py-12">
      <div>
        <p class="text-[12px] font-semibold uppercase tracking-[0.16em] text-[#f2c36d]">Authentic crowd-vetted opinions</p>
        <h2 class="mt-2 font-display text-3xl font-bold leading-tight sm:text-4xl">What travelers keep learning the hard way</h2>
        <p class="mt-4 leading-relaxed text-white/75">
          The guide is organized around repeated planning questions and field reports: the advice
          people wish they had before the first taxi, first train station, first hotel desk, or
          first untranslated menu.
        </p>
      </div>
      <div class="grid gap-4">
        {crowdPicks.map((pick) => (
          <a href={pick.href} class="group rounded-lg border border-white/15 bg-white/8 p-5 transition-colors hover:border-[#f2c36d]/70 hover:bg-white/12">
            <p class="text-[11px] font-semibold uppercase tracking-wider text-[#f2c36d]">{pick.label}</p>
            <h3 class="mt-2 font-display text-2xl font-bold group-hover:text-[#f2c36d]">{pick.title}</h3>
            <p class="mt-2 leading-relaxed text-white/75">{pick.body}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:py-16">
    <div class="grid gap-8 lg:grid-cols-[1fr_1fr]">
      <div class="overflow-hidden rounded-lg border border-line bg-card">
        <img src="/images/china-high-speed-train.jpg" alt="High-speed train in a Chinese railway station" class="h-64 w-full object-cover sm:h-72" />
        <div class="p-6">
          <p class="text-[12px] font-semibold uppercase tracking-[0.16em] text-accent">Traveling China</p>
          <h2 class="mt-2 font-display text-3xl font-bold">Trains, Didi, metro, and the airport-to-hotel handoff</h2>
          <p class="mt-3 leading-relaxed text-soft">
            China is easier when you treat transport as a system: book high-speed rail between
            cities, use Didi when addresses are hard, and use Alipay transport QR codes for metro.
          </p>
          <div class="mt-5 flex flex-wrap gap-3">
            <a href="/guides/china-high-speed-trains/" class="rounded-md bg-accent px-4 py-2.5 text-sm font-semibold text-white hover:bg-accent-dark">Train guide</a>
            <a href="/guides/didi-metro-getting-around/" class="rounded-md border border-line px-4 py-2.5 text-sm font-semibold hover:border-accent/50 hover:text-accent">City transport</a>
          </div>
        </div>
      </div>
      <div class="overflow-hidden rounded-lg border border-line bg-card">
        <img src="/images/china-street-food.jpg" alt="Chinese street food stall with steam and bright signage" class="h-64 w-full object-cover sm:h-72" />
        <div class="p-6">
          <p class="text-[12px] font-semibold uppercase tracking-[0.16em] text-accent">Eating China</p>
          <h2 class="mt-2 font-display text-3xl font-bold">Street food, tea houses, QR menus, and dietary survival</h2>
          <p class="mt-3 leading-relaxed text-soft">
            The best meals are often visible, pointable, and cheap. The trick is knowing how to
            order, how to pay, and which famous food streets are mostly theater.
          </p>
          <div class="mt-5 flex flex-wrap gap-3">
            <a href="/guides/street-food-night-markets/" class="rounded-md bg-accent px-4 py-2.5 text-sm font-semibold text-white hover:bg-accent-dark">Street food</a>
            <a href="/guides/food-ordering-dietary/" class="rounded-md border border-line px-4 py-2.5 text-sm font-semibold hover:border-accent/50 hover:text-accent">Ordering guide</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 sm:px-6">
    <div class="rounded-lg border border-line bg-card p-5 sm:p-8">
      <div class="grid gap-6 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
        <div>
          <p class="text-[12px] font-semibold uppercase tracking-[0.16em] text-accent">Travel essentials</p>
          <h2 class="mt-2 font-display text-3xl font-bold leading-tight sm:text-4xl">Before you fly, fix the basics</h2>
        </div>
        <p class="leading-relaxed text-soft">
          Visa rules, mobile payments, eSIMs, translation, hotels, and train bookings are the
          practical layer underneath every good China trip.
        </p>
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        {essentials.map((guide) => <GuideCard guide={guide} />)}
      </div>
    </div>
  </section>
</Base>
