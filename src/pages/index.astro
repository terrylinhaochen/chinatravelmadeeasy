---
import Base from '../layouts/Base.astro';
import GuideCard from '../components/GuideCard.astro';
import Icon from '../components/Icon.astro';
import { getCollection } from 'astro:content';

const guides = (await getCollection('guides')).sort(
  (a, b) => a.data.order - b.data.order
);

// Two pillars: the experiences worth coming for, and the logistics that make them possible.
const DELIGHT_CATEGORIES = new Set(['Authentic China', 'Food']);
const DELIGHT_SLUGS = new Set(['7-day-china-itinerary']);
const delights = guides.filter(
  (g) => DELIGHT_CATEGORIES.has(g.data.category) || DELIGHT_SLUGS.has(g.id)
);
const logistics = guides.filter((g) => !delights.includes(g));

const description =
  'The two halves of a great China trip: authentic experiences (street food, tea houses, real neighborhoods) and the logistics that unlock them — payments, visas, eSIMs, trains, and hotels, without speaking Chinese.';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'China Travel Made Easy',
    url: 'https://chinatravelmadeeasy.com/',
    description,
    inLanguage: 'en',
    publisher: {
      '@type': 'Person',
      name: 'Terry Chen',
      url: 'https://chinatravelmadeeasy.com/about/',
    },
  },
];
---

<Base title="China Travel Made Easy — China travel guides for non-Chinese speakers" description={description} jsonLd={jsonLd}>
  <!-- Hero -->
  <section class="border-b border-line bg-gradient-to-b from-accent-soft/60 to-paper">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 py-14 sm:py-20">
      <p class="text-[12px] font-semibold uppercase tracking-[0.15em] text-accent">
        For first-time visitors · Updated for mid-2026
      </p>
      <h1 class="font-display font-bold text-3xl sm:text-[2.6rem] leading-tight mt-3 max-w-2xl">
        The real China is worth the trip. The logistics shouldn't stop you.
      </h1>
      <p class="text-soft text-lg mt-4 max-w-2xl leading-relaxed">
        Night markets, tea houses, neighborhoods where nobody's performing for tourists — that's
        why you go. These guides handle both halves: the experiences worth planning around, and
        the 2026 logistics (payments, visas, internet, trains) that make them possible without
        speaking a word of Chinese.
      </p>
      <div class="mt-7 flex flex-wrap items-center gap-3">
        <a
          href="/guides/china-pre-departure-checklist/"
          class="inline-flex items-center gap-2 rounded-md bg-accent px-5 py-2.5 text-white font-medium hover:bg-accent-dark transition-colors"
        >
          Start here: pre-departure checklist
          <Icon name="arrow" class="w-4 h-4" />
        </a>
        <a
          href="/guides/"
          class="inline-flex items-center rounded-md border border-line bg-card px-5 py-2.5 font-medium text-soft hover:border-accent/50 hover:text-accent transition-colors"
        >
          Browse all guides
        </a>
      </div>
    </div>
  </section>

  <!-- The three things -->
  <section class="mx-auto max-w-4xl px-4 sm:px-6 py-12">
    <h2 class="font-display font-bold text-2xl">The three things that make or break a China trip</h2>
    <div class="grid sm:grid-cols-3 gap-4 mt-6">
      <div class="rounded-lg border border-line bg-card p-5">
        <Icon name="wallet" class="w-6 h-6 text-accent" />
        <h3 class="font-display font-bold mt-3">Payments</h3>
        <p class="text-sm text-soft mt-1.5 leading-relaxed">
          China is nearly cashless. Set up Alipay and WeChat Pay with your home credit card
          <em>before</em> you land, or the first day gets stressful fast.
        </p>
      </div>
      <div class="rounded-lg border border-line bg-card p-5">
        <Icon name="wifi" class="w-6 h-6 text-accent" />
        <h3 class="font-display font-bold mt-3">Internet</h3>
        <p class="text-sm text-soft mt-1.5 leading-relaxed">
          Google, WhatsApp, and Instagram are blocked on local networks — but a travel eSIM
          sidesteps the whole problem. One decision fixes 90% of it.
        </p>
      </div>
      <div class="rounded-lg border border-line bg-card p-5">
        <Icon name="passport" class="w-6 h-6 text-accent" />
        <h3 class="font-display font-bold mt-3">Entry rules</h3>
        <p class="text-sm text-soft mt-1.5 leading-relaxed">
          Dozens of passports now enter visa-free for 30 days, and most others get 10 days in
          transit. Many travelers don't realize they no longer need a visa.
        </p>
      </div>
    </div>
  </section>

  <!-- Authentic delights -->
  <section class="mx-auto max-w-4xl px-4 sm:px-6 py-6">
    <div class="flex items-baseline justify-between">
      <h2 class="font-display font-bold text-2xl">Authentic delights</h2>
      <p class="text-sm text-faint">{delights.length} guides</p>
    </div>
    <p class="text-soft mt-2 max-w-2xl leading-relaxed">
      The experiences worth building a trip around — eating, wandering, and the everyday culture
      most visitors walk past.
    </p>
    <div class="grid sm:grid-cols-2 gap-4 mt-6">
      {delights.map((guide) => <GuideCard guide={guide} />)}
    </div>
  </section>

  <!-- Travel logistics -->
  <section class="mx-auto max-w-4xl px-4 sm:px-6 py-6 pb-16">
    <div class="flex items-baseline justify-between">
      <h2 class="font-display font-bold text-2xl">Travel logistics</h2>
      <p class="text-sm text-faint">{logistics.length} guides</p>
    </div>
    <p class="text-soft mt-2 max-w-2xl leading-relaxed">
      The unglamorous half that makes the rest possible: money, internet, entry rules, and getting
      around.
    </p>
    <div class="grid sm:grid-cols-2 gap-4 mt-6">
      {logistics.map((guide) => <GuideCard guide={guide} />)}
    </div>
  </section>

</Base>
