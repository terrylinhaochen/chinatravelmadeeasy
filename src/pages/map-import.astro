---
import Base from '../layouts/Base.astro';

const description = 'Paste a China travel recommendation link, extract the place, and save it to your map.';
---

<Base title="Save a China travel link to maps" description={description}>
  <section class="mx-auto max-w-2xl px-4 py-10 sm:px-6 sm:py-14">
    <p class="text-[12px] font-semibold uppercase tracking-[0.15em] text-accent">Link to map</p>
    <h1 class="mt-3 font-display text-4xl font-bold leading-tight sm:text-5xl">Paste link. Save place.</h1>
    <p class="mt-4 text-lg leading-relaxed text-soft">
      Turn a social post, review, or itinerary link into a place you can save in Apple Maps.
    </p>
  </section>

  <section class="mx-auto max-w-2xl px-4 pb-8 sm:px-6">
    <div class="rounded-lg border border-line bg-[#f4f0e8] p-5 sm:p-6">
      <p class="font-display text-2xl font-bold">Why this exists</p>
      <p class="mt-2 text-sm leading-relaxed text-soft">
        China trip ideas are scattered across captions, comments, screenshots, and local review links. This pulls the place out of the recommendation so you can keep it in your map instead of losing it in a saved-post folder.
      </p>
      <div class="mt-5 grid gap-3 sm:grid-cols-[1fr_auto_1fr_auto_1fr] sm:items-center">
        <div class="rounded-md border border-line bg-card p-4">
          <p class="text-[11px] font-semibold uppercase tracking-wider text-faint">1. Link</p>
          <p class="mt-1 font-semibold text-ink">Social recommendation</p>
        </div>
        <div class="hidden text-center font-display text-2xl text-accent sm:block">→</div>
        <div class="rounded-md border border-line bg-card p-4">
          <p class="text-[11px] font-semibold uppercase tracking-wider text-faint">2. Extract</p>
          <p class="mt-1 font-semibold text-ink">Place name + city</p>
        </div>
        <div class="hidden text-center font-display text-2xl text-accent sm:block">→</div>
        <div class="rounded-md border border-line bg-card p-4">
          <p class="text-[11px] font-semibold uppercase tracking-wider text-faint">3. Save</p>
          <p class="mt-1 font-semibold text-ink">Your map list</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-2xl px-4 pb-8 sm:px-6">
    <div class="rounded-lg border border-line bg-card p-5 sm:p-6">
      <label for="linkInput" class="font-display text-2xl font-bold">Paste link</label>
      <div class="mt-3 grid gap-3 sm:grid-cols-[1fr_auto]">
        <input id="linkInput" type="url" inputmode="url" class="rounded-md border border-line bg-paper p-3 text-sm outline-none focus:border-accent" placeholder="https://..." />
        <button id="extractBtn" type="button" class="rounded-md bg-accent px-5 py-2.5 text-sm font-semibold text-white hover:bg-accent-dark">Extract</button>
      </div>
      <p id="statusText" class="mt-4 hidden rounded-md border border-line bg-paper p-3 text-sm leading-relaxed text-soft"></p>
    </div>
  </section>

  <section id="resultSection" class="mx-auto hidden max-w-2xl px-4 pb-8 sm:px-6">
    <div class="rounded-lg border border-line bg-card p-5 sm:p-6">
      <p class="text-[12px] font-semibold uppercase tracking-[0.15em] text-accent">Extracted place</p>
      <div id="placeResult" class="mt-3"></div>
    </div>
  </section>

  <section id="loginSection" class="mx-auto hidden max-w-2xl px-4 pb-8 sm:px-6">
    <div class="rounded-lg border border-line bg-paper p-5 sm:p-6">
      <p class="text-[12px] font-semibold uppercase tracking-[0.15em] text-accent">Sign in to save</p>
      <h2 class="mt-2 font-display text-2xl font-bold">Save this place to your trip list.</h2>
      <p class="mt-2 text-sm leading-relaxed text-soft">For this local prototype, sign-in is stored in this browser. A production version would connect this to the real account system before syncing across devices.</p>
      <div class="mt-4 grid gap-3 sm:grid-cols-[1fr_auto]">
        <input id="emailInput" type="email" class="rounded-md border border-line bg-white p-3 text-sm outline-none focus:border-accent" placeholder="you@example.com" />
        <button id="loginBtn" type="button" class="rounded-md bg-ink px-5 py-2.5 text-sm font-semibold text-white hover:bg-accent">Continue</button>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-2xl px-4 pb-12 sm:px-6">
    <div class="rounded-lg border border-line bg-card p-5 sm:p-6">
      <div class="flex items-end justify-between gap-3">
        <div>
          <p class="text-[12px] font-semibold uppercase tracking-[0.15em] text-accent">Saved here</p>
          <h2 class="mt-1 font-display text-2xl font-bold">My saved places</h2>
          <p class="mt-1 text-sm text-soft">A backup list of places you have opened for map saving.</p>
        </div>
        <p id="userBadge" class="text-sm text-faint"></p>
      </div>
      <div id="savedList" class="mt-4 grid gap-2 text-sm text-soft"></div>
    </div>
  </section>

  <script>
    import { amapUrl, appleMapsUrl, displayName, extractTripPlaces, sourceFromShareOrLink } from '../utils/placeExtraction.js';

    const linkInput = document.querySelector('#linkInput');
    const extractBtn = document.querySelector('#extractBtn');
    const statusText = document.querySelector('#statusText');
    const resultSection = document.querySelector('#resultSection');
    const placeResult = document.querySelector('#placeResult');
    const loginSection = document.querySelector('#loginSection');
    const emailInput = document.querySelector('#emailInput');
    const loginBtn = document.querySelector('#loginBtn');
    const savedList = document.querySelector('#savedList');
    const userBadge = document.querySelector('#userBadge');
    const userKey = 'ctme-map-user';
    const savedKey = 'ctme-map-saved-places';
    let selectedPlace = null;
    let selectedSource = null;
    let pendingSave = null;

    const sharedSource = sourceFromShareOrLink(window.location.search, '');
    if (sharedSource.url) linkInput.value = sharedSource.url;
    renderSaved();

    extractBtn.addEventListener('click', () => runExtraction(linkInput.value));
    loginBtn.addEventListener('click', () => {
      const email = emailInput.value.trim();
      if (!/^\S+@\S+\.\S+$/.test(email)) {
        showStatus('Enter an email to save places.', true);
        return;
      }
      localStorage.setItem(userKey, JSON.stringify({ email, createdAt: new Date().toISOString() }));
      loginSection.classList.add('hidden');
      renderSaved();
      if (pendingSave) savePlace(pendingSave, true);
    });

    function runExtraction(link) {
      const normalized = sourceFromShareOrLink(window.location.search, link);
      const result = extractTripPlaces(normalized);
      selectedSource = result.source;
      selectedPlace = result.places[0] || null;
      pendingSave = null;
      loginSection.classList.add('hidden');
      if (!link.trim()) {
        showStatus('Paste a link first.', true);
        resultSection.classList.add('hidden');
        return;
      }
      if (!selectedPlace) {
        showStatus('I could not extract a place from this link alone. If the social app did not pass the caption, use a share URL that includes title/text/caption. The page does not call third-party APIs.', true);
        resultSection.classList.add('hidden');
        return;
      }
      showStatus('Found ' + displayName(selectedPlace) + ' from ' + result.source.platform + '.', false);
      renderPlace(selectedPlace);
    }

    function renderPlace(place) {
      resultSection.classList.remove('hidden');
      placeResult.innerHTML = '<article class="rounded-lg border border-line bg-paper p-4" data-place-card>' +
        '<p class="text-[11px] font-semibold uppercase tracking-wider text-faint">' + escapeHtml(place.category || 'Place') + '</p>' +
        '<h2 class="mt-1 font-display text-3xl font-bold">' + escapeHtml(displayName(place)) + '</h2>' +
        '<p class="mt-2 text-sm leading-relaxed text-soft">' + escapeHtml(place.note || 'Found in the shared link.') + '</p>' +
        '<div class="mt-4 flex flex-wrap gap-2">' +
          '<button id="saveAppleBtn" type="button" class="rounded-md bg-ink px-4 py-2.5 text-sm font-semibold text-white hover:bg-accent">Save in Apple Maps</button>' +
          '<details class="text-sm text-soft"><summary class="cursor-pointer rounded-md border border-line px-3 py-2 font-semibold text-ink">Other maps</summary>' +
          '<a class="mt-2 inline-block rounded-md border border-line px-3 py-2 font-semibold hover:border-accent/50 hover:text-accent" target="_blank" rel="noopener" href="' + amapUrl(place) + '">高德地图</a></details>' +
        '</div></article>';
      document.querySelector('#saveAppleBtn').addEventListener('click', () => savePlace(place, true));
    }

    function savePlace(place, openMap) {
      const user = getUser();
      if (!user) {
        pendingSave = place;
        loginSection.classList.remove('hidden');
        emailInput.focus();
        showStatus('Sign in once to save places to your trip list.', false);
        return;
      }
      const saved = getSaved().filter((item) => keyFor(item) !== keyFor(place));
      saved.unshift({ ...place, sourceUrl: selectedSource?.url || place.sourceUrl || '', savedAt: new Date().toISOString(), savedBy: user.email });
      localStorage.setItem(savedKey, JSON.stringify(saved.slice(0, 24)));
      renderSaved();
      showStatus('Saved ' + displayName(place) + '. Opening Apple Maps.', false);
      if (openMap) window.open(appleMapsUrl(place), '_blank', 'noopener');
      pendingSave = null;
    }

    function renderSaved() {
      const user = getUser();
      userBadge.textContent = user ? user.email : 'Not signed in';
      const saved = getSaved();
      if (!saved.length) {
        savedList.innerHTML = '<div class="rounded-md border border-dashed border-line bg-paper p-4">Saved places will appear here after sign-in.</div>';
        return;
      }
      savedList.innerHTML = saved.map((place) => '<a target="_blank" rel="noopener" href="' + appleMapsUrl(place) + '" class="flex items-center justify-between gap-3 rounded-md border border-line bg-paper p-3 hover:border-accent/50"><span class="font-semibold text-ink">' + escapeHtml(displayName(place)) + '</span><span class="text-xs text-faint">Apple Maps</span></a>').join('');
    }

    function showStatus(message, isError) {
      statusText.textContent = message;
      statusText.classList.remove('hidden');
      statusText.classList.toggle('border-accent', Boolean(isError));
    }
    function getUser() { try { return JSON.parse(localStorage.getItem(userKey) || 'null'); } catch { return null; } }
    function getSaved() { try { return JSON.parse(localStorage.getItem(savedKey) || '[]'); } catch { return []; } }
    function keyFor(place) { return String(place.name || '').toLowerCase() + '|' + String(place.city || '').toLowerCase(); }
    function escapeHtml(value) { return String(value || '').replace(/[&<>"]/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[char])); }
  </script>
</Base>
