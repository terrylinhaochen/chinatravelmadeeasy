---
import Base from '../layouts/Base.astro';

const description = 'Paste a TikTok or Instagram link, extract China trip places, and save them to your map.';
---

<Base title="Save a China travel link to maps" description={description}>
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-14">
    <p class="ds-eyebrow">Link to map</p>
    <h1 class="mt-3 text-4xl font-bold leading-tight sm:text-5xl">Create map collections from TikTok inspiration.</h1>
    <p class="mt-4 text-lg leading-relaxed text-soft">
      Paste a TikTok or Instagram link. Extract the places mentioned,
      save them as a trip collection, then open each one in Apple Maps.
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-8 sm:px-6">
    <div class="ds-panel p-5 sm:p-6">
      <p class="text-2xl font-bold">From social post to saved map list</p>
      <p class="mt-2 text-sm leading-relaxed text-soft">
        CrowdListen-style source processing detects TikTok and Instagram share links, reads the
        share text/caption available to the browser, extracts place names and cities, then turns the
        recommendation into a save-ready collection.
      </p>
      <div class="mt-5 grid gap-3 sm:grid-cols-[1fr_auto_1fr_auto_1fr] sm:items-center">
        <div class="ds-card p-4">
          <p class="ds-tag">1. Import</p>
          <p class="mt-1 font-semibold text-ink">TikTok or Instagram share</p>
        </div>
        <div class="hidden text-center text-2xl font-bold text-accent sm:block">→</div>
        <div class="ds-card p-4">
          <p class="ds-tag">2. Extract</p>
          <p class="mt-1 font-semibold text-ink">Places + city context</p>
        </div>
        <div class="hidden text-center text-2xl font-bold text-accent sm:block">→</div>
        <div class="ds-card p-4">
          <p class="ds-tag">3. Collect</p>
          <p class="mt-1 font-semibold text-ink">Saved Apple Maps links</p>
        </div>
      </div>
      <div class="mt-5 flex flex-wrap gap-2 text-xs font-semibold text-soft">
        {['TikTok / Douyin', 'Instagram Reels'].map((source) => (
          <span class="ds-chip">{source}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-8 sm:px-6">
    <div class="ds-card p-5 sm:p-6">
      <div class="flex flex-wrap items-end justify-between gap-3">
        <div>
          <label for="linkInput" class="text-2xl font-bold">Paste link</label>
          <p class="mt-1 text-sm leading-relaxed text-soft">Paste a TikTok or Instagram link, then extract places. Or run a sample.</p>
        </div>
        <div class="flex flex-wrap gap-2">
          <button type="button" data-sample="tiktok-shanghai" class="sampleBtn ds-button ds-button-secondary min-h-0 px-3 py-2">Run TikTok sample</button>
          <button type="button" data-sample="instagram-chengdu" class="sampleBtn ds-button ds-button-secondary min-h-0 px-3 py-2">Run Instagram sample</button>
        </div>
      </div>
      <div class="mt-3 grid gap-3 sm:grid-cols-[1fr_auto]">
        <input id="linkInput" type="url" inputmode="url" class="ds-input text-sm" placeholder="https://..." />
        <button id="extractBtn" type="button" class="ds-button ds-button-primary">Extract</button>
      </div>
      <p id="sourceText" class="ds-tag mt-3 hidden"></p>
      <p id="statusText" class="ds-card mt-4 hidden p-3 text-sm leading-relaxed text-soft"></p>
    </div>
  </section>

  <section id="resultSection" class="mx-auto hidden max-w-6xl px-4 pb-8 sm:px-6">
    <div class="ds-card p-5 sm:p-6">
      <div class="flex flex-wrap items-end justify-between gap-3">
        <div>
          <p class="ds-eyebrow">Extracted collection</p>
          <h2 id="collectionTitle" class="mt-1 text-2xl font-bold">Places from this link</h2>
        </div>
        <button id="saveCollectionBtn" type="button" class="ds-button ds-button-dark">
          Save collection
        </button>
      </div>
      <div id="placeResult" class="mt-4 grid gap-3"></div>
    </div>
  </section>

  <section id="loginSection" class="mx-auto hidden max-w-6xl px-4 pb-8 sm:px-6">
    <div class="ds-panel p-5 sm:p-6">
      <p class="ds-eyebrow">Sign in to save</p>
      <h2 class="mt-2 text-2xl font-bold">Save this collection to your trip list.</h2>
      <p class="mt-2 text-sm leading-relaxed text-soft">For this local prototype, sign-in is stored in this browser. A production version would connect this to the real account system before syncing across devices.</p>
      <div class="mt-4 grid gap-3 sm:grid-cols-[1fr_auto]">
        <input id="emailInput" type="email" class="ds-input text-sm" placeholder="you@example.com" />
        <button id="loginBtn" type="button" class="ds-button ds-button-dark">Continue</button>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-12 sm:px-6">
    <div class="ds-card p-5 sm:p-6">
      <div class="flex items-end justify-between gap-3">
        <div>
          <p class="ds-eyebrow">Saved here</p>
          <h2 class="mt-1 text-2xl font-bold">My saved collections</h2>
          <p class="mt-1 text-sm text-soft">A backup list of places ready to open and save in Apple Maps.</p>
        </div>
        <p id="userBadge" class="text-sm text-faint"></p>
      </div>
      <div id="savedList" class="mt-4 grid gap-2 text-sm text-soft"></div>
    </div>
  </section>

  <script>
    import { amapUrl, appleMapsUrl, displayName, extractTripPlaces, normalizeSource, sourceFromShareOrLink } from '../utils/placeExtraction.js';

    const linkInput = document.querySelector('#linkInput');
    const extractBtn = document.querySelector('#extractBtn');
    const sourceText = document.querySelector('#sourceText');
    const statusText = document.querySelector('#statusText');
    const resultSection = document.querySelector('#resultSection');
    const placeResult = document.querySelector('#placeResult');
    const collectionTitle = document.querySelector('#collectionTitle');
    const saveCollectionBtn = document.querySelector('#saveCollectionBtn');
    const loginSection = document.querySelector('#loginSection');
    const emailInput = document.querySelector('#emailInput');
    const loginBtn = document.querySelector('#loginBtn');
    const savedList = document.querySelector('#savedList');
    const userBadge = document.querySelector('#userBadge');
    const userKey = 'ctme-map-user';
    const savedKey = 'ctme-map-saved-places';
    const sampleSources = {
      'tiktok-shanghai': {
        collectionName: 'TikTok Shanghai food crawl',
        title: 'Shanghai food crawl: soup dumplings, old streets, skyline',
        url: 'https://www.tiktok.com/@chinatravel/video/7380012345678901234',
        text: 'Save this Shanghai crawl: lunch at Jia Jia Tang Bao, snack walk on Huanghe Road, sunset at The Bund, then camera walk on Wukang Road. #Shanghai #ChinaTravel',
      },
      'instagram-chengdu': {
        collectionName: 'Instagram Chengdu tea day',
        title: 'Chengdu slow day: tea, park, hotpot',
        url: 'https://www.instagram.com/reel/C8ChinaTeaDay/',
        text: "Chengdu save list: start at People's Park, sit at Heming Tea House, then dinner at 小龙坎火锅. Easy first day if you want tea house culture and hotpot.",
      },
    };
    let selectedPlaces = [];
    let selectedSource = null;
    let selectedCollectionName = 'China inspiration collection';
    let pendingSave = null;

    const sharedSource = sourceFromShareOrLink(window.location.search, '');
    if (sharedSource.url) linkInput.value = sharedSource.url;
    renderSaved();

    extractBtn.addEventListener('click', () => runExtraction(linkInput.value));
    document.querySelectorAll('.sampleBtn').forEach((button) => {
      button.addEventListener('click', () => runExtraction(sampleSources[button.dataset.sample], { fromSample: true }));
    });
    saveCollectionBtn.addEventListener('click', () => saveCollection(selectedPlaces, true));
    loginBtn.addEventListener('click', () => {
      const email = emailInput.value.trim();
      if (!/^\S+@\S+\.\S+$/.test(email)) {
        showStatus('Enter an email to save places.', true);
        return;
      }
      localStorage.setItem(userKey, JSON.stringify({ email, createdAt: new Date().toISOString() }));
      loginSection.classList.add('hidden');
      renderSaved();
      if (pendingSave) saveCollection(pendingSave.places, pendingSave.openMap);
    });

    function runExtraction(input, options = {}) {
      const normalized = typeof input === 'object'
        ? normalizeSource(input)
        : sourceFromShareOrLink(window.location.search, input);
      const result = extractTripPlaces(normalized);
      selectedSource = result.source;
      selectedPlaces = result.places;
      selectedCollectionName = typeof input === 'object' && input.collectionName
        ? input.collectionName
        : result.source.platform + ' China places';
      pendingSave = null;
      loginSection.classList.add('hidden');
      if (typeof input === 'object') {
        linkInput.value = input.url || '';
      }
      if (!String(normalized.url || normalized.text || '').trim()) {
        showStatus('Paste a link first.', true);
        resultSection.classList.add('hidden');
        return;
      }
      sourceText.textContent = 'Detected source: ' + result.source.platform + (options.fromSample ? ' sample' : '');
      sourceText.classList.remove('hidden');
      if (!selectedPlaces.length) {
        showStatus('I could not extract a place from this link alone. If the social app did not pass the caption, use a share URL that includes title/text/caption. The page does not call third-party APIs.', true);
        resultSection.classList.add('hidden');
        return;
      }
      showStatus('Extracted ' + selectedPlaces.length + ' place' + (selectedPlaces.length === 1 ? '' : 's') + ' from ' + result.source.platform + '. Save the collection, then open each place in Apple Maps.', false);
      renderPlaces(selectedPlaces);
    }

    function renderPlaces(places) {
      resultSection.classList.remove('hidden');
      collectionTitle.textContent = selectedCollectionName;
      placeResult.innerHTML = places.map((place, index) => '<article class="ds-card p-4" data-place-card>' +
        '<p class="ds-tag">' + escapeHtml(place.category || 'Place') + '</p>' +
        '<h3 class="mt-1 text-2xl font-bold">' + escapeHtml(displayName(place)) + '</h3>' +
        '<p class="mt-2 text-sm leading-relaxed text-soft">' + escapeHtml(place.note || 'Found in the shared link.') + '</p>' +
        '<div class="mt-4 flex flex-wrap gap-2">' +
          '<button data-save-index="' + index + '" type="button" class="savePlaceBtn ds-button ds-button-dark">Save place</button>' +
          '<a target="_blank" rel="noopener" href="' + appleMapsUrl(place) + '" class="ds-button ds-button-secondary">Open Apple Maps</a>' +
          '<details class="text-sm text-soft"><summary class="cursor-pointer rounded-md border border-line px-3 py-2 font-semibold text-ink">Other maps</summary>' +
          '<a class="ds-button ds-button-secondary mt-2 min-h-0 px-3 py-2" target="_blank" rel="noopener" href="' + amapUrl(place) + '">高德地图</a></details>' +
        '</div></article>').join('');
      document.querySelectorAll('.savePlaceBtn').forEach((button) => {
        button.addEventListener('click', () => saveCollection([places[Number(button.dataset.saveIndex)]], true));
      });
    }

    function saveCollection(places, openMap) {
      const cleanPlaces = (places || []).filter(Boolean);
      if (!cleanPlaces.length) {
        showStatus('Extract places before saving.', true);
        return;
      }
      const user = getUser();
      if (!user) {
        pendingSave = { places: cleanPlaces, openMap };
        loginSection.classList.remove('hidden');
        emailInput.focus();
        showStatus('Sign in once to save this collection to your trip list.', false);
        return;
      }
      const current = getSaved();
      const sourceUrl = selectedSource?.url || cleanPlaces[0]?.sourceUrl || '';
      const collection = {
        id: Date.now(),
        name: cleanPlaces.length === 1 ? displayName(cleanPlaces[0]) : selectedCollectionName,
        platform: selectedSource?.platform || cleanPlaces[0]?.sourcePlatform || 'Source',
        sourceUrl,
        savedAt: new Date().toISOString(),
        savedBy: user.email,
        places: cleanPlaces,
      };
      localStorage.setItem(savedKey, JSON.stringify([collection, ...current].slice(0, 24)));
      renderSaved();
      showStatus('Saved ' + collection.name + '. Open each place in Apple Maps from the saved collection.', false);
      if (openMap && cleanPlaces.length === 1) window.open(appleMapsUrl(cleanPlaces[0]), '_blank', 'noopener');
      pendingSave = null;
    }

    function renderSaved() {
      const user = getUser();
      userBadge.textContent = user ? user.email : 'Not signed in';
      const saved = getSaved();
      if (!saved.length) {
        savedList.innerHTML = '<div class="ds-card border-dashed p-4">Saved collections will appear here after sign-in.</div>';
        return;
      }
      savedList.innerHTML = saved.map((collection) => {
        const places = Array.isArray(collection.places) ? collection.places : [collection];
        return '<article class="ds-card p-4">' +
          '<div class="flex flex-wrap items-start justify-between gap-3">' +
          '<div><p class="ds-tag">' + escapeHtml(collection.platform || 'Collection') + '</p>' +
          '<h3 class="text-xl font-bold text-ink">' + escapeHtml(collection.name || displayName(places[0])) + '</h3></div>' +
          '<span class="text-xs text-faint">' + places.length + ' place' + (places.length === 1 ? '' : 's') + '</span></div>' +
          '<div class="mt-3 flex flex-wrap gap-2">' + places.map((place) => '<a target="_blank" rel="noopener" href="' + appleMapsUrl(place) + '" class="ds-chip hover:border-accent/50 hover:text-accent">' + escapeHtml(displayName(place)) + '</a>').join('') + '</div>' +
        '</article>';
      }).join('');
    }

    function showStatus(message, isError) {
      statusText.textContent = message;
      statusText.classList.remove('hidden');
      statusText.classList.toggle('border-accent', Boolean(isError));
    }
    function getUser() { try { return JSON.parse(localStorage.getItem(userKey) || 'null'); } catch { return null; } }
    function getSaved() { try { return JSON.parse(localStorage.getItem(savedKey) || '[]'); } catch { return []; } }
    function keyFor(place) { return String(place.name || '').toLowerCase() + '|' + String(place.city || '').toLowerCase(); }
    function escapeHtml(value) { return String(value || '').replace(/[&<>"]/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[char])); }
  </script>
</Base>
