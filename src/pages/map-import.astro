---
import Base from '../layouts/Base.astro';

const description =
  'Turn captions, screenshot text, and shared place lists into a reviewable China place task with bilingual identity, group decisions, and map handoffs.';
const mapFaqs = [
  {
    q: 'What can I drop into the map tool?',
    a: 'Paste the text from a caption, screenshot, friend list, or itinerary. A bare social URL is not fetched by this static prototype; include the caption or place names so the tool has evidence to review.',
  },
  {
    q: 'When do I choose Apple Maps or AMap?',
    a: 'Map choices appear after extraction. AMap is the mainland-China execution default because it preserves local POI coverage; Apple Maps remains available as a second provider check. The first step stays focused on cleaning the raw list.',
  },
  {
    q: 'Can I share or remix saved pins?',
    a: 'Yes. Mark each candidate Keep, Maybe, or Drop, add the hard constraints, then copy a handoff link. The recipient reopens the evidence, decisions, reasons, and constraints as their own editable version.',
  },
  {
    q: 'How do I contribute a local-language recommendation?',
    a: 'Expand Contribute local knowledge, preserve the original name and evidence, choose place or route, and add a public source or map link when available. The page prepares a private review packet; it does not publish or transmit the contribution automatically.',
  },
];
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Make local China tips map-ready together',
    description,
    url: 'https://chinatravelmadeeasy.com/map-import/',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'China Travel Made Easy map saver',
    applicationCategory: 'TravelApplication',
    operatingSystem: 'Web',
    description,
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    name: 'Map saving questions',
    mainEntity: mapFaqs.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.a,
      },
    })),
  },
];
---

<Base title="Make local China tips map-ready together" description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-14">
    <p class="ds-eyebrow">Shared China place task</p>
    <h1 class="mt-3 max-w-4xl text-4xl font-bold leading-tight sm:text-5xl">Make local China tips map-ready together.</h1>
    <p class="mt-4 max-w-2xl text-lg leading-relaxed text-soft">
      Paste the recommendation itself, keep its evidence attached, decide together, then open only the reviewed places in AMap or Apple Maps.
    </p>
  </section>

  <section id="importSection" class="mx-auto max-w-6xl px-4 pb-8 sm:px-6">
    <div class="ds-card p-5 sm:p-6">
      <div class="mb-5 flex flex-wrap gap-2 text-xs font-semibold text-soft">
        <span class="ds-chip border-accent/50 text-accent">1. Import</span>
        <span class="ds-chip">2. Resolve</span>
        <span class="ds-chip">3. Decide</span>
        <span class="ds-chip">4. Handoff</span>
      </div>
      <div class="flex flex-wrap items-end justify-between gap-3">
        <div>
          <label for="linkInput" class="inline-flex min-h-8 items-center text-2xl font-bold">Paste the recommendation itself</label>
          <p class="mt-1 max-w-2xl text-sm leading-relaxed text-soft">Captions, OCR text, and one-place-per-line lists work. A bare TikTok or Instagram URL does not: this static page cannot fetch the post behind it.</p>
        </div>
        <div class="flex flex-wrap gap-2">
          <button type="button" data-sample="tiktok-shanghai" class="sampleBtn ds-button ds-button-secondary min-h-0 px-3 py-2">Run TikTok sample</button>
          <button type="button" data-sample="instagram-chengdu" class="sampleBtn ds-button ds-button-secondary min-h-0 px-3 py-2">Run Instagram sample</button>
        </div>
      </div>
      <div class="mt-3 grid gap-3 sm:grid-cols-[1fr_auto] sm:items-end">
        <textarea id="linkInput" class="ds-input min-h-28 resize-y text-sm" placeholder="Paste a caption, screenshot text, or a numbered place list. Include the city when you can."></textarea>
        <button id="extractBtn" type="button" class="ds-button ds-button-primary">Preview pins</button>
      </div>
      <p id="sourceText" class="ds-tag mt-3 hidden"></p>
      <p id="statusText" class="ds-card mt-4 hidden p-3 text-sm leading-relaxed text-soft"></p>
    </div>

    <details id="contribute" class="ds-card mt-5 overflow-hidden" data-contribution-details>
      <summary class="cursor-pointer list-none p-5 sm:p-6">
        <div class="flex items-center justify-between gap-4">
          <div>
            <p class="ds-eyebrow">Contribute local knowledge</p>
            <h2 class="mt-2 text-2xl font-bold">Share the original evidence—not just a recommendation</h2>
            <p class="mt-2 max-w-3xl text-sm leading-relaxed text-soft">Add a local-language post, map link, caption, or route with enough context for a reviewer to translate and resolve it without guessing.</p>
          </div>
          <span class="grid h-10 w-10 shrink-0 place-items-center rounded-full border border-line text-xl" aria-hidden="true">+</span>
        </div>
      </summary>

      <div class="border-t border-line p-5 sm:p-6">
        <div class="grid gap-8 lg:grid-cols-[.7fr_1.3fr]">
          <div>
            <p class="text-sm leading-relaxed text-soft">A useful contribution preserves the local wording, says why it belongs in a trip, and admits when the map identity is missing. It does not need to be polished or translated.</p>
            <ol class="mt-5 grid gap-3 text-sm text-soft">
              <li class="rounded-2xl border border-line p-4"><strong class="block text-ink">1. Preserve the source</strong>Public link or pasted original-language evidence.</li>
              <li class="rounded-2xl border border-line p-4"><strong class="block text-ink">2. Preserve the shape</strong>Say whether it is one place, a bounded route, or still unclear.</li>
              <li class="rounded-2xl border border-line p-4"><strong class="block text-ink">3. Let review do the rest</strong>Translation, provider matching, duplication, and publication remain pending.</li>
            </ol>
          </div>

          <form class="ds-panel p-5 sm:p-6" data-contribution-form>
            <div class="grid gap-4 sm:grid-cols-2">
              <label class="text-sm font-semibold">China city or destination<input required name="city" maxlength="100" class="ds-input mt-2" placeholder="Shanghai, Hong Kong, Chengdu..." /></label>
              <label class="text-sm font-semibold">Source language<input required name="sourceLanguage" maxlength="40" class="ds-input mt-2" placeholder="Chinese, Cantonese, English..." /></label>
              <label class="text-sm font-semibold">Source ecosystem
                <select required name="sourcePlatform" class="ds-input mt-2">
                  <option value="">Choose one</option>
                  <option value="xiaohongshu">Xiaohongshu</option>
                  <option value="dianping">Dianping</option>
                  <option value="instagram">Instagram</option>
                  <option value="tiktok">TikTok</option>
                  <option value="local-map">Local map</option>
                  <option value="local-publication">Local publication or guide</option>
                  <option value="personal-knowledge">Personal local knowledge</option>
                  <option value="other">Other</option>
                </select>
              </label>
              <label class="text-sm font-semibold">What is it?
                <select required name="kind" class="ds-input mt-2" data-contribution-kind>
                  <option value="place">One place or venue</option>
                  <option value="route">A bounded walk or route</option>
                  <option value="unclear">Not sure yet</option>
                </select>
              </label>
            </div>

            <label class="mt-4 block text-sm font-semibold">Original place or route name<input required name="originalName" maxlength="160" class="ds-input mt-2" placeholder="Keep the original script when possible" /></label>

            <div class="mt-4 hidden grid gap-4 sm:grid-cols-2" data-route-fields>
              <label class="text-sm font-semibold">Route start<input name="routeStart" maxlength="160" class="ds-input mt-2" placeholder="Named entrance or intersection" /></label>
              <label class="text-sm font-semibold">Route end<input name="routeEnd" maxlength="160" class="ds-input mt-2" placeholder="Named exit or final stop" /></label>
            </div>

            <div class="mt-4 grid gap-4 sm:grid-cols-2">
              <label class="text-sm font-semibold">Public source link <span class="font-normal text-faint">if available</span><input name="sourceUrl" type="url" class="ds-input mt-2" placeholder="https://…" /></label>
              <label class="text-sm font-semibold">Local map share link <span class="font-normal text-faint">optional</span><input name="localMapUrl" type="url" class="ds-input mt-2" placeholder="AMap, Apple, Baidu, Google…" /></label>
            </div>

            <label class="mt-4 block text-sm font-semibold">Original caption, quote, or screenshot OCR<textarea name="evidenceText" maxlength="2000" class="ds-input mt-2 min-h-32" placeholder="Paste the relevant local-language wording. Keep claims and qualifiers intact."></textarea></label>
            <label class="mt-4 block text-sm font-semibold">Why might this change a traveler’s plan?<textarea required name="whyItMatters" maxlength="500" class="ds-input mt-2 min-h-24" placeholder="The concrete reason, tradeoff, warning, route role, or experience—not ‘hidden gem.’"></textarea></label>

            <label class="mt-4 block text-sm font-semibold">Your relationship to this evidence
              <select name="personalContext" class="ds-input mt-2">
                <option value="source-only">I found the source</option>
                <option value="planning">I am considering it for a trip</option>
                <option value="visited">I went here</option>
                <option value="local">I know this place locally</option>
              </select>
            </label>

            <label class="mt-5 flex items-start gap-3 text-sm leading-relaxed text-soft">
              <input required name="rightsConsent" type="checkbox" class="mt-1" />
              <span>I can share this link or short evidence excerpt for review. I understand it will not publish automatically and may be corrected, merged, or rejected.</span>
            </label>

            <div class="mt-6 flex flex-wrap items-center gap-3">
              <button type="submit" class="ds-button ds-button-dark">Prepare contribution</button>
              <p class="hidden text-sm text-soft" data-contribution-status aria-live="polite"></p>
            </div>
          </form>
        </div>

        <section class="mt-6 hidden rounded-3xl border border-line bg-surface p-5 sm:p-6" data-contribution-result aria-labelledby="contribution-result-heading">
          <p class="ds-eyebrow">Review packet ready</p>
          <h3 id="contribution-result-heading" class="mt-2 text-2xl font-bold" data-contribution-title></h3>
          <p class="mt-2 max-w-3xl text-sm leading-relaxed text-soft">The record is saved on this device only. Download it or prepare an email to send it for human review.</p>
          <ul class="mt-5 grid gap-2 sm:grid-cols-2" data-contribution-checklist></ul>
          <div class="mt-6 flex flex-wrap gap-3">
            <button type="button" class="ds-button ds-button-dark" data-contribution-email>Prepare review email</button>
            <button type="button" class="ds-button ds-button-secondary" data-contribution-download>Download JSON</button>
            <button type="button" class="text-sm font-semibold text-soft hover:text-accent" data-contribution-reset>Share another source</button>
          </div>
        </section>
      </div>
    </details>
  </section>

  <section id="resultSection" class="mx-auto hidden max-w-6xl px-4 pb-8 sm:px-6">
    <div class="grid gap-5 lg:grid-cols-[minmax(0,1fr)_21rem] lg:items-start">
      <div class="ds-card min-w-0 p-5 sm:p-6">
      <div class="flex flex-wrap items-end justify-between gap-3">
        <div>
          <p class="ds-eyebrow">Extracted collection</p>
          <h2 id="collectionTitle" class="mt-1 text-2xl font-bold">Places from this list</h2>
        </div>
        <div class="flex flex-wrap gap-2">
          <button id="changeLinkBtn" type="button" class="ds-button ds-button-secondary">Change link</button>
        </div>
      </div>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-soft">Check the identity and source line, then give every place a decision. “Maybe” is deliberately unresolved; nothing enters the route until someone marks it Keep.</p>
      <p id="resultStatusText" class="ds-card mt-4 hidden p-3 text-sm leading-relaxed text-soft" aria-live="polite"></p>
      <div id="placeResult" class="mt-4 grid gap-3"></div>
      </div>

      <aside class="ds-card p-5 lg:sticky lg:top-24" aria-labelledby="workspaceHeading">
        <p class="ds-eyebrow">Decision workspace</p>
        <h2 id="workspaceHeading" class="mt-1 text-2xl font-bold">Make the list usable</h2>
        <div id="decisionSummary" class="mt-4 grid grid-cols-3 gap-2 text-center"></div>

        <details class="mt-5 border-t border-line pt-4" open>
          <summary class="cursor-pointer font-semibold text-ink">Trip constraints</summary>
          <div class="mt-3 grid gap-3">
            <label class="text-xs font-semibold text-faint">Start or hotel base<input id="constraintBase" class="ds-input mt-1 text-sm" placeholder="e.g. Jing'an, Shanghai"></label>
            <label class="text-xs font-semibold text-faint">Time available<input id="constraintTime" class="ds-input mt-1 text-sm" placeholder="e.g. Tue 10:00–18:00"></label>
            <label class="text-xs font-semibold text-faint">Pace<select id="constraintPace" class="ds-input mt-1 text-sm"><option value="relaxed">Relaxed</option><option value="balanced" selected>Balanced</option><option value="full">Full day</option></select></label>
            <label class="text-xs font-semibold text-faint">Must-do<input id="constraintMustDo" class="ds-input mt-1 text-sm" placeholder="One non-negotiable"></label>
            <label class="text-xs font-semibold text-faint">Access, diet, budget, or booking needs<textarea id="constraintNeeds" class="ds-input mt-1 min-h-20 resize-y text-sm" maxlength="280" placeholder="Only constraints that change the choice"></textarea></label>
          </div>
        </details>

        <div class="mt-5 border-t border-line pt-4">
          <div class="flex items-center justify-between gap-3">
            <h3 class="font-semibold text-ink">Conflicts to resolve</h3>
            <span id="conflictCount" class="ds-tag">0</span>
          </div>
          <div id="conflictList" class="mt-3 grid gap-2 text-sm text-soft"></div>
        </div>

        <div class="mt-5 border-t border-line pt-4">
          <h3 class="font-semibold text-ink">Smallest coherent route</h3>
          <div id="routePreview" class="mt-3 grid gap-3 text-sm text-soft"></div>
        </div>

        <div class="mt-5 grid gap-2">
          <button id="sharePlanBtn" type="button" class="ds-button ds-button-primary">Copy editable task link</button>
          <button id="copyHandoffBtn" type="button" class="ds-button ds-button-secondary">Copy map handoff</button>
          <button id="saveCollectionBtn" type="button" class="ds-button ds-button-dark">Save kept places</button>
          <p class="text-xs leading-relaxed text-faint">The link is a reopenable snapshot, not live multi-user sync. AMap and Apple links still require you to confirm the provider result.</p>
        </div>
      </aside>
    </div>
  </section>

  <section id="savedSection" class="mx-auto hidden max-w-6xl px-4 pb-12 sm:px-6">
    <div class="ds-card p-5 sm:p-6">
      <div class="flex items-end justify-between gap-3">
        <div>
          <p class="ds-eyebrow">Saved here</p>
          <h2 class="mt-1 text-2xl font-bold">My saved pin lists</h2>
          <p class="mt-1 text-sm text-soft">Places ready to open, save, or remix in a map app.</p>
        </div>
        <div class="flex flex-wrap items-center gap-3">
          <p id="userBadge" class="text-sm text-faint"></p>
          <a href="/profile/" class="ds-button ds-button-secondary min-h-0 px-3 py-2">View Profile</a>
        </div>
      </div>
      <div id="savedList" class="mt-4 grid gap-2 text-sm text-soft"></div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-12 sm:px-6">
    <div class="grid gap-5 lg:grid-cols-[0.72fr_1.28fr]">
      <div>
        <p class="ds-eyebrow">How it works</p>
        <h2 class="mt-2 text-2xl font-bold">What happens after I paste a list?</h2>
        <p class="mt-3 text-sm leading-relaxed text-soft">
          The tool keeps the source evidence attached, marks heuristic matches, carries group decisions into the shared link, and sequences only kept places.
          It does not pretend a text guess is a verified point of interest or that a snapshot link is live collaboration.
        </p>
      </div>
      <dl class="grid gap-3">
        {mapFaqs.map((item) => (
          <div class="ds-card p-4">
            <dt class="font-semibold text-ink">{item.q}</dt>
            <dd class="mt-2 text-sm leading-relaxed text-soft">{item.a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <script>
    import { amapUrl, appleMapsUrl, displayName, extractTripPlaces, normalizeSource, sourceFromShareOrLink } from '../utils/placeExtraction.js';
    import { getSavedPinLists, getUser, savePinList } from '../utils/localPrototypeState.js';
    import { createSharedWorkspace, decisionCounts, decodeSharedWorkspace, encodeSharedWorkspace, findWorkspaceConflicts, sequenceKeptPlaces } from '../utils/sharedLocationTask.js';
    import {
      canonicalizeContributionUrl,
      createLocalKnowledgeSubmission,
      inferContributionPlatform,
      localKnowledgeReviewChecklist,
      validateLocalKnowledgeSubmission,
    } from '../utils/localKnowledgeSubmission.js';

    const linkInput = document.querySelector('#linkInput');
    const extractBtn = document.querySelector('#extractBtn');
    const sourceText = document.querySelector('#sourceText');
    const statusText = document.querySelector('#statusText');
    const resultStatusText = document.querySelector('#resultStatusText');
    const importSection = document.querySelector('#importSection');
    const resultSection = document.querySelector('#resultSection');
    const placeResult = document.querySelector('#placeResult');
    const collectionTitle = document.querySelector('#collectionTitle');
    const saveCollectionBtn = document.querySelector('#saveCollectionBtn');
    const sharePlanBtn = document.querySelector('#sharePlanBtn');
    const copyHandoffBtn = document.querySelector('#copyHandoffBtn');
    const changeLinkBtn = document.querySelector('#changeLinkBtn');
    const savedSection = document.querySelector('#savedSection');
    const savedList = document.querySelector('#savedList');
    const userBadge = document.querySelector('#userBadge');
    const decisionSummary = document.querySelector('#decisionSummary');
    const conflictCount = document.querySelector('#conflictCount');
    const conflictList = document.querySelector('#conflictList');
    const routePreview = document.querySelector('#routePreview');
    const constraintBase = document.querySelector('#constraintBase');
    const constraintTime = document.querySelector('#constraintTime');
    const constraintPace = document.querySelector('#constraintPace');
    const constraintMustDo = document.querySelector('#constraintMustDo');
    const constraintNeeds = document.querySelector('#constraintNeeds');
    const contributionDetails = document.querySelector('[data-contribution-details]');
    const contributionForm = document.querySelector('[data-contribution-form]');
    const contributionKind = document.querySelector('[data-contribution-kind]');
    const routeFields = document.querySelector('[data-route-fields]');
    const contributionStatus = document.querySelector('[data-contribution-status]');
    const contributionResult = document.querySelector('[data-contribution-result]');
    const contributionTitle = document.querySelector('[data-contribution-title]');
    const contributionChecklist = document.querySelector('[data-contribution-checklist]');
    const sampleSources = {
      'tiktok-shanghai': {
        collectionName: 'TikTok Shanghai food crawl',
        title: 'Shanghai food crawl: soup dumplings, old streets, skyline',
        url: 'https://www.tiktok.com/@chinatravel/video/7380012345678901234',
        text: 'Save this Shanghai crawl: lunch at Jia Jia Tang Bao, snack walk on Huanghe Road, sunset at The Bund, then camera walk on Wukang Road. #Shanghai #ChinaTravel',
      },
      'instagram-chengdu': {
        collectionName: 'Instagram Chengdu tea day',
        title: 'Chengdu slow day: tea, park, hotpot',
        url: 'https://www.instagram.com/reel/C8ChinaTeaDay/',
        text: "Chengdu save list: start at People's Park, sit at Heming Tea House, then dinner at 小龙坎火锅. Easy first day if you want tea house culture and hotpot.",
      },
    };
    let selectedPlaces = [];
    let selectedSource = null;
    let selectedCollectionName = 'China inspiration collection';
    let currentContribution = null;
    const pendingAuthSaveKey = 'ctme-pending-map-save';
    const contributionStorageKey = 'ctme-local-knowledge-contributions-v1';

    const query = new URLSearchParams(window.location.search);
    const sharedWorkspace = decodeSharedWorkspace(query.get('task'));
    const sharedSource = sourceFromShareOrLink(window.location.search, '');
    if (sharedWorkspace) {
      loadWorkspace(sharedWorkspace);
    } else if (sharedSource.text) {
      linkInput.value = sharedSource.text;
    }
    renderSaved();
    if (sharedWorkspace) {
      showStatus('Reopened an editable task with its evidence, decisions, and trip constraints.', false);
      renderPlaces(selectedPlaces);
      showStage('result');
    } else if (query.get('text')) {
      runExtraction({
        collectionName: query.get('title') || 'Shared China places',
        title: query.get('title') || '',
        text: query.get('text') || '',
        url: query.get('url') || '',
      });
    } else {
      showStage('import');
    }
    if (window.location.hash === '#contribute' && contributionDetails) contributionDetails.open = true;

    extractBtn.addEventListener('click', () => runExtraction(linkInput.value));
    document.querySelectorAll('.sampleBtn').forEach((button) => {
      button.addEventListener('click', () => runExtraction(sampleSources[button.dataset.sample], { fromSample: true }));
    });
    saveCollectionBtn.addEventListener('click', () => saveCollection(keptPlaces(), true));
    sharePlanBtn.addEventListener('click', shareReviewedPlan);
    copyHandoffBtn.addEventListener('click', copyMapHandoff);
    changeLinkBtn.addEventListener('click', () => showStage('import'));
    [constraintBase, constraintTime, constraintPace, constraintMustDo, constraintNeeds].forEach((input) => {
      input.addEventListener('input', updateWorkspaceOverview);
      input.addEventListener('change', updateWorkspaceOverview);
    });
    contributionKind?.addEventListener('change', renderContributionShape);
    contributionForm?.querySelector('[name="sourceUrl"]')?.addEventListener('blur', (event) => {
      const platform = contributionForm.querySelector('[name="sourcePlatform"]');
      if (!platform.value) platform.value = inferContributionPlatform(event.currentTarget.value);
    });
    contributionForm?.addEventListener('submit', prepareContribution);
    document.querySelector('[data-contribution-download]')?.addEventListener('click', downloadContribution);
    document.querySelector('[data-contribution-email]')?.addEventListener('click', emailContribution);
    document.querySelector('[data-contribution-reset]')?.addEventListener('click', resetContribution);
    renderContributionShape();
    resumePendingAuthSave();

    function prepareContribution(event) {
      event.preventDefault();
      const formData = new FormData(event.currentTarget);
      const rawSourceUrl = String(formData.get('sourceUrl') || '').trim();
      const rawMapUrl = String(formData.get('localMapUrl') || '').trim();
      if (rawSourceUrl && !canonicalizeContributionUrl(rawSourceUrl)) {
        showContributionStatus('Use a public HTTPS source link. Local, private-network, credentialed, and HTTP URLs are not accepted.', true);
        return;
      }
      if (rawMapUrl && !canonicalizeContributionUrl(rawMapUrl)) {
        showContributionStatus('Use a public HTTPS map link.', true);
        return;
      }

      const submission = createLocalKnowledgeSubmission({
        city: formData.get('city'),
        sourceLanguage: formData.get('sourceLanguage'),
        sourcePlatform: formData.get('sourcePlatform'),
        sourceUrl: rawSourceUrl,
        kind: formData.get('kind'),
        originalName: formData.get('originalName'),
        evidenceText: formData.get('evidenceText'),
        whyItMatters: formData.get('whyItMatters'),
        personalContext: formData.get('personalContext'),
        localMapUrl: rawMapUrl,
        routeStart: formData.get('routeStart'),
        routeEnd: formData.get('routeEnd'),
        rightsConsent: formData.get('rightsConsent') === 'on',
      });
      const validation = validateLocalKnowledgeSubmission(submission);
      if (!validation.valid) {
        showContributionStatus(validation.errors.join(' · '), true);
        return;
      }

      currentContribution = submission;
      persistContribution(submission);
      renderContributionResult(submission);
      showContributionStatus('Review packet prepared and saved on this device. Nothing has been sent.', false);
      window.gtag?.('event', 'local_knowledge_contribution_prepared', {
        source_platform: submission.sourcePlatform,
        source_language: submission.sourceLanguage,
        contribution_kind: submission.kind,
        has_map_link: Boolean(submission.localMapUrl),
      });
    }

    function renderContributionShape() {
      const isRoute = contributionKind?.value === 'route';
      routeFields?.classList.toggle('hidden', !isRoute);
      routeFields?.querySelectorAll('input').forEach((input) => { input.required = isRoute; });
    }

    function renderContributionResult(submission) {
      const review = localKnowledgeReviewChecklist(submission);
      contributionTitle.textContent = submission.originalName + ' · ' + submission.city;
      contributionChecklist.innerHTML = review.checks.map((check) =>
        '<li class="rounded-2xl border border-line bg-white p-3 text-sm"><strong class="text-ink">' + (check.ready ? 'Ready' : 'Needs review') + '</strong><span class="ml-2 text-soft">' + escapeHtml(check.label) + '</span></li>'
      ).join('');
      contributionResult.classList.remove('hidden');
      contributionResult.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    function persistContribution(submission) {
      try {
        const existing = JSON.parse(localStorage.getItem(contributionStorageKey) || '[]');
        const records = [submission, ...existing.filter((item) => item.submissionId !== submission.submissionId)].slice(0, 25);
        localStorage.setItem(contributionStorageKey, JSON.stringify(records));
      } catch {
        localStorage.setItem(contributionStorageKey, JSON.stringify([submission]));
      }
    }

    function downloadContribution() {
      if (!currentContribution) return;
      const blob = new Blob([JSON.stringify(currentContribution, null, 2) + '\n'], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = currentContribution.submissionId + '.json';
      document.body.append(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(url);
      showContributionStatus('JSON downloaded. Send that file for review when the email body is too long.', false);
    }

    function emailContribution() {
      if (!currentContribution) return;
      const subject = 'Local knowledge contribution · ' + currentContribution.city + ' · ' + currentContribution.originalName;
      window.location.href = 'mailto:hello@chinatravelmadeeasy.com?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(formatContribution(currentContribution));
    }

    function formatContribution(submission) {
      return [
        'Submission: ' + submission.submissionId,
        'City: ' + submission.city,
        'Source language: ' + submission.sourceLanguage,
        'Source ecosystem: ' + submission.sourcePlatform,
        'Shape: ' + submission.kind,
        'Original name: ' + submission.originalName,
        ...(submission.routeStart ? ['Route start: ' + submission.routeStart] : []),
        ...(submission.routeEnd ? ['Route end: ' + submission.routeEnd] : []),
        'Source: ' + (submission.sourceUrl || 'not supplied'),
        'Local map: ' + (submission.localMapUrl || 'not supplied'),
        'Relationship: ' + (submission.personalContext || 'not supplied'),
        '',
        'Why it may change a trip:',
        submission.whyItMatters,
        '',
        'Original evidence:',
        submission.evidenceText || 'Open the supplied public source.',
        '',
        'This record requires translation, provider resolution, duplicate review, and editorial approval before publication.',
      ].join('\n');
    }

    function resetContribution() {
      currentContribution = null;
      contributionForm.reset();
      contributionResult.classList.add('hidden');
      contributionStatus.classList.add('hidden');
      renderContributionShape();
      contributionForm.querySelector('[name="city"]')?.focus();
    }

    function showContributionStatus(message, isError) {
      contributionStatus.textContent = message;
      contributionStatus.classList.remove('hidden');
      contributionStatus.classList.toggle('text-accent', Boolean(isError));
    }

    function runExtraction(input, options = {}) {
      const normalized = typeof input === 'object'
        ? normalizeSource(input)
        : /^https?:\/\//i.test(String(input || '').trim())
          ? sourceFromShareOrLink(window.location.search, input)
          : normalizeSource({ text: input });
      const result = extractTripPlaces(normalized);
      selectedSource = result.source;
      selectedPlaces = result.places.map((place) => ({ ...place, decision: 'maybe', decisionReason: '' }));
      selectedCollectionName = typeof input === 'object' && input.collectionName
        ? input.collectionName
        : result.source.platform + ' China places';
      if (typeof input === 'object') {
        linkInput.value = input.url || '';
      }
      if (!String(normalized.url || normalized.text || '').trim()) {
        showStatus('Paste a link first.', true);
        showStage('import');
        return;
      }
      sourceText.textContent = 'Detected source: ' + result.source.platform + (options.fromSample ? ' sample' : '');
      sourceText.classList.remove('hidden');
      if (!selectedPlaces.length) {
        showStatus('I could not extract a place from this source alone. Paste the caption, screenshot text, or list contents so the page has place names to read. The page does not call third-party APIs.', true);
        showStage('import');
        return;
      }
      setConstraints({ pace: 'balanced' });
      showStatus('Previewed ' + selectedPlaces.length + ' place' + (selectedPlaces.length === 1 ? '' : 's') + ' from ' + result.source.platform + '. Verify each identity, then choose Keep, Maybe, or Drop.', false);
      renderPlaces(selectedPlaces);
      showStage('result');
    }

    function renderPlaces(places) {
      collectionTitle.textContent = selectedCollectionName;
      placeResult.innerHTML = places.map((place, index) => '<article class="ds-card p-4" data-place-card>' +
        '<div class="flex flex-wrap items-center justify-between gap-2"><p class="ds-tag">' + escapeHtml(place.category || 'Place') + '</p>' +
        '<span class="text-xs font-semibold text-faint">' + escapeHtml(place.confidence === 'known place' ? 'Known place match' : 'Needs your review') + '</span></div>' +
        '<div class="mt-3 grid gap-3 sm:grid-cols-2">' +
          '<label class="text-xs font-semibold text-faint">Place name<input data-edit-name="' + index + '" class="ds-input mt-1 text-sm" value="' + escapeHtml(place.name) + '"></label>' +
          '<label class="text-xs font-semibold text-faint">Chinese or local name<input data-edit-local-name="' + index + '" class="ds-input mt-1 text-sm" value="' + escapeHtml(place.localName || '') + '" placeholder="Verify before mainland handoff"></label>' +
          '<label class="text-xs font-semibold text-faint">City<input data-edit-city="' + index + '" class="ds-input mt-1 text-sm" value="' + escapeHtml(place.city || '') + '" placeholder="Add city"></label>' +
          '<div class="text-xs font-semibold text-faint"><span>Decision</span><div class="mt-1 grid grid-cols-3 gap-1" role="group" aria-label="Decision for ' + escapeHtml(place.name) + '">' +
            decisionButton(index, 'keep', 'Keep', place.decision) +
            decisionButton(index, 'maybe', 'Maybe', place.decision) +
            decisionButton(index, 'drop', 'Drop', place.decision) +
          '</div></div>' +
        '</div>' +
        '<p class="mt-3 text-sm leading-relaxed text-soft"><strong class="text-ink">Source evidence:</strong> ' + escapeHtml(place.note || 'No supporting line was captured.') + '</p>' +
        '<label class="mt-3 block text-xs font-semibold text-faint">Why this decision? <span class="font-normal">Optional, shared with the task.</span><input data-edit-reason="' + index + '" class="ds-input mt-1 text-sm" maxlength="280" value="' + escapeHtml(place.decisionReason || '') + '" placeholder="e.g. Must-do, too far, branch still unclear"></label>' +
        '<div class="mt-4 flex flex-wrap gap-2">' +
          '<a target="_blank" rel="noopener" href="' + amapUrl(place) + '" class="ds-button ds-button-primary">Check in AMap</a>' +
          '<a target="_blank" rel="noopener" href="' + appleMapsUrl(place) + '" class="ds-button ds-button-secondary">Check in Apple Maps</a>' +
        '</div></article>').join('');
      document.querySelectorAll('[data-edit-name]').forEach((input) => {
        input.addEventListener('input', () => { selectedPlaces[Number(input.dataset.editName)].name = input.value.trim(); updateWorkspaceOverview(); });
        input.addEventListener('change', () => renderPlaces(selectedPlaces));
      });
      document.querySelectorAll('[data-edit-local-name]').forEach((input) => {
        input.addEventListener('input', () => { selectedPlaces[Number(input.dataset.editLocalName)].localName = input.value.trim(); updateWorkspaceOverview(); });
        input.addEventListener('change', () => renderPlaces(selectedPlaces));
      });
      document.querySelectorAll('[data-edit-city]').forEach((input) => {
        input.addEventListener('input', () => { selectedPlaces[Number(input.dataset.editCity)].city = input.value.trim(); updateWorkspaceOverview(); });
        input.addEventListener('change', () => renderPlaces(selectedPlaces));
      });
      document.querySelectorAll('[data-decision-index]').forEach((button) => {
        button.addEventListener('click', () => {
          selectedPlaces[Number(button.dataset.decisionIndex)].decision = button.dataset.decision;
          renderPlaces(selectedPlaces);
        });
      });
      document.querySelectorAll('[data-edit-reason]').forEach((input) => {
        input.addEventListener('input', () => {
          selectedPlaces[Number(input.dataset.editReason)].decisionReason = input.value.trim();
          updateWorkspaceOverview();
        });
      });
      updateWorkspaceOverview();
    }

    async function saveCollection(places, openMap) {
      const cleanPlaces = (places || []).filter(Boolean);
      if (!cleanPlaces.length) {
        showStatus('Mark at least one place Keep before saving.', true);
        return;
      }
      const workspace = currentWorkspace();
      let user = getUser();
      if (!user) {
        const pendingAction = {
          places: cleanPlaces,
          source: selectedSource,
          collectionName: selectedCollectionName,
          workspace,
        };
        localStorage.setItem(pendingAuthSaveKey, JSON.stringify(pendingAction));
        user = window.ctmeRequireUser ? await window.ctmeRequireUser('save this reviewed list to your profile') : null;
        if (!user) return;
      }
      const sourceUrl = selectedSource?.url || cleanPlaces[0]?.sourceUrl || '';
      const fingerprint = slugify(sourceUrl || selectedCollectionName || cleanPlaces.map((place) => displayName(place)).join('-'));
      const collection = {
        id: 'upload:' + fingerprint,
        name: selectedCollectionName,
        platform: selectedSource?.platform || cleanPlaces[0]?.sourcePlatform || 'Source',
        sourceUrl,
        savedAt: new Date().toISOString(),
        savedBy: user.email,
        places: cleanPlaces,
        decisions: workspace.places.map(({ name, city, decision, decisionReason }) => ({ name, city, decision, decisionReason })),
        constraints: workspace.constraints,
      };
      savePinList(collection);
      renderSaved();
      showStage('saved');
      if (openMap && cleanPlaces.length === 1) window.open(appleMapsUrl(cleanPlaces[0]), '_blank', 'noopener');
      localStorage.removeItem(pendingAuthSaveKey);
    }

    function resumePendingAuthSave() {
      if (!getUser()) return;
      let pending;
      try { pending = JSON.parse(localStorage.getItem(pendingAuthSaveKey) || 'null'); } catch { pending = null; }
      if (!pending?.places?.length) return;
      selectedPlaces = pending.places;
      selectedSource = pending.source || null;
      selectedCollectionName = pending.collectionName || 'China inspiration collection';
      if (pending.workspace) loadWorkspace(pending.workspace);
      localStorage.removeItem(pendingAuthSaveKey);
      saveCollection(pending.places, false);
    }

    async function shareReviewedPlan() {
      const workspace = currentWorkspace();
      if (!workspace.places.length) {
        showStatus('Keep at least one candidate before sharing.', true);
        return;
      }
      const url = new URL('/map-import/', window.location.origin);
      url.searchParams.set('task', encodeSharedWorkspace(workspace));
      try {
        await navigator.clipboard.writeText(url.toString());
        showStatus('Editable task link copied. It reopens the bilingual identities, evidence, decisions, reasons, and constraints as a snapshot.', false);
      } catch {
        window.prompt('Copy this editable task link:', url.toString());
      }
    }

    async function copyMapHandoff() {
      const groups = sequenceKeptPlaces(currentWorkspace());
      if (!groups.length) {
        showStatus('Mark at least one place Keep before copying a map handoff.', true);
        return;
      }
      const constraints = getConstraints();
      const lines = [selectedCollectionName];
      if (constraints.base) lines.push('Start/base: ' + constraints.base);
      if (constraints.time) lines.push('Time: ' + constraints.time);
      lines.push('Pace: ' + constraints.pace);
      if (constraints.mustDo) lines.push('Must-do: ' + constraints.mustDo);
      if (constraints.needs) lines.push('Needs: ' + constraints.needs);
      groups.forEach((group) => {
        lines.push('', group.city);
        group.places.forEach((place, index) => {
          lines.push((index + 1) + '. ' + displayName(place));
          lines.push('   AMap: ' + amapUrl(place));
          lines.push('   Apple Maps: ' + appleMapsUrl(place));
        });
      });
      lines.push('', 'Verify the provider result, branch, entrance, and current opening details before relying on this handoff.');
      try {
        await navigator.clipboard.writeText(lines.join('\n'));
        showStatus('Map handoff copied for the kept places. It includes separate AMap and Apple queries, not a claim that favorites were written.', false);
      } catch {
        window.prompt('Copy this map handoff:', lines.join('\n'));
      }
    }

    function currentWorkspace() {
      return createSharedWorkspace({
        title: selectedCollectionName,
        source: selectedSource,
        places: selectedPlaces,
        constraints: getConstraints(),
      });
    }

    function loadWorkspace(workspace) {
      const clean = createSharedWorkspace(workspace);
      selectedCollectionName = clean.title;
      selectedSource = clean.source;
      selectedPlaces = clean.places;
      linkInput.value = clean.source.text || clean.source.url || '';
      sourceText.textContent = 'Reopened source: ' + clean.source.platform;
      sourceText.classList.remove('hidden');
      setConstraints(clean.constraints);
    }

    function getConstraints() {
      return {
        base: constraintBase.value.trim(),
        time: constraintTime.value.trim(),
        pace: constraintPace.value,
        mustDo: constraintMustDo.value.trim(),
        needs: constraintNeeds.value.trim(),
      };
    }

    function setConstraints(constraints = {}) {
      constraintBase.value = constraints.base || '';
      constraintTime.value = constraints.time || '';
      constraintPace.value = constraints.pace || 'balanced';
      constraintMustDo.value = constraints.mustDo || '';
      constraintNeeds.value = constraints.needs || '';
    }

    function keptPlaces() {
      return selectedPlaces.filter((place) => place.decision === 'keep' && place.name?.trim());
    }

    function decisionButton(index, decision, label, selectedDecision) {
      const selected = decision === selectedDecision;
      return '<button type="button" data-decision-index="' + index + '" data-decision="' + decision + '" aria-pressed="' + selected + '" class="ds-button min-h-0 px-2 py-2 text-xs ' + (selected ? 'ds-button-dark' : 'ds-button-secondary') + '">' + label + '</button>';
    }

    function updateWorkspaceOverview() {
      const workspace = currentWorkspace();
      const counts = decisionCounts(workspace);
      decisionSummary.innerHTML = ['keep', 'maybe', 'drop'].map((decision) =>
        '<div class="ds-card p-2"><strong class="block text-xl text-ink">' + counts[decision] + '</strong><span class="text-xs capitalize text-faint">' + decision + '</span></div>'
      ).join('');

      const conflicts = findWorkspaceConflicts(workspace);
      conflictCount.textContent = String(conflicts.length);
      conflictList.innerHTML = conflicts.length
        ? conflicts.map((conflict) => '<p class="rounded-md border border-line p-2"><strong class="text-ink">' + (conflict.placeIndex === null ? 'Whole task' : 'Place ' + (conflict.placeIndex + 1)) + ':</strong> ' + escapeHtml(conflict.message) + '</p>').join('')
        : '<p class="rounded-md border border-line p-2">No deterministic conflicts found. Still verify hours, closures, reservations, branch, and entrance in the provider.</p>';

      const groups = sequenceKeptPlaces(workspace);
      routePreview.innerHTML = groups.length
        ? groups.map((group) => '<div><p class="font-semibold text-ink">' + escapeHtml(group.city) + '</p><ol class="mt-2 grid gap-2">' + group.places.map((place, index) => '<li class="grid grid-cols-[1.5rem_1fr] gap-2"><span class="grid h-6 w-6 place-items-center rounded-full border border-line text-xs">' + (index + 1) + '</span><span><strong class="block text-ink">' + escapeHtml(displayName(place)) + '</strong><span class="text-xs">Source order; confirm travel time in AMap.</span></span></li>').join('') + '</ol></div>').join('')
        : '<p class="rounded-md border border-dashed border-line p-3">Mark a place Keep to build the handoff order.</p>';
      saveCollectionBtn.textContent = counts.keep ? 'Save ' + counts.keep + ' kept place' + (counts.keep === 1 ? '' : 's') : 'Save kept places';
    }

    function renderSaved() {
      const user = getUser();
      userBadge.textContent = user ? user.email : 'Not signed in';
      const saved = getSavedPinLists();
      if (!saved.length) {
        savedList.innerHTML = '<div class="ds-card border-dashed p-4">Saved collections will appear here after sign-in.</div>';
        return;
      }
      savedList.innerHTML = saved.map((collection) => {
        const places = Array.isArray(collection.places) ? collection.places : [collection];
        return '<article class="ds-card p-4">' +
          '<div class="flex flex-wrap items-start justify-between gap-3">' +
          '<div><p class="ds-tag">' + escapeHtml(collection.platform || 'Collection') + '</p>' +
          '<h3 class="text-xl font-bold text-ink">' + escapeHtml(collection.name || displayName(places[0])) + '</h3></div>' +
          '<span class="text-xs text-faint">' + places.length + ' place' + (places.length === 1 ? '' : 's') + '</span></div>' +
          '<div class="mt-3 flex flex-wrap gap-2">' + places.map((place) => '<a target="_blank" rel="noopener" href="' + appleMapsUrl(place) + '" class="ds-chip hover:border-accent/50 hover:text-accent">' + escapeHtml(displayName(place)) + '</a>').join('') + '</div>' +
          '<a href="/profile/" class="mt-4 inline-flex text-sm font-semibold text-ink hover:text-accent">See it on Profile</a>' +
        '</article>';
      }).join('');
    }

    function showStage(stage) {
      importSection.classList.toggle('hidden', stage !== 'import');
      resultSection.classList.toggle('hidden', stage !== 'result');
      savedSection.classList.toggle('hidden', stage !== 'saved');
    }
    function showStatus(message, isError) {
      [statusText, resultStatusText].forEach((target) => {
        target.textContent = message;
        target.classList.remove('hidden');
        target.classList.toggle('border-accent', Boolean(isError));
      });
    }
    function keyFor(place) { return String(place.name || '').toLowerCase() + '|' + String(place.city || '').toLowerCase(); }
    function slugify(value) {
      return String(value || 'list')
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-|-$/g, '')
        .slice(0, 96) || 'list';
    }
    function escapeHtml(value) { return String(value || '').replace(/[&<>"]/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[char])); }
  </script>
</Base>
