---
import Base from '../layouts/Base.astro';
import AnswerListingPage from '../components/AnswerListingPage.astro';
import { questionAlternates, questionLocales } from '../data/localizedQuestions';

const page = questionLocales.en;
const perPage = 6;
const answerItems = page.groups.flatMap((group) => group.questions);
const currentPage = 1;
const totalPages = Math.ceil(answerItems.length / perPage);
const pagedItems = answerItems.slice(0, perPage);
const faqEntities = page.groups.flatMap((group) =>
  group.questions.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
      url: new URL(item.href, Astro.site).toString(),
    },
  }))
);
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: page.title,
    description: page.description,
    inLanguage: page.lang,
    about: ['China travel planning', 'China visas', 'China payments', 'China transport'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    name: page.title,
    description: page.description,
    inLanguage: page.lang,
    mainEntity: faqEntities,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: page.title,
    description: page.description,
    inLanguage: page.lang,
    numberOfItems: pagedItems.length,
    itemListElement: pagedItems.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.q,
      description: item.answer,
      url: new URL(item.href, Astro.site).toString(),
    })),
  },
];
---

<Base title={page.title} description={page.description} lang={page.lang} alternates={questionAlternates} jsonLd={jsonLd}>
  <AnswerListingPage page={page} items={pagedItems} currentPage={currentPage} totalPages={totalPages} />
</Base>
